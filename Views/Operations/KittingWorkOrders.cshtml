@model WMS.ViewModels.KittingWorkOrderPageViewModel
@using WMS.Models
@{
    ViewData["Title"] = "Phiếu lắp bộ hàng";
    string StatusText(KittingWorkOrderStatusEnum status) => status switch
    {
        KittingWorkOrderStatusEnum.Draft => "Nháp",
        KittingWorkOrderStatusEnum.Reserved => "Đã giữ chỗ",
        KittingWorkOrderStatusEnum.Completed => "Hoàn tất",
        KittingWorkOrderStatusEnum.Cancelled => "Đã hủy",
        _ => "Không áp dụng"
    };
    string StatusBadge(KittingWorkOrderStatusEnum status) => status switch
    {
        KittingWorkOrderStatusEnum.Reserved => "badge-info",
        KittingWorkOrderStatusEnum.Completed => "badge-success",
        KittingWorkOrderStatusEnum.Cancelled => "badge-danger",
        _ => "badge-secondary"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-boxes-packing text-accent"></i> Phiếu lắp bộ hàng</h1>
        <p class="page-subtitle">Lắp bộ hàng hoặc bộ quà tặng từ nhiều vật tư thành phần, giữ chỗ theo nguyên tắc hết hạn trước xuất trước, tiêu hao tồn và nhập mã hàng bộ sau khi hoàn tất.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-controller="Operations" asp-action="CreateKittingWorkOrder"><i class="fas fa-plus"></i> Tạo phiếu lắp bộ hàng</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card"><div class="stat-value">@Model.DraftCount</div><div class="stat-label">Nháp</div></div>
    <div class="stat-card info"><div class="stat-value">@Model.ReservedCount</div><div class="stat-label">Đã giữ chỗ</div></div>
    <div class="stat-card success"><div class="stat-value">@Model.CompletedCount</div><div class="stat-label">Hoàn tất</div></div>
    <div class="stat-card danger"><div class="stat-value">@Model.CancelledCount</div><div class="stat-label">Đã hủy</div></div>
</div>

<form method="get" class="filter-bar">
    <div class="form-group">
        <label class="form-label">Kho</label>
        <select class="form-control" name="warehouseId">
            <option value="">Tất cả</option>
            @foreach (var w in Model.Warehouses)
            {
                <option value="@w.WarehouseId" selected="@(Model.WarehouseId == w.WarehouseId)">@w.WarehouseCode - @w.WarehouseName</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Trạng thái</label>
        <select class="form-control" name="status">
            <option value="">Tất cả</option>
            @foreach (KittingWorkOrderStatusEnum s in Enum.GetValues<KittingWorkOrderStatusEnum>())
            {
                <option value="@s" selected="@(Model.Status == s)">@StatusText(s)</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Tìm nhanh</label>
        <input class="form-control" name="search" value="@Model.Search" placeholder="mã phiếu, mã hàng bộ, tên bộ, lô..." />
    </div>
    <div class="form-group">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary" type="submit"><i class="fas fa-filter"></i> Lọc</button>
    </div>
</form>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Phiếu</th>
                <th>Mã hàng bộ</th>
                <th>Kho</th>
                <th>Vị trí nhập</th>
                <th class="td-number">Số lượng</th>
                <th>Lô/HSD</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.WorkOrders.Any())
        {
            <tr><td colspan="8" class="cell-empty cell-empty-md">Chưa có phiếu lắp bộ hàng nào theo bộ lọc hiện tại.</td></tr>
        }
        @foreach (var order in Model.WorkOrders)
        {
            <tr>
                <td>
                    <div class="td-code">@order.WorkOrderCode</div>
                    <div class="table-subtext-sm">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </td>
                <td>
                    <div class="fw-700">@order.FinishedItem?.ItemCode</div>
                    <div class="table-subtext-sm">@order.FinishedItem?.ItemName</div>
                </td>
                <td>@order.Warehouse?.WarehouseCode</td>
                <td><span class="td-code">@order.FinishedLocation?.LocationCode</span></td>
                <td class="td-number">@order.CompletedQty.ToString("N0") / @order.PlannedQty.ToString("N0")</td>
                <td>@(order.FinishedLotNumber ?? "---") @(order.FinishedExpiryDate.HasValue ? $" / {order.FinishedExpiryDate:dd/MM/yyyy}" : "")</td>
                <td><span class="badge @StatusBadge(order.Status)">@StatusText(order.Status)</span></td>
                <td class="td-actions">
                    <a class="btn btn-sm btn-primary" asp-controller="Operations" asp-action="KittingWorkOrderDetails" asp-route-id="@order.KittingWorkOrderId"><i class="fas fa-eye"></i> Chi tiết</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
