@model List<WMS.Models.CapacityScenario>
@{
    ViewData["Title"] = "Mô phỏng sức chứa";
    var scenarios = Model;
    var warehouses = ViewBag.Warehouses as List<WMS.Models.Warehouse> ?? new();
    int? warehouseId = ViewBag.WarehouseId;
    int baselineVolume = ViewBag.BaselineVolume ?? 0;
    int dockCount = ViewBag.DockCount ?? 0;
    int laborCount = ViewBag.LaborCount ?? 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-chart-line text-primary"></i> Mô phỏng sức chứa</h1>
        <p class="page-subtitle">Lập kế hoạch giả định nếu-thì — dự báo nhu cầu cửa xuất/nhập, nhân sự và điểm nghẽn khi khối lượng thay đổi</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Operations" asp-action="Slotting" class="btn btn-secondary"><i class="fas fa-layer-group"></i> Định vị lưu kho</a>
        <a asp-controller="Operations" asp-action="LaborProductivity" class="btn btn-secondary"><i class="fas fa-users-gear"></i> Hiệu suất nhân sự</a>
    </div>
</div>

<!-- Baseline Metrics -->
<div class="enterprise-card mb-4">
    <div class="enterprise-card-header">
        <div>
            <h3 class="enterprise-card-title"><i class="fas fa-warehouse"></i> Chỉ số cơ sở (30 ngày gần nhất)</h3>
        </div>
    </div>
    <div class="enterprise-card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-file-invoice"></i></div>
                    <div class="kpi-content">
                        <div class="kpi-value">@baselineVolume</div>
                        <div class="kpi-label">Đơn hàng/ngày TB</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-door-open"></i></div>
                    <div class="kpi-content">
                        <div class="kpi-value">@dockCount</div>
                        <div class="kpi-label">Cửa xuất, nhập</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-user-tie"></i></div>
                    <div class="kpi-content">
                        <div class="kpi-value">@laborCount</div>
                        <div class="kpi-label">Nhân sự đang làm việc</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Run Simulation Form -->
<div class="enterprise-card mb-4">
    <div class="enterprise-card-header">
        <div>
            <h3 class="enterprise-card-title"><i class="fas fa-play text-success"></i> Chạy Mô phỏng Mới</h3>
            <p class="enterprise-card-subtitle">Nhập các tham số giả định để phân tích điểm nghẽn</p>
        </div>
    </div>
    <div class="enterprise-card-body">
        <form method="post" asp-controller="Operations" asp-action="RunCapacitySimulation">
            @Html.AntiForgeryToken()
            <input type="hidden" name="WarehouseId" value="@warehouseId" />
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Tên kịch bản <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="ScenarioName" required placeholder="VD: Tết 2026" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <input type="text" class="form-control" name="Description" placeholder="Mô tả ngắn..." />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Khối lượng/ngày</label>
                        <input type="number" class="form-control" name="DailyVolume" value="@baselineVolume" min="1" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Tăng trưởng (%)</label>
                        <input type="number" class="form-control" name="VolumeGrowthPct" value="0" min="-50" max="200" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Hệ số mùa vụ (Peak Factor)</label>
                        <input type="number" class="form-control" name="PeakFactor" value="1.0" step="0.1" min="1.0" max="3.0" />
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Số cửa bến hiện tại</label>
                        <input type="number" class="form-control" name="DockCount" value="@dockCount" min="1" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Số Labor hiện tại</label>
                        <input type="number" class="form-control" name="LaborCount" value="@laborCount" min="1" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Giờ làm/ngày</label>
                        <input type="number" class="form-control" name="WorkingHoursPerDay" value="8" min="1" max="24" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Giờ cao điểm</label>
                        <input type="number" class="form-control" name="PeakHours" value="4" min="1" max="24" />
                    </div>
                </div>
                <div class="col-md-4 form-action-top">
                    <button type="submit" class="btn btn-success"><i class="fas fa-play"></i> Chạy Mô phỏng</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Simulation Results -->
@if (scenarios.Any())
{
    <div class="enterprise-card">
        <div class="enterprise-card-header">
            <div>
                <h3 class="enterprise-card-title"><i class="fas fa-list-alt"></i> Lịch sử Kịch bản</h3>
            </div>
        </div>
        <div class="enterprise-card-body">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Tên kịch bản</th>
                            <th>Ngày</th>
                            <th class="text-right">Khối lượng</th>
                            <th class="text-right">Tăng trưởng %</th>
                            <th class="text-right">Cửa bến</th>
                            <th class="text-right">Labor</th>
                            <th>Điểm nghẽn</th>
                            <th>Khuyến nghị</th>
                            <th>Độ tin cậy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in scenarios)
                        {
                            <tr class="@(s.CriticalBottleneck == "Dock" ? "row-danger" : s.CriticalBottleneck == "Labor" ? "row-warning" : "row-success")">
                                <td><strong>@s.ScenarioName</strong><br><small class="text-muted">@s.CreatedBy</small></td>
                                <td>@s.ScenarioDate.ToString("dd/MM/yyyy")<br><small class="text-muted">@s.CreatedAt.ToString("HH:mm")</small></td>
                                <td class="text-right">@s.DailyVolume</td>
                                <td class="text-right">
                                    <span class="badge @(s.VolumeGrowthPct > 30 ? "badge-danger" : s.VolumeGrowthPct > 0 ? "badge-warning" : "badge-secondary")">
                                        @(s.VolumeGrowthPct > 0 ? "+" : "")@s.VolumeGrowthPct%
                                    </span>
                                </td>
                                <td class="text-right">@s.DockCount</td>
                                <td class="text-right">@s.LaborCount</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(s.Bottlenecks))
                                    {
                                        foreach (var bn in s.Bottlenecks.Split(';'))
                                        {
                                            <span class="badge badge-danger mr-1">@bn.Trim()</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge badge-success"><i class="fas fa-check"></i> OK</span>
                                    }
                                </td>
                                <td class="fs-sm">@s.Recommendations</td>
                                <td>
                                    <div class="progress-bar-container">
                                        <div class="progress-bar-fill @(s.ConfidenceScore >= 80 ? "bg-success" : s.ConfidenceScore >= 50 ? "bg-warning" : "bg-danger")"
                                             data-progress-width="@($"{s.ConfidenceScore:0.##}%")"></div>
                                        <span class="progress-bar-text">@s.ConfidenceScore%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fas fa-chart-line"></i></div>
        <div class="empty-text">Chưa có kịch bản nào</div>
        <div class="empty-sub">Chạy mô phỏng đầu tiên để bắt đầu lập kế hoạch giả định.</div>
    </div>
}
