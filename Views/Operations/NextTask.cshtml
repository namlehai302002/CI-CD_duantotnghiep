@model WMS.ViewModels.InterleavedTaskQueue
@{
    ViewData["Title"] = "Nhiệm vụ tiếp theo";
    var warehouses = (List<WMS.Models.Warehouse>?)ViewBag.Warehouses ?? new();
    var warehouseId = (int?)ViewBag.WarehouseId;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Nhiệm vụ tiếp theo</h1>
        <p class="page-subtitle">Hệ thống gợi ý nhiệm vụ gần nhất theo vị trí hiện tại — tránh đi tay không, tăng năng suất.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Operations" asp-action="RfPicking" class="btn btn-secondary"><i class="fas fa-hand-pointer"></i> Quét lấy hàng</a>
        <a asp-controller="Operations" asp-action="RfMovement" class="btn btn-secondary"><i class="fas fa-dolly"></i> Quét điều chuyển</a>
    </div>
</div>

<!-- ═══ Quét vị trí hiện tại ═══ -->
<div class="card next-task-scanner-card">
    <div class="card-body">
        <form method="get" asp-controller="Operations" asp-action="NextTask" id="location-form">
            @if (warehouseId.HasValue)
            {
                <input type="hidden" name="warehouseId" value="@warehouseId" />
            }
            <div class="enterprise-inline-controls">
                @if (warehouses.Count > 1)
                {
                    <div class="form-group w-180">
                        <label class="form-label">Kho</label>
                        <select name="warehouseId" class="form-control" data-wms-submit-form="true">
                            <option value="">Tất cả kho</option>
                            @foreach (var w in warehouses)
                            {
                                <option value="@w.WarehouseId" selected="@(warehouseId == w.WarehouseId)">@w.WarehouseName</option>
                            }
                        </select>
                    </div>
                }
                <div class="form-group flex-1 min-w-200">
                    <label class="form-label"><i class="fas fa-location-dot"></i> Quét vị trí hiện tại</label>
                    <div class="scan-input-row">
                        <input class="form-control" id="location-scan-input" name="locationScan"
                               value="@Model.CurrentLocationCode"
                               placeholder="Quét mã vạch vị trí bạn đang đứng..." autofocus />
                        <button type="button" class="btn btn-secondary scan-camera-btn" data-wms-call="scanCurrentLocation" title="Mở camera quét vị trí">
                            <i class="fas fa-camera"></i>
                        </button>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
                    </div>
                </div>
                @if (Model.CurrentLocationCode != null)
                {
                    <div class="form-group">
                        <span class="badge badge-success badge-roomy-lg">
                            <i class="fas fa-map-pin"></i> @Model.CurrentLocationCode
                            @if (!string.IsNullOrEmpty(Model.CurrentZoneCode))
                            {
                                <span class="opacity-muted">| Khu vực @Model.CurrentZoneCode</span>
                            }
                        </span>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<!-- ═══ Scoring Explanation ═══ -->
@if (!string.IsNullOrWhiteSpace(Model.ScoringExplanation))
{
    <div class="scoring-explanation">
        <i class="fas fa-brain"></i> @Model.ScoringExplanation
    </div>
}

<!-- ═══ Summary Stats ═══ -->
<div class="next-task-stats">
    <div class="stat-chip stat-pick">
        <i class="fas fa-hand-pointer"></i>
        <span>Lấy hàng: <strong>@Model.TotalPickTasks</strong></span>
    </div>
    <div class="stat-chip stat-move">
        <i class="fas fa-dolly"></i>
        <span>Điều chuyển: <strong>@Model.TotalMovementTasks</strong></span>
    </div>
    <div class="stat-chip stat-total">
        <i class="fas fa-list-check"></i>
        <span>Hiển thị: <strong>@Model.Tasks.Count</strong> / @(Model.TotalPickTasks + Model.TotalMovementTasks)</span>
    </div>
</div>

<!-- ═══ Task Queue ═══ -->
@if (!Model.Tasks.Any())
{
    <div class="card">
        <div class="card-body text-center text-muted cell-empty-lg">
            <i class="fas fa-check-circle empty-success-icon empty-success-icon-lg"></i>
            <strong>Không có nhiệm vụ nào đang chờ!</strong>
            <p class="mt-3">Tất cả nhiệm vụ đã được xử lý hoặc nằm ngoài phạm vi kho/khu vực của bạn.</p>
        </div>
    </div>
}
else
{
    <div class="next-task-grid">
        @{ var rank = 0; }
        @foreach (var task in Model.Tasks)
        {
            rank++;
            var isPick = task.Category == WMS.ViewModels.TaskCategoryEnum.Pick;
            var categoryBadge = isPick ? "badge-pick" : "badge-move";
            var categoryIcon = isPick ? "fa-hand-pointer" : "fa-dolly";
            var categoryLabel = isPick ? "LẤY HÀNG" : "ĐIỀU CHUYỂN";
            var remaining = task.PlannedQty - task.CompletedQty;

            var priorityLabel = task.Priority switch
            {
                WMS.Models.MovementTaskPriorityEnum.Urgent => "Khẩn cấp",
                WMS.Models.MovementTaskPriorityEnum.High => "Cao",
                WMS.Models.MovementTaskPriorityEnum.Normal => "Bình thường",
                WMS.Models.MovementTaskPriorityEnum.Low => "Thấp",
                _ => ""
            };
            var priorityBadge = task.Priority switch
            {
                WMS.Models.MovementTaskPriorityEnum.Urgent => "badge-danger",
                WMS.Models.MovementTaskPriorityEnum.High => "badge-warning",
                _ => "badge-secondary"
            };

            <div class="card next-task-card @(rank == 1 ? "next-task-top" : "")">
                <div class="card-header enterprise-table-tools">
                    <span>
                        <span class="rank-badge">#@rank</span>
                        <span class="badge @categoryBadge"><i class="fas @categoryIcon"></i> @categoryLabel</span>
                        @if (task.Priority >= WMS.Models.MovementTaskPriorityEnum.High)
                        {
                            <span class="badge @priorityBadge">@priorityLabel</span>
                        }
                    </span>
                    <span class="score-total" title="@task.ScoreBreakdown">
                        <i class="fas fa-star"></i> @task.TotalScore điểm
                    </span>
                </div>
                <div class="card-body">
                    <div class="task-info-grid">
                        <div class="rf-meta"><strong>Mã:</strong> @task.TaskCode</div>
                        <div class="rf-meta"><strong>Loại:</strong> @task.TaskTypeName</div>
                        <div class="rf-meta"><strong>Vật tư:</strong> @task.ItemCode @(!string.IsNullOrEmpty(task.ItemName) ? $"- {task.ItemName}" : "")</div>
                        <div class="rf-meta">
                            <strong>Từ:</strong> <span class="location-code">@task.SourceLocationCode</span>
                            <i class="fas fa-arrow-right task-arrow-muted"></i>
                            <strong>Đến:</strong> <span class="location-code">@task.DestinationLocationCode</span>
                        </div>
                        <div class="rf-meta"><strong>Số lượng:</strong> @remaining.ToString("N2") / @task.PlannedQty.ToString("N2")</div>
                        @if (!string.IsNullOrWhiteSpace(task.ZoneCode))
                        {
                            <div class="rf-meta"><strong>Khu vực:</strong> @task.ZoneCode @(!string.IsNullOrEmpty(task.AisleCode) ? $"| Dãy {task.AisleCode}" : "")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(task.AssignedTo))
                        {
                            <div class="rf-meta"><strong>Đã gán:</strong> @task.AssignedTo</div>
                        }
                        @if (task.DueAt.HasValue)
                        {
                            var overdue = task.DueAt.Value < WMS.Common.VietnamTime.Now;
                            <div class="rf-meta">
                                <strong>Hạn:</strong>
                                <span class="@(overdue ? "text-danger" : "")">
                                    @task.DueAt.Value.ToString("dd/MM HH:mm")
                                    @(overdue ? " ⚠ QUÁ HẠN" : "")
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Score breakdown bar -->
                    <div class="score-breakdown">
                        <div class="score-bar">
                            <div class="score-segment score-proximity" data-segment-width="@($"{task.ProximityScore * 0.4:0.##}%")" title="Gần: @task.ProximityScore"></div>
                            <div class="score-segment score-priority" data-segment-width="@($"{task.PriorityScore * 0.3:0.##}%")" title="Ưu tiên: @task.PriorityScore"></div>
                            <div class="score-segment score-urgency" data-segment-width="@($"{task.UrgencyScore * 0.2:0.##}%")" title="Khẩn: @task.UrgencyScore"></div>
                            @if (task.InterleavingBonus > 0)
                            {
                                <div class="score-segment score-interleave" data-segment-width="@($"{task.InterleavingBonus * 0.1:0.##}%")" title="Xen kẽ: @task.InterleavingBonus"></div>
                            }
                        </div>
                        <div class="score-legend">
                            <span><span class="dot dot-proximity"></span>Gần @task.ProximityScore</span>
                            <span><span class="dot dot-priority"></span>Ưu tiên @task.PriorityScore</span>
                            <span><span class="dot dot-urgency"></span>Khẩn @task.UrgencyScore</span>
                            @if (task.InterleavingBonus > 0)
                            {
                                <span><span class="dot dot-interleave"></span>Xen kẽ +@task.InterleavingBonus</span>
                            }
                        </div>
                    </div>

                    <!-- Accept button -->
                    <form method="post" asp-controller="Operations" asp-action="AcceptNextTask" class="mt-3" data-enterprise-confirm="Nhận nhiệm vụ này để xử lý trong ca hiện tại?" data-enterprise-confirm-ok="Nhận nhiệm vụ">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="category" value="@((int)task.Category)" />
                        <input type="hidden" name="taskId" value="@task.TaskId" />
                        @if (warehouseId.HasValue)
                        {
                            <input type="hidden" name="warehouseId" value="@warehouseId" />
                        }
                        <button type="submit" class="btn @(rank == 1 ? "btn-primary" : "btn-secondary") btn-accept">
                            <i class="fas fa-play"></i> Nhận nhiệm vụ
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    var scanInput = document.getElementById('location-scan-input');
    if (scanInput && !scanInput.value) {
        scanInput.focus();
    }

    // Tự gửi bộ lọc khi người dùng nhấn Enter trong ô quét mã vạch
    scanInput?.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('location-form')?.submit();
        }
    });

    @if (TempData["Success"] != null)
    {
        <text>playBeep(true);</text>
    }
    @if (TempData["Error"] != null)
    {
        <text>playBeep(false);</text>
    }
});

function playBeep(success) {
    try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.value = success ? 880 : 330;
        gain.gain.value = 0.15;
        osc.start();
        osc.stop(ctx.currentTime + (success ? 0.12 : 0.35));
    } catch (e) {}
}

function scanCurrentLocation() {
    window.wmsScanner.scanToField('location-scan-input', {
        closeOnSuccess: true,
        submitForm: true
    });
}
</script>
}
