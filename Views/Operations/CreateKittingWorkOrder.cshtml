@model WMS.ViewModels.KittingWorkOrderCreatePageViewModel
@{
    ViewData["Title"] = "Tạo phiếu lắp bộ hàng";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-boxes-packing text-accent"></i> Tạo phiếu lắp bộ hàng</h1>
        <p class="page-subtitle">Chọn mã hàng bộ đã có định mức nguyên vật liệu đang hiệu lực, số lượng cần lắp và vị trí nhập thành phẩm sau khi hoàn tất.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" asp-controller="Operations" asp-action="KittingWorkOrders"><i class="fas fa-arrow-left"></i> Danh sách</a>
    </div>
</div>

<div class="enterprise-card">
    <div class="enterprise-card-header">
        <div>
            <h3 class="enterprise-card-title">Thông tin phiếu</h3>
            <p class="enterprise-card-subtitle">Vật tư thành phần sẽ được sinh từ định mức nguyên vật liệu và giữ chỗ tự động theo nguyên tắc hết hạn trước xuất trước.</p>
        </div>
    </div>
    <div class="enterprise-card-body">
        <form method="post" asp-controller="Operations" asp-action="CreateKittingWorkOrder" class="form-grid">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Kho</label>
                <select class="form-control" name="WarehouseId" id="warehouseSelect" required>
                    <option value="">Chọn kho</option>
                    @foreach (var w in Model.Warehouses)
                    {
                        <option value="@w.WarehouseId" selected="@(Model.Request.WarehouseId == w.WarehouseId)">@w.WarehouseCode - @w.WarehouseName</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Mã hàng bộ thành phẩm</label>
                <select class="form-control" name="FinishedItemId" required>
                    <option value="">Chọn mã hàng bộ</option>
                    @foreach (var item in Model.FinishedItems)
                    {
                        <option value="@item.ItemId" selected="@(Model.Request.FinishedItemId == item.ItemId)">@item.ItemCode - @item.ItemName (@item.BaseUom?.UomCode)</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Vị trí nhập thành phẩm</label>
                <select class="form-control" name="FinishedLocationId" id="finishedLocationSelect" required>
                    <option value="">Chọn vị trí</option>
                    @foreach (var loc in Model.Locations)
                    {
                        var wh = loc.Zone?.Warehouse;
                        <option value="@loc.LocationId" data-warehouse="@wh?.WarehouseId" selected="@(Model.Request.FinishedLocationId == loc.LocationId)">
                            @wh?.WarehouseCode - @loc.LocationCode
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Số lượng bộ</label>
                <input class="form-control" type="number" name="PlannedQty" value="@Model.Request.PlannedQty.ToString("0")" min="1" step="1" required />
            </div>

            <div class="form-group">
                <label class="form-label">Lô thành phẩm</label>
                <input class="form-control" name="FinishedLotNumber" value="@Model.Request.FinishedLotNumber" placeholder="Bắt buộc nếu mã hàng bộ quản lý lô" />
            </div>

            <div class="form-group">
                <label class="form-label">HSD thành phẩm</label>
                <input class="form-control" type="date" name="FinishedExpiryDate" value="@(Model.Request.FinishedExpiryDate?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="form-group form-span-2">
                <label class="form-label">Ghi chú</label>
                <textarea class="form-control" name="Notes" rows="3" placeholder="Yêu cầu dịch vụ gia tăng, chiến dịch, khách hàng...">@Model.Request.Notes</textarea>
            </div>

            <div class="form-actions form-span-2">
                <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> Tạo phiếu</button>
                <a class="btn btn-secondary" asp-controller="Operations" asp-action="KittingWorkOrders">Hủy</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const warehouseSelect = document.getElementById('warehouseSelect');
        const locationSelect = document.getElementById('finishedLocationSelect');
        const options = Array.from(locationSelect.options);

        function filterLocations() {
            const warehouseId = warehouseSelect.value;
            options.forEach(option => {
                if (!option.value) return;
                option.hidden = warehouseId && option.dataset.warehouse !== warehouseId;
            });
            const selected = locationSelect.selectedOptions[0];
            if (selected && selected.hidden) locationSelect.value = '';
        }

        warehouseSelect.addEventListener('change', filterLocations);
        filterLocations();
    });
</script>
