@model WMS.ViewModels.SlottingSimulationPageViewModel
@using WMS.Models
@{
    ViewData["Title"] = "Mô phỏng tối ưu vị trí";
    var selected = ViewBag.SelectedScenario as SlottingSimulationScenario;
    string TranslateSimStatus(SlottingSimulationStatusEnum status) => status switch {
        SlottingSimulationStatusEnum.Draft => "Bản nháp",
        SlottingSimulationStatusEnum.Approved => "Đã duyệt",
        SlottingSimulationStatusEnum.PartiallyApproved => "Duyệt 1 phần",
        SlottingSimulationStatusEnum.Failed => "Lỗi",
        SlottingSimulationStatusEnum.Cancelled => "Đã hủy",
        _ => "Không áp dụng"
    };
    string TranslateSimLineStatus(SlottingSimulationLineStatusEnum status) => status switch {
        SlottingSimulationLineStatusEnum.Draft => "Nháp",
        SlottingSimulationLineStatusEnum.TaskCreated => "Đã tạo NV",
        SlottingSimulationLineStatusEnum.Failed => "Lỗi",
        SlottingSimulationLineStatusEnum.Skipped => "Bỏ qua",
        _ => "Không áp dụng"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-flask text-accent"></i> Mô phỏng tối ưu vị trí (Tối ưu vị trí)</h1>
        <p class="page-subtitle">Mô phỏng trước/sau, phí di chuyển và tiết kiệm thời gian trước khi tạo nhiệm vụ di chuyển hàng loạt.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Operations" asp-action="Slotting" class="btn btn-secondary"><i class="fas fa-layer-group"></i> Tối ưu vị trí</a>
        <a asp-controller="Operations" asp-action="MovementTasks" class="btn btn-secondary"><i class="fas fa-list-check"></i> Nhiệm vụ di chuyển</a>
    </div>
</div>

<form method="get" class="filter-bar">
    <div class="form-group">
        <label class="form-label">Kho</label>
        <select class="form-control" name="warehouseId">
            <option value="">Chọn kho</option>
            @foreach (var w in Model.Warehouses)
            {
                <option value="@w.WarehouseId" selected="@(Model.WarehouseId == w.WarehouseId)">@w.WarehouseCode - @w.WarehouseName</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Tìm nhanh</label>
        <input class="form-control" name="search" value="@Model.Search" placeholder="Vật tư, vị trí, ABC..." />
    </div>
    <div class="form-group">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary" type="submit"><i class="fas fa-filter"></i> Xem đề xuất</button>
    </div>
</form>

<div class="enterprise-card mb-4">
    <div class="enterprise-card-header">
        <div>
            <h3 class="enterprise-card-title"><i class="fas fa-play text-success"></i> Tạo kịch bản từ đề xuất hiện tại</h3>
            <p class="enterprise-card-subtitle">Hiện có @Model.CurrentSuggestionCount đề xuất hợp lệ theo bộ lọc.</p>
        </div>
    </div>
    <div class="enterprise-card-body">
        <form method="post" asp-controller="Operations" asp-action="CreateSlottingSimulation" class="slotting-simulation-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="WarehouseId" value="@Model.WarehouseId" />
            <input type="hidden" name="Search" value="@Model.Search" />
            <div class="form-group">
                <label class="form-label">Tên kịch bản</label>
                <input class="form-control" name="ScenarioName" value="Kịch bản tối ưu @WMS.Common.VietnamTime.Now.ToString("yyyyMMdd-HHmm")" />
            </div>
            <div class="form-group">
                <label class="form-label">Số dòng tối đa</label>
                <input class="form-control" type="number" name="MaxLines" value="50" min="1" max="200" />
            </div>
            <button class="btn btn-success" type="submit" @(Model.WarehouseId.HasValue && Model.CurrentSuggestionCount > 0 ? "" : "disabled")>
                <i class="fas fa-flask"></i> Chạy mô phỏng
            </button>
        </form>
    </div>
</div>

@if (selected != null)
{
    <div class="enterprise-card mb-4">
        <div class="enterprise-card-header">
            <div>
                <h3 class="enterprise-card-title">@selected.ScenarioCode - @selected.ScenarioName</h3>
                <p class="enterprise-card-subtitle">
                    Số dòng: @selected.LineCount |
                    Tiết kiệm QĐ: @selected.TotalEstimatedTravelMinutesSaved.ToString("N2") phút |
                    Phí di chuyển: @selected.TotalMovementCostMinutes.ToString("N2") phút |
                    Thực nhận: @selected.NetEstimatedMinutesSaved.ToString("N2") phút
                </p>
            </div>
            @if (selected.Status == SlottingSimulationStatusEnum.Draft)
            {
                <form method="post" asp-controller="Operations" asp-action="ApproveSlottingSimulation" data-enterprise-confirm="Duyệt kịch bản và tạo nhiệm vụ di chuyển?" data-enterprise-confirm-ok="Duyệt kịch bản">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="scenarioId" value="@selected.ScenarioId" />
                    <button class="btn btn-primary" type="submit"><i class="fas fa-list-check"></i> Duyệt & tạo NV di chuyển</button>
                </form>
            }
            else
            {
                <span class="badge badge-info">@TranslateSimStatus(selected.Status)</span>
            }
        </div>
        <div class="enterprise-card-body">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Vật tư</th>
                            <th>Di chuyển</th>
                            <th class="text-right">SL</th>
                            <th class="text-right">Tần suất lấy/ngày</th>
                            <th class="text-right">Trước</th>
                            <th class="text-right">Sau</th>
                            <th class="text-right">Tiết kiệm QĐ</th>
                            <th class="text-right">Phí di chuyển</th>
                            <th class="text-right">Thực nhận</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var l in Model.PreviewLines)
                    {
                        <tr class="@(l.NetEstimatedMinutesSaved > 0 ? "" : "row-warning")">
                            <td>
                                <div class="fw-700">@l.Item?.ItemCode</div>
                                <div class="table-subtext-sm">Hạng @l.AbcClass | Điểm @l.SlottingScore</div>
                            </td>
                            <td>
                                <span class="td-code">@l.SourceLocation?.LocationCode</span>
                                <i class="fas fa-arrow-right inline-icon-gap"></i>
                                <span class="td-code">@l.SuggestedLocation?.LocationCode</span>
                            </td>
                            <td class="td-number">@l.PlannedMoveQty.ToString("N2")</td>
                            <td class="td-number">@l.DailyPickFrequency.ToString("N2")</td>
                            <td class="td-number">@l.BeforeTravelDistance.ToString("N2")</td>
                            <td class="td-number">@l.AfterTravelDistance.ToString("N2")</td>
                            <td class="td-number">@l.EstimatedTravelMinutesSaved.ToString("N2")</td>
                            <td class="td-number">@l.MovementCostMinutes.ToString("N2")</td>
                            <td class="td-number fw-700 @(l.NetEstimatedMinutesSaved > 0 ? "text-success" : "text-danger")">@l.NetEstimatedMinutesSaved.ToString("N2")</td>
                            <td>
                                <span class="badge @(l.Status == SlottingSimulationLineStatusEnum.TaskCreated ? "badge-success" : l.Status == SlottingSimulationLineStatusEnum.Failed ? "badge-danger" : l.Status == SlottingSimulationLineStatusEnum.Skipped ? "badge-warning" : "badge-secondary")">@TranslateSimLineStatus(l.Status)</span>
                                @if (l.MovementTask != null)
                                {
                                    <div class="table-subtext-sm">@l.MovementTask.TaskCode</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(l.ErrorMessage))
                                {
                                    <div class="table-subtext-sm text-danger">@l.ErrorMessage</div>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="enterprise-card">
    <div class="enterprise-card-header">
        <div>
            <h3 class="enterprise-card-title"><i class="fas fa-clock-rotate-left"></i> Lịch sử kịch bản</h3>
        </div>
    </div>
    <div class="enterprise-card-body">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Kịch bản</th>
                        <th>Kho</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Số dòng</th>
                        <th class="text-right">NV</th>
                        <th class="text-right">Tiết kiệm thực</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Scenarios.Any())
                {
                    <tr><td colspan="8" class="cell-empty cell-empty-sm">Chưa có kịch bản mô phỏng nào.</td></tr>
                }
                @foreach (var s in Model.Scenarios)
                {
                    <tr>
                        <td>
                            <div class="fw-700">@s.ScenarioCode</div>
                            <div class="table-subtext-sm">@s.ScenarioName</div>
                        </td>
                        <td>@s.Warehouse?.WarehouseName</td>
                        <td><span class="badge badge-info">@TranslateSimStatus(s.Status)</span></td>
                        <td class="td-number">@s.LineCount</td>
                        <td class="td-number">@s.ApprovedTaskCount</td>
                        <td class="td-number">@s.NetEstimatedMinutesSaved.ToString("N2") phút</td>
                        <td>@s.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><a class="btn btn-sm btn-secondary" asp-controller="Operations" asp-action="SlottingSimulation" asp-route-warehouseId="@s.WarehouseId" asp-route-scenarioId="@s.ScenarioId"><i class="fas fa-eye"></i> Xem</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
