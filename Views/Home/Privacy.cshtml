@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chính sách bảo mật</h1>
        <p class="page-subtitle">Các nguyên tắc bảo vệ dữ liệu vận hành, tài khoản và lịch sử thao tác trong hệ thống quản lý kho.</p>
    </div>
</div>

<div class="enterprise-form-layout">
    <section class="card enterprise-form-card">
        <div class="card-header"><span class="card-title">Nguyên tắc bảo vệ dữ liệu</span></div>
        <div class="card-body">
            <ol class="audit-checklist">
                <li>Người dùng chỉ được truy cập đúng vai trò, kho, khu vực và chủ hàng được phân công.</li>
                <li>Mọi thao tác quan trọng được ghi nhận bằng nhật ký hệ thống hoặc sổ giao dịch nghiệp vụ tương ứng.</li>
                <li>Không chia sẻ tài khoản cá nhân; khi nhân sự nghỉ hoặc đổi bộ phận cần khóa tài khoản ngay.</li>
                <li>Dữ liệu vận hành thật không được xuất ra ngoài nếu chưa có phê duyệt của quản lý.</li>
            </ol>
        </div>
    </section>

    <aside class="enterprise-form-aside">
        <div class="card">
            <div class="card-header"><span class="card-title">Liên hệ hỗ trợ</span></div>
            <div class="card-body">
                <p class="text-muted">Khi phát hiện truy cập bất thường hoặc dữ liệu sai lệch, hãy báo ngay cho quản trị viên hệ thống hoặc quản lý kho.</p>
            </div>
        </div>
    </aside>
</div>
