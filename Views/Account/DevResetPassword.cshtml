@{
    ViewData["Title"] = "Đặt lại mật khẩu môi trường thử nghiệm";
    Layout = "_Layout";
}

<div class="login-page enterprise-auth-page">
    <div class="enterprise-auth-stage">
        <section class="enterprise-auth-visual" aria-label="Công cụ thử nghiệm WMS Pro">
            <div class="enterprise-auth-brand-signal">
                <img src="~/images/logo-full.svg" asp-append-version="true" alt="WMS - Quản lý kho nội bộ" class="enterprise-auth-lockup" />
                <p>Chỉ dùng cho môi trường trình diễn hoặc phát triển khi đã có mã nội bộ.</p>
            </div>

            <div class="enterprise-auth-status">
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot warning"></span><span>Không dùng cho môi trường vận hành thật</span></div>
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot"></span><span>Yêu cầu mã đặt lại nội bộ</span></div>
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot success"></span><span>Mật khẩu mới vẫn phải đáp ứng chính sách mạnh</span></div>
            </div>
        </section>

        <section class="enterprise-auth-panel auth-card" aria-labelledby="devResetTitle">
            <div class="login-logo">
                <div class="logo-icon"><img src="~/images/logo.svg" asp-append-version="true" alt="Biểu trưng WMS Pro" class="brand-mark-img" /></div>
                <h1 id="devResetTitle">Đặt lại mật khẩu thử nghiệm</h1>
                <p>Chỉ dùng trong môi trường trình diễn hoặc phát triển</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
            }

            <form method="post" asp-action="DevResetPassword" class="enterprise-auth-form">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Mã đặt lại nội bộ</label>
                    <input type="password" name="token" class="form-control" autocomplete="off" required placeholder="Mã bí mật trong cấu hình người phát triển" />
                </div>
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <input type="text" name="userName" class="form-control" autocomplete="username" required placeholder="Ví dụ: quantri@congty.vn" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mật khẩu mới</label>
                    <input type="password" name="newPassword" class="form-control" autocomplete="new-password" required placeholder="8+ ký tự, HOA/thường/số/ký tự đặc biệt" />
                </div>
                <button type="submit" class="btn btn-danger btn-lg full-width-action mt-8 enterprise-auth-submit">
                    <i class="fas fa-key"></i> Đặt lại mật khẩu
                </button>
            </form>
        </section>
    </div>
</div>
