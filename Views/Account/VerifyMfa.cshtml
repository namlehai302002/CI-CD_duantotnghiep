@model VerifyMfaViewModel
@{ ViewData["Title"] = "Xác thực mã bảo mật"; Layout = "_Layout"; }

<div class="login-page enterprise-auth-page">
    <div class="enterprise-auth-stage">
        <section class="enterprise-auth-visual" aria-label="Trạng thái xác thực WMS Pro">
            <div class="enterprise-auth-brand-signal">
                <img src="~/images/logo-full.svg" asp-append-version="true" alt="WMS - Quản lý kho nội bộ" class="enterprise-auth-lockup" />
                <p>Lớp kiểm tra bổ sung giúp bảo vệ thao tác tồn kho, phiếu và dữ liệu khách hàng.</p>
            </div>

            <div class="enterprise-auth-grid compact" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span>
            </div>

            <div class="enterprise-auth-status">
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot warning"></span><span>Mã xác thực có thời hạn ngắn</span></div>
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot success"></span><span>Thiết bị tin cậy được kiểm tra theo vai trò</span></div>
                <div class="enterprise-auth-status-row"><span class="enterprise-auth-status-dot"></span><span>Lưu nhật ký IP, thiết bị và kết quả đăng nhập</span></div>
            </div>
        </section>

        <section class="enterprise-auth-panel login-card" aria-labelledby="mfaTitle">
            <div class="login-logo">
                <div class="logo-icon"><img src="~/images/logo.svg" asp-append-version="true" alt="Biểu trưng WMS Pro" class="brand-mark-img" /></div>
                <h1 id="mfaTitle">Xác thực mã bảo mật</h1>
                <p>Bảo vệ tài khoản quản trị</p>
            </div>

            <div class="user-guide mb-12">
                <div class="user-guide-text">Đã gửi mã xác thực đến: <strong>@Model.MaskedEmail</strong></div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage</div>
            }

            <form method="post" asp-action="VerifyMfa" class="enterprise-auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ChallengeId" value="@Model.ChallengeId" />
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <div class="form-group">
                    <label class="form-label">Tài khoản</label>
                    <input type="text" class="form-control" value="@Model.UserName" autocomplete="username" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label">Mã xác thực (6 số)</label>
                    <input type="text" name="CaptchaCode" maxlength="6" inputmode="numeric" autocomplete="one-time-code" class="form-control" placeholder="Nhập mã xác thực 6 số" required autofocus />
                </div>
                <button type="submit" class="btn btn-primary btn-lg full-width-action mt-8 enterprise-auth-submit">
                    <i class="fas fa-shield-alt"></i> Xác thực đăng nhập
                </button>
            </form>
        </section>
    </div>
</div>
