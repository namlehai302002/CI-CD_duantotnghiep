@model List<WMS.Models.Voucher>
@{
    ViewData["Title"] = "Danh sách phiếu";
    var inboundStatus = (WMS.Models.InboundStatusEnum?)ViewBag.InboundStatus;
    var inboundStatusValue = inboundStatus.HasValue ? ((byte)inboundStatus.Value).ToString() : "";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Phiếu kho</h1>
        <p class="page-subtitle">Quản lý giao dịch nhập, xuất, điều chỉnh và chuyển kho.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Vouchers" asp-action="Create" asp-route-type="1" class="btn btn-primary"><i class="fas fa-plus"></i> Nhập kho</a>
        <a asp-controller="Vouchers" asp-action="Create" asp-route-type="2" class="btn btn-secondary"><i class="fas fa-minus"></i> Xuất kho</a>
        <a asp-controller="Vouchers" asp-action="Create" asp-route-type="6" class="btn btn-secondary"><i class="fas fa-exchange-alt"></i> Chuyển kho</a>
    </div>
</div>

<div class="user-guide">
    <div class="user-guide-title"><i class="fas fa-circle-info"></i> Dành cho nhân viên kho</div>
    <div class="user-guide-text">Tạo phiếu theo đúng nghiệp vụ đang làm: nhập hàng, xuất nội bộ hoặc chuyển kho. Bấm vào mã phiếu để xem chi tiết.</div>
</div>

<form method="get" class="filter-bar">
    <div class="form-group">
        <label class="form-label">Tìm nhanh</label>
        <input type="text" name="search" class="form-control" placeholder="Nhập mã phiếu, mã lịch nhận hàng, xe hoặc ghi chú..." value="@ViewBag.Search" />
    </div>
    <div class="form-group">
        <label class="form-label">Loại phiếu</label>
        <select name="type" class="form-control">
            <option value="">Tất cả</option>
            <option value="1" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 1)">Nhập kho</option>
            <option value="2" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 2)">Xuất kho nội bộ</option>
            <option value="3" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 3)">Trả nhà cung cấp</option>
            <option value="4" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 4)">Khách trả hàng</option>
            <option value="5" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 5)">Điều chỉnh kho</option>
            <option value="6" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 6)">Chuyển kho</option>
            <option value="7" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 7)">Nhập thành phẩm (từ SX)</option>
            <option value="8" selected="@(ViewBag.Type != null && (byte)ViewBag.Type == 8)">Xuất sản xuất</option>
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Trạng thái nhập</label>
        <select name="inboundStatus" class="form-control">
            <option value="">Tất cả</option>
            <option value="1" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.Draft)">Nháp</option>
            <option value="2" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.PendingApproval)">Chờ duyệt</option>
            <option value="3" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.Approved)">Đã duyệt</option>
            <option value="4" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.Receiving)">Đang nhận</option>
            <option value="5" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.Completed)">Hoàn tất</option>
            <option value="6" selected="@(inboundStatus == WMS.Models.InboundStatusEnum.Rejected)">Từ chối</option>
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Từ ngày</label>
        <input type="date" name="dateFrom" class="form-control" value="@(ViewBag.DateFrom != null ? ((DateTime)ViewBag.DateFrom).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="form-group">
        <label class="form-label">Đến ngày</label>
        <input type="date" name="dateTo" class="form-control" value="@(ViewBag.DateTo != null ? ((DateTime)ViewBag.DateTo).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="form-group">
        <label class="form-label">&nbsp;</label>
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm dữ liệu</button>
    </div>
</form>

<div class="table-actions enterprise-table-tools">
    <div class="pagination-info">
        @if (ViewBag.TotalCount > 0)
        {
            <span>Hiển thị @(((ViewBag.Page - 1) * ViewBag.PageSize) + 1)-@Math.Min(ViewBag.Page * ViewBag.PageSize, ViewBag.TotalCount) trong @ViewBag.TotalCount phiếu</span>
        }
    </div>
    <div class="tool-group">
        <input type="text" id="voucherClientSearch" class="form-control max-w-320" placeholder="Lọc nhanh trên bảng hiện tại..." />
        <button class="btn-export" data-wms-export-table="#voucherTable" data-wms-export-filename="phieu_kho"><i class="fas fa-file-excel"></i> Xuất Excel</button>
    </div>
</div>

<div class="table-container">
    <table id="voucherTable">
        <thead>
            <tr>
                <th class="sortable">Mã phiếu</th><th class="sortable">Ngày lập</th><th>Loại</th><th>Kho nhập/xuất</th>
                <th>Đối tác</th><th class="sortable cell-right">Số mặt hàng</th><th>Trạng thái</th><th>Người lập</th><th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="10" class="cell-compact"><div class="empty-state"><div class="empty-icon"><i class="fas fa-file-invoice"></i></div><div class="empty-text">Chưa có phiếu nào</div><div class="empty-sub">Tạo phiếu nhập/xuất mới hoặc thay đổi bộ lọc</div><div class="empty-action"><a asp-controller="Vouchers" asp-action="Create" asp-route-type="1" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Tạo phiếu</a></div></div></td></tr>
            }
            @foreach (var v in Model)
            {
                <tr>
                    <td>
                        <a asp-controller="Vouchers" asp-action="Details" asp-route-id="@v.VoucherId" class="td-code link-clean">@v.VoucherCode</a>
                        @if (!string.IsNullOrWhiteSpace(v.AsnCode))
                        {
                            <div class="text-muted font-mono fs-xs mt-1">Mã lịch nhận hàng: @v.AsnCode</div>
                        }
                    </td>
                    <td>@v.VoucherDate.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge badge-info">@v.VoucherTypeName</span></td>
                    <td>@v.Warehouse?.WarehouseName @(v.DestWarehouseId.HasValue ? $" ➡️ {v.DestWarehouse?.WarehouseName}" : "")</td>
                    <td>@(v.Partner?.PartnerName ?? "---")</td>
                    <td class="td-number">@v.TotalLines</td>
                    <td><span class="badge @v.StatusBadgeClass">@v.StatusDisplay</span>
                        @if (v.IsOverdue)
                        {
                            <span class="badge badge-danger ms-1" title="Đã trễ hạn giao hàng"><i class="fas fa-clock"></i> Trễ</span>
                        }
                        @if (v.IsInboundFlow && v.InboundStatus == WMS.Models.InboundStatusEnum.PendingApproval)
                        {
                            <span class="badge badge-info ms-1" title="Cần người duyệt xử lý"><i class="fas fa-bell"></i></span>
                        }
                    </td>
                    <td>@v.CreatedBy</td>
                    <td class="td-actions">
                        <a asp-controller="Vouchers" asp-action="Details" asp-route-id="@v.VoucherId" class="btn btn-sm btn-secondary" title="Chi tiết"><i class="fas fa-eye"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="table-pagination" id="voucherPager">
    @if (ViewBag.TotalPages > 1)
    {
        var startPage = Math.Max(1, (int)ViewBag.Page - 2);
        var endPage = Math.Min((int)ViewBag.TotalPages, startPage + 4);
        if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);

        <a href="?page=1&type=@((int?)ViewBag.Type)&inboundStatus=@inboundStatusValue&dateFrom=@(((DateTime?)ViewBag.DateFrom)?.ToString("yyyy-MM-dd"))&dateTo=@(((DateTime?)ViewBag.DateTo)?.ToString("yyyy-MM-dd"))&search=@ViewBag.Search&pageSize=@ViewBag.PageSize"
           class="btn btn-sm btn-secondary @(ViewBag.Page.Equals(1) ? "disabled" : "")" title="Trang đầu">
            <i class="fas fa-angle-double-left"></i>
        </a>
        <a href="?page=@((int)ViewBag.Page - 1)&type=@((int?)ViewBag.Type)&inboundStatus=@inboundStatusValue&dateFrom=@(((DateTime?)ViewBag.DateFrom)?.ToString("yyyy-MM-dd"))&dateTo=@(((DateTime?)ViewBag.DateTo)?.ToString("yyyy-MM-dd"))&search=@ViewBag.Search&pageSize=@ViewBag.PageSize"
           class="btn btn-sm btn-secondary @(ViewBag.Page.Equals(1) ? "disabled" : "")" title="Trang trước">
            <i class="fas fa-chevron-left"></i>
        </a>

        @for (int p = startPage; p <= endPage; p++)
        {
            <a href="?page=@p&type=@((int?)ViewBag.Type)&inboundStatus=@inboundStatusValue&dateFrom=@(((DateTime?)ViewBag.DateFrom)?.ToString("yyyy-MM-dd"))&dateTo=@(((DateTime?)ViewBag.DateTo)?.ToString("yyyy-MM-dd"))&search=@ViewBag.Search&pageSize=@ViewBag.PageSize"
               class="btn btn-sm @(p == (int)ViewBag.Page ? "btn-primary" : "btn-secondary")">@p</a>
        }

        <a href="?page=@((int)ViewBag.Page + 1)&type=@((int?)ViewBag.Type)&inboundStatus=@inboundStatusValue&dateFrom=@(((DateTime?)ViewBag.DateFrom)?.ToString("yyyy-MM-dd"))&dateTo=@(((DateTime?)ViewBag.DateTo)?.ToString("yyyy-MM-dd"))&search=@ViewBag.Search&pageSize=@ViewBag.PageSize"
           class="btn btn-sm btn-secondary @(ViewBag.Page.Equals(ViewBag.TotalPages) ? "disabled" : "")" title="Trang sau">
            <i class="fas fa-chevron-right"></i>
        </a>
        <a href="?page=@ViewBag.TotalPages&type=@((int?)ViewBag.Type)&inboundStatus=@inboundStatusValue&dateFrom=@(((DateTime?)ViewBag.DateFrom)?.ToString("yyyy-MM-dd"))&dateTo=@(((DateTime?)ViewBag.DateTo)?.ToString("yyyy-MM-dd"))&search=@ViewBag.Search&pageSize=@ViewBag.PageSize"
           class="btn btn-sm btn-secondary @(ViewBag.Page.Equals(ViewBag.TotalPages) ? "disabled" : "")" title="Trang cuối">
            <i class="fas fa-angle-double-right"></i>
        </a>
    }
</div>

@section Scripts {
@* Only enable client-side search when total records < 500 (performance) *@
@if (ViewBag.TotalCount < 500)
{
<script>
(() => {
    const table = document.getElementById('voucherTable');
    const pager = document.getElementById('voucherPager');
    const search = document.getElementById('voucherClientSearch');
    if (!table || !pager || !search) return;
    const rows = Array.from(table.querySelectorAll('tbody tr')).filter(r => r.querySelectorAll('td').length > 1);
    const pageSize = 12;
    let currentPage = 1;
    let filtered = rows;

    function render() {
        const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        rows.forEach(r => r.style.display = 'none');
        filtered.slice((currentPage - 1) * pageSize, currentPage * pageSize).forEach(r => r.style.display = '');
        let emptyRow = table.querySelector('tbody tr.client-empty-row');
        if (!emptyRow) {
            emptyRow = document.createElement('tr');
            emptyRow.className = 'client-empty-row';
            emptyRow.innerHTML = '<td colspan="9" class="cell-empty cell-empty-md">Không tìm thấy phiếu phù hợp trên bảng hiện tại.</td>';
            table.querySelector('tbody').appendChild(emptyRow);
        }
        emptyRow.style.display = filtered.length === 0 ? '' : 'none';
        pager.innerHTML = '';
        const prev = document.createElement('button');
        prev.className = 'btn btn-sm btn-secondary';
        prev.textContent = 'Trước';
        prev.disabled = currentPage === 1;
        prev.addEventListener('click', () => { currentPage--; render(); });
        const next = document.createElement('button');
        next.className = 'btn btn-sm btn-secondary';
        next.textContent = 'Sau';
        next.disabled = currentPage === totalPages;
        next.addEventListener('click', () => { currentPage++; render(); });
        const info = document.createElement('span');
        info.className = 'step-chip';
        info.textContent = `Trang ${currentPage}/${totalPages} (lọc ${filtered.length}/${rows.length})`;
        pager.append(prev, info, next);
    }

    search.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        filtered = rows.filter(r => r.innerText.toLowerCase().includes(q));
        currentPage = 1;
        render();
    });

    render();
})();
</script>
}
}
