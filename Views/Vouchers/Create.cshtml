                        <div class="loc-suggest-modal">
                            <div class="loc-suggest-header">
                                <div>
                                    <h5 class="loc-suggest-title">📦 Vị Trí Chứa Vật Tư</h5>
                                    <p class="loc-suggest-sub">${escapeDocumentText(itemName)}</p>
                                </div>
                                <button type="button" class="loc-suggest-close" data-wms-close-modal="locationSuggestionModal">&times;</button>
                            </div>
                            <div class="loc-suggest-body">
                                <table class="loc-suggest-table">
                                    <thead><tr>
                                        <th>Ô vị trí</th>
                                        <th>Khu</th>
                                        <th>Tồn kho</th>
                                        <th>HSD (FEFO)</th>
                                        <th class="loc-suggest-center">Chọn</th>
                                    </tr></thead>
                                    <tbody>${tableRows}</tbody>
                                </table>
                            </div>
                            <div class="loc-suggest-footer">
                                <button type="button" class="btn btn-sm btn-secondary" data-wms-close-modal="locationSuggestionModal">Đóng</button>
                            </div>
                        </div>
                    `;
                    modal.innerHTML = contentHtml;
                    window.enhanceDataWidths?.();
                } else {
                    // NHẬP KHO: hiện ô còn trống / sức chứa
                    if (data && data.length > 0) {
                        data.forEach(loc => {
                            if (loc.hasOtherItem) return;
                            const locId = safeLocationId(loc.locationId);
                            const locCodeText = escapeDocumentText(loc.locationCode);
                            const locCodeArg = suggestionArg(loc.locationCode);
                            const zoneText = escapeDocumentText(loc.zoneName);
                            const availableText = formatVnNumber(loc.available);
                            const fillPercent = safePercent(loc.fillPercent);
                            const isSelected = String(loc.locationId ?? '') === currentLocId;
                            const fillClass = fillPercent <= 70 ? 'loc-suggest-fill-ok' : fillPercent <= 90 ? 'loc-suggest-fill-warn' : 'loc-suggest-fill-danger';
                            const starIcon = loc.hasSameItem ? '<span title="Đã chứa cùng vật tư" class="loc-suggest-same-item">⭐</span> ' : '';
                            tableRows += `<tr class="loc-suggest-row ${isSelected ? 'is-selected' : ''}">
                                <td>${starIcon}${locCodeText}</td>
                                <td>${zoneText}</td>
                                <td>${availableText}</td>
                                <td><div class="loc-suggest-fill"><div class="loc-suggest-fill-track"><div class="loc-suggest-fill-bar ${fillClass}" data-progress-width="${fillPercent}%"></div></div><span class="loc-suggest-fill-text">${fillPercent}%</span></div></td>
                                <td class="loc-suggest-center"><button type="button" class="btn btn-sm btn-outline-primary" data-wms-call="selectSuggestedLocation" data-wms-arg="${locId}" data-wms-arg2="${locCodeText}"><i class="fas fa-check"></i> Chọn</button></td>
                            </tr>`;
