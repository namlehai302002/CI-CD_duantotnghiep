    function normalizeInputDate(value) {
        if (!value) return '';
        const text = String(value).trim();
        if (!text) return '';
        if (/^\d{4}-\d{2}-\d{2}/.test(text)) return text.substring(0, 10);
        const parsed = new Date(text);
        if (Number.isNaN(parsed.getTime())) return '';
        return new Intl.DateTimeFormat('en-CA', {
            timeZone: 'Asia/Ho_Chi_Minh',
            year: 'numeric',
            month: '2-digit',
            day: '2-digit'
        }).format(parsed);
    }

    function escapeDocumentText(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function suggestionArg(value) {
        return escapeDocumentText(JSON.stringify(String(value ?? '')));
    }

    function safeLocationId(value) {
        const id = Number.parseInt(value, 10);
        return Number.isFinite(id) && id > 0 ? id : 0;
    }

    function safePercent(value) {
        const percent = Number(value);
        if (!Number.isFinite(percent)) return 0;
        return Math.max(0, Math.min(100, Math.round(percent)));
    }

    function formatVnNumber(value) {
        const number = Number(value);
        return Number.isFinite(number) ? number.toLocaleString('vi-VN') : '0';
    }

    function isReadyDocumentLine(item) {
        const matched = item.IsMatched ?? item.isMatched ?? !!(item.ItemId ?? item.itemId);
        const review = item.RequiresReview ?? item.requiresReview ?? false;
        return matched && !review && !!(item.ItemId ?? item.itemId);
    }

    function mergeReadyDocumentLines(items) {
        const map = new Map();
        for (const item of items) {
            const itemId = item.ItemId ?? item.itemId ?? 0;
            const unitPrice = item.UnitPrice ?? item.unitPrice ?? 0;
            const lotNumber = item.LotNumber ?? item.lotNumber ?? '';
            const expiryDate = normalizeInputDate(item.ExpiryDate ?? item.expiryDate);
            const key = `${itemId}__${unitPrice}__${lotNumber}__${expiryDate}`;
            const quantity = item.Quantity ?? item.quantity ?? 1;
            const existing = map.get(key);
            if (!existing) {
                map.set(key, { ...item, Quantity: quantity });
            } else {
                existing.Quantity = (existing.Quantity || 0) + quantity;
            }
        }
        return Array.from(map.values());
    }

    function buildDocumentPreviewHtml(lines, warnings, confidence, parseStatus) {
        const readyLines = lines.filter(isReadyDocumentLine);
        const reviewLines = lines.filter(line => !isReadyDocumentLine(line));
        const visibleLines = lines.slice(0, 12);
        const lineRows = visibleLines.map(line => {
            const ready = isReadyDocumentLine(line);
            const code = line.ItemCode ?? line.itemCode ?? line.SuggestedItemCode ?? line.suggestedItemCode ?? '';
            const name = line.ItemName ?? line.itemName ?? line.SuggestedItemName ?? line.suggestedItemName ?? '';
            const quantity = line.Quantity ?? line.quantity ?? '';
            const unit = line.UnitName ?? line.unitName ?? '';
            const lot = line.LotNumber ?? line.lotNumber ?? '';
            const status = ready ? 'Đã khớp' : 'Cần chọn vật tư';
            const badgeClass = ready ? 'ready' : 'review';
            const lineWarnings = line.Warnings ?? line.warnings ?? [];
            return `
                <tr>
                    <td>${escapeDocumentText(code)}</td>
                    <td>${escapeDocumentText(name)}</td>
                    <td>${escapeDocumentText(quantity)}</td>
                    <td>${escapeDocumentText(unit)}</td>
                    <td>${escapeDocumentText(lot)}</td>
                    <td><span class="doc-status-badge ${badgeClass}">${status}</span>${lineWarnings.length ? `<div class="doc-preview-line-warning">${escapeDocumentText(lineWarnings[0])}</div>` : ''}</td>
                </tr>`;
        }).join('');

        const warningHtml = warnings.length
            ? `<div class="doc-preview-warning">
                    ${warnings.slice(0, 6).map(w => `<div>• ${escapeDocumentText(w)}</div>`).join('')}
                    ${warnings.length > 6 ? `<div>• Còn ${warnings.length - 6} cảnh báo khác...</div>` : ''}
               </div>`
            : '';

        return `
            <div class="doc-preview-body">
                <div class="doc-preview-chip-row">
                    <span class="doc-preview-chip doc-preview-chip-status">Trạng thái: ${escapeDocumentText(parseStatus || 'Partial')}</span>
                    <span class="doc-preview-chip doc-preview-chip-ready">Đã khớp: ${readyLines.length}</span>
                    <span class="doc-preview-chip doc-preview-chip-review">Cần kiểm tra: ${reviewLines.length}</span>
                    <span class="doc-preview-chip doc-preview-chip-confidence">Độ tin cậy: ${Math.round((confidence || 0) * 100)}%</span>
                </div>
                <div class="doc-preview-table-wrap">
                    <table class="doc-preview-table">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Tên vật tư</th>
                                <th>SL</th>
                                <th>ĐVT</th>
                                <th>Số lô</th>
                                <th>Kết quả</th>
                            </tr>
                        </thead>
                        <tbody>${lineRows || '<tr><td colspan="6" class="doc-preview-empty">Chưa có dòng nào đủ rõ để đề xuất.</td></tr>'}</tbody>
                    </table>
                </div>
                ${lines.length > visibleLines.length ? `<div class="doc-preview-more">Đang hiển thị ${visibleLines.length}/${lines.length} dòng đầu tiên.</div>` : ''}
                ${warningHtml}
                <div class="doc-preview-note">Hệ thống chỉ áp dụng các dòng đã khớp chắc chắn. Dòng còn cảnh báo cần chọn vật tư thủ công trên phiếu.</div>
            </div>`;
    }

    async function applyMappedItemsToLines(items) {
        if (!items || items.length === 0) return { newItemNames: [], matchedCount: 0 };

        // Destroy Select2 BEFORE processing to avoid DOM conflicts
        if (typeof $ !== 'undefined') {
            $('.item-select, .source-uom-select').each(function() {
                if ($(this).hasClass('select2-hidden-accessible')) {
                    $(this).select2('destroy');
                }
            });
        }

        const tbody = document.getElementById('linesContainer');
        let firstRow = tbody.querySelector('.line-row');
        let isFirstBlank = firstRow && firstRow.querySelector('.item-select').value === "";
        let newItemNames = [];
        let matchedCount = 0;

        items.forEach((item, index) => {
            let targetRow = null;
            if (index === 0 && isFirstBlank) {
                targetRow = firstRow;
            } else {
                const newRow = document.querySelector('.line-row').cloneNode(true);
                newRow.querySelectorAll('[name]').forEach(el => {
                    el.name = el.name.replace(/\[\d+\]/, `[${lineIdx}]`);
                    if (el.tagName === 'INPUT') {
                        if (el.className.includes('loc-input')) el.value = '';
                        else if (el.type === 'hidden') { /* keep */ }
                        else el.value = '';
                    } else if (el.tagName === 'SELECT') {
                        if (el.className.includes('item-select')) el.value = '';
                        if (el.className.includes('source-uom-select')) el.value = '';
                        if (el.className.includes('loc-select')) el.value = '';
                    }
                });
                const destUom = newRow.querySelector('.dest-uom-select');
                if (destUom) destUom.value = '';
                const destQty = newRow.querySelector('.dest-qty-input');
                if (destQty) destQty.value = '';
                const sourceUomSelect = newRow.querySelector('.source-uom-select');
                if (sourceUomSelect) {
                    resetSourceUomOptions(sourceUomSelect);
                }
                tbody.appendChild(newRow);
                lineIdx++;
                targetRow = newRow;
            }

            const select = targetRow.querySelector('.item-select');
            const itemId = item.ItemId ?? item.itemId;
            const itemCode = item.ItemCode ?? item.itemCode ?? '';
            const itemName = item.ItemName ?? item.itemName ?? '';
            const baseUomId = item.BaseUomId ?? item.baseUomId ?? '';
            let matched = Array.from(select.options).find(o => o.value == itemId);
            if (!matched) {
                const newText = `[${itemCode}] ${itemName}`;
                document.querySelectorAll('.item-select').forEach(sel => {
                    const opt = new Option(newText, itemId);
                    opt.dataset.uom = baseUomId || '';
                    opt.dataset.cost = canSeeFinancialJs ? (item.UnitPrice ?? item.unitPrice ?? 0) : 0;
                    sel.add(opt);
                });
            }

            select.value = itemId;
            itemChanged(select);

            if (item.IsNew) newItemNames.push(`[${itemCode}] ${itemName}`);
            else matchedCount++;

            const qtyVal = (item.Quantity ?? item.quantity ?? 1);
            targetRow.querySelector('input[name$=".TransactionQty"]').value = formatWithCommas(qtyVal.toString());

            const unitPriceVal = canSeeFinancialJs ? (item.UnitPrice ?? item.unitPrice ?? 0) : 0;
            if (unitPriceVal) targetRow.querySelector('.cost-input').value = formatWithCommas(unitPriceVal.toString());

            if (item.LocationId) {
                const locSel = targetRow.querySelector('.loc-select');
                if (locSel) locSel.value = item.LocationId;
            }
            if (item.DefectQty != null) {
                const defectInput = targetRow.querySelector('input[name$=".DefectQty"]');
                if (defectInput) defectInput.value = formatWithCommas((item.DefectQty || 0).toString());
            }

            if (item.LotNumber != null || item.lotNumber != null) {
                const lotVal = (item.LotNumber ?? item.lotNumber ?? '').toString();
                const lotInput = targetRow.querySelector('input[name$=".LotNumber"]');
                if (lotInput) lotInput.value = lotVal;
            }

            const manufacturingDate = normalizeInputDate(item.ManufacturingDate ?? item.manufacturingDate);
            if (manufacturingDate) {
                const mfgInput = targetRow.querySelector('.mfg-date-input');
                if (mfgInput) mfgInput.value = manufacturingDate;
            }

            const expiryDate = normalizeInputDate(item.ExpiryDate ?? item.expiryDate);
            if (expiryDate) {
                const expInput = targetRow.querySelector('.exp-date-input');
                if (expInput) expInput.value = expiryDate;
            }
        });

        if (typeof initSelect2 === 'function') initSelect2();
        refreshLineNumbers();
        return { newItemNames, matchedCount };
    }

    document.getElementById('excelFileInput')?.addEventListener('change', async function() {
        const file = this.files?.[0];
        if (!file) return;

        const btn = document.getElementById('importExcelBtn');
        const busy = window.wmsLoading?.begin(btn, { text: 'Đang nhập Excel...', delay: 700 });

        const formData = new FormData();
        formData.append('file', file);

        try {
            const token = document.querySelector('#voucherForm input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/Vouchers/ImportLinesExcel', {
                method: 'POST',
                headers: token ? { 'RequestVerificationToken': token } : {},
                body: formData
            });

            const raw = await response.text();
            let res = null;
            try { res = raw ? JSON.parse(raw) : null; } catch (e) {}
            if (!response.ok) {
                Swal.fire('Lỗi nhập Excel', res?.error || res?.title || raw || ('HTTP ' + response.status), 'error');
                return;
            }
            if (!res) {
                Swal.fire('Lỗi nhập Excel', 'Máy chủ không trả về dữ liệu hợp lệ.', 'error');
                return;
            }
            let items = [];
            try { items = JSON.parse(res.data); } catch (e) {}
            if (!items || items.length === 0) {
                Swal.fire('Không có dữ liệu', 'File Excel không có dòng hợp lệ.', 'warning');
                return;
            }

            const summary = await applyMappedItemsToLines(items);
            const msg = `Đã nhập ${items.length} dòng từ Excel!\n✅ Khớp vật tư: ${summary.matchedCount}\n🆕 Tạo mới: ${summary.newItemNames.length}`;
            Swal.fire({
                title: 'Nhập Excel thành công!',
                html: `<div class="swal-preline-body">${msg}</div>`,
                icon: 'success',
                confirmButtonColor: '#10b981'
            });
        } catch (e) {
            Swal.fire('Lỗi nhập dữ liệu', 'Đã xảy ra lỗi: ' + e, 'error');
        } finally {
            window.wmsLoading?.end(busy);
            this.value = '';
        }
    });

    document.getElementById('documentFileInput')?.addEventListener('change', async function() {
        const files = Array.from(this.files || []);
        if (!files.length) return;

        const btn = document.getElementById('uploadDocumentBtn');
        const busy = window.wmsLoading?.begin(btn, { text: `Đang đọc ${files.length} chứng từ...`, delay: 700 });

        const token = document.querySelector('#voucherForm input[name="__RequestVerificationToken"]')?.value;
        const allItems = [];
        const allWarnings = [];
        const readResults = [];

        try {
            Swal.fire({
                title: 'Đang đọc chứng từ...',
                html: `0/${files.length} chứng từ`,
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            for (let i = 0; i < files.length; i++) {
                Swal.update({ html: `${i + 1}/${files.length} chứng từ` });
                const formData = new FormData();
                formData.append('file', files[i]);
                const response = await fetch('/Vouchers/AnalyzeReceipt', {
                    method: 'POST',
                    headers: token ? { 'RequestVerificationToken': token } : {},
                    body: formData
                });
                const raw = await response.text();
                let res = null;
                try { res = raw ? JSON.parse(raw) : null; } catch (e) {}
                if (!response.ok) throw new Error(res?.error || res?.title || raw || ('HTTP ' + response.status));
                if (!res) throw new Error('Máy chủ không trả về dữ liệu đọc chứng từ hợp lệ.');
                let items = [];
                try { items = JSON.parse(res.data); } catch (e) { console.error('[Đọc chứng từ] Lỗi parse dữ liệu đã phân tích.', e); }
                const warnings = Array.isArray(res.warnings) ? res.warnings : [];
                allWarnings.push(...warnings.map(w => `${files[i].name}: ${w}`));
                readResults.push({
                    fileName: files[i].name,
                    provider: res.provider || 'MinerU',
                    confidence: Number(res.confidence || 0),
                    parseStatus: res.parseStatus || 'Partial'
                });
                if (items && items.length) {
                    allItems.push(...items.map(item => ({ ...item, SourceFileName: files[i].name })));
                }
            }

            Swal.close();

            if (allItems.length === 0) {
                const warningText = allWarnings.length ? `<br><br>${allWarnings.slice(0, 5).map(escapeDocumentText).join('<br>')}` : '';
                Swal.fire('Chưa có dòng đề xuất', `Không nhận diện được dòng vật tư đủ rõ từ chứng từ.${warningText}`, 'warning');
                return;
            }

            const readyItems = allItems.filter(isReadyDocumentLine);
            const mergedReadyItems = mergeReadyDocumentLines(readyItems);
            const averageConfidence = readResults.length
                ? readResults.reduce((sum, result) => sum + result.confidence, 0) / readResults.length
                : 0;
            const status = readResults.every(result => result.parseStatus === 'Success')
                ? 'Success'
                : (readyItems.length > 0 ? 'Partial' : 'Failed');

            const preview = await Swal.fire({
                title: 'Kết quả đọc chứng từ',
                html: buildDocumentPreviewHtml(allItems, allWarnings, averageConfidence, status),
                icon: readyItems.length ? (allWarnings.length ? 'warning' : 'info') : 'warning',
                width: 920,
                showCancelButton: readyItems.length > 0,
                confirmButtonText: readyItems.length > 0 ? `Áp dụng ${mergedReadyItems.length} dòng đã khớp` : 'Đã hiểu',
                cancelButtonText: 'Kiểm tra lại',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#64748b'
            });

            if (!preview.isConfirmed || readyItems.length === 0) return;

            const summary = await applyMappedItemsToLines(mergedReadyItems);
            const msg = `Đã đọc ${files.length} chứng từ.\nTổng dòng đề xuất: ${allItems.length}\nDòng đã áp dụng: ${mergedReadyItems.length}\nCần kiểm tra thủ công: ${allItems.length - readyItems.length}\nKhớp vật tư: ${summary.matchedCount}`;
            Swal.fire({
                title: 'Đã áp dụng dòng chứng từ',
                html: `<div class="swal-preline-body">${escapeDocumentText(msg)}</div>`,
                icon: 'success',
                confirmButtonColor: '#10b981'
            });
        } catch (e) {
            Swal.close();
            Swal.fire('Lỗi đọc chứng từ', '' + e, 'error');
        } finally {
            window.wmsLoading?.end(busy);
            this.value = '';
        }
    });

    // ================================================================
    // DIRECTED PUTAWAY — Frontend Integration
    // Gọi bộ gợi ý vị trí cất hàng và tự động điền vị trí phù hợp.
    // ================================================================
    async function autoPutaway() {
        const rows = document.querySelectorAll('#linesContainer .line-row');
        const items = [];
        const warehouseId = parseInt(document.querySelector('input[name="WarehouseId"]')?.value || '0');
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        rows.forEach((row, idx) => {
            const itemSelect = row.querySelector('.item-select');
            const qtyInput = row.querySelector('input[name$=".TransactionQty"]');
            const lotInput = row.querySelector('input[name$=".LotNumber"]');
            const expiryInput = row.querySelector('input[name$=".ExpiryDate"]');
            if (itemSelect && itemSelect.value) {
                items.push({
                    itemId: parseInt(itemSelect.value),
                    rowIndex: idx,
                    warehouseId: warehouseId > 0 ? warehouseId : null,
                    quantity: parseFloat(qtyInput?.value || '0') || null,
                    lotNumber: lotInput?.value?.trim() || null,
                    expiryDate: expiryInput?.value || null
                });
            }
        });

        if (items.length === 0) {
            Swal.fire('Chưa có vật tư', 'Vui lòng chọn ít nhất 1 vật tư trước khi chạy gợi ý vị trí cất hàng.', 'warning');
            return;
        }

        const busy = window.wmsLoading?.begin(
            document.getElementById('linesContainer') || document.getElementById('voucherForm'),
            { text: 'Đang gợi ý vị trí cất hàng...', delay: 700, disable: false }
        );

        try {
            const resp = await fetch('/Vouchers/SuggestPutaway', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify(items)
            });
            const raw = await resp.text();
            let data = null;
            try {
                data = raw ? JSON.parse(raw) : null;
            } catch {
                data = null;
            }
            if (!resp.ok) {
                const serverMessage = data?.error || data?.title || raw || `HTTP ${resp.status}`;
                Swal.fire('Lỗi Engine', serverMessage, 'error');
                return;
            }
            if (!data) {
                Swal.fire('Lỗi xử lý', 'Server không trả về dữ liệu hợp lệ cho chức năng gợi ý vị trí cất hàng.', 'error');
                return;
            }

            if (!data.success) {
                Swal.fire('Lỗi Engine', data.error || 'Không thể phân bổ vị trí.', 'error');
                return;
            }

            // Apply suggestions to form with animation
            let assignedCount = 0;
            let strategies = [];
            const allRows = document.querySelectorAll('#linesContainer .line-row');

            for (const s of data.suggestions) {
                if (s.locationId && s.rowIndex < allRows.length) {
                    const row = allRows[s.rowIndex];
                    const locSelect = row.querySelector('.putaway-loc-select');
                    if (locSelect) {
                        // Destroy Select2 if active
                        if ($(locSelect).hasClass('select2-hidden-accessible')) {
                            $(locSelect).select2('destroy');
                        }
                        locSelect.value = s.locationId;
                        
                        // Visual feedback: highlight the cell
                        locSelect.style.transition = 'all 0.5s';
                        locSelect.style.background = 'rgba(99, 102, 241, 0.15)';
                        locSelect.style.borderColor = '#6366f1';
                        locSelect.style.fontWeight = '700';
                        setTimeout(() => {
                            locSelect.style.background = '';
                            locSelect.style.borderColor = '';
                        }, 3000);

                        assignedCount++;
                        const strategyLocation = escapeDocumentText(s.locationCode);
                        const strategyName = escapeDocumentText(s.strategy);
                        const strategyReason = escapeDocumentText(s.reason || '');
                        strategies.push(
                            `<b>${strategyLocation}</b> <span class="putaway-strategy">← ${strategyName}</span>`
                            + `${strategyReason ? `<div class="putaway-reason">${strategyReason}</div>` : ''}`
                        );
                    }
                }
            }

            // Show result
            Swal.fire({
                title: '<i class="fas fa-check-circle swal-title-success-icon"></i> Đã gợi ý vị trí cất hàng',
                html: `<div class="putaway-result-body">
                    <div class="putaway-summary">
                        <i class="fas fa-box-open"></i> Đã phân bổ ${assignedCount}/${items.length} vật tư vào vị trí tối ưu
                    </div>
                    ${strategies.map((s, i) => `<div class="putaway-line">${i+1}. ${s}</div>`).join('')}
                    <div class="putaway-algo-note">
                        <i class="fas fa-info-circle"></i> Thuật toán xếp hạng: cùng lô/cùng vật tư → fixed bin đủ tải → ô trống cùng khu vực → ô trống khả dụng
                    </div>
                </div>`,
                icon: null,
                confirmButtonColor: '#6366f1',
                confirmButtonText: 'Tuyệt vời!'
            });

            if (typeof beepSuccess === 'function') beepSuccess();

        } catch (err) {
            Swal.fire('Lỗi kết nối', 'Không thể kết nối đến server: ' + err.message, 'error');
        } finally {
            window.wmsLoading?.end(busy);
        }
    }


</script>
