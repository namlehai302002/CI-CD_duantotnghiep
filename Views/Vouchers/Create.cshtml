                    if (!tableRows) { tableRows = '<tr><td colspan="5" class="loc-suggest-empty">Không tìm thấy vị trí phù hợp</td></tr>'; }
                    const bestLoc = data.length > 0 ? data[0] : null;
                    const contentHtml = `
                        <div class="loc-suggest-modal">
                            <div class="loc-suggest-header">
                                <div>
                                    <h5 class="loc-suggest-title">🔍 Gợi Ý Vị Trí</h5>
                                    <p class="loc-suggest-sub">${escapeDocumentText(itemName)} — SL: ${formatVnNumber(qty)}</p>
                                </div>
                                <button type="button" class="loc-suggest-close" data-wms-close-modal="locationSuggestionModal">&times;</button>
                            </div>
                            <div class="loc-suggest-body">
                                <div class="loc-suggest-hint"><span class="loc-suggest-same-item">⭐</span> = Ô đã chứa cùng vật tư (ưu tiên cao)</div>
                                <table class="loc-suggest-table">
                                    <thead><tr>
                                        <th>Ô</th>
                                        <th>Khu</th>
                                        <th>Còn trống</th>
                                        <th>% đầy</th>
