                                ${bestLoc ? `<button type="button" class="btn btn-sm btn-success" data-wms-call="selectSuggestedLocation" data-wms-arg="${safeLocationId(bestLoc.locationId)}" data-wms-arg2="${escapeDocumentText(bestLoc.locationCode)}">📦 Tự động phân bổ</button>` : ''}
