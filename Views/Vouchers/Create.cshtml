    function selectSuggestedLocation(locationId, locationCode) {
        if (window._currentLocSelect) {
            window._currentLocSelect.value = locationId;
            validateLocation(window._currentLocSelect);
        }
        document.getElementById('locationSuggestionModal')?.classList.remove('is-open');
    }

    async function validateLocation(locSelect) {
        const row = locSelect.closest('tr');
        const locId = locSelect.value;
        const itemSelect = row.querySelector('.item-select');
        const itemId = itemSelect.value;
        const itemText = itemSelect.selectedOptions[0]?.text.trim() || "Vật tư";

        if (!locId || !itemId) return;

        // 1. Check same-form conflicts
        let conflictInForm = false;
        let conflictItemName = "";
        document.querySelectorAll('.line-row').forEach(otherRow => {
            if (otherRow === row) return;
            const otherLocSelect = otherRow.querySelector('.loc-select');
            const otherItemSelect = otherRow.querySelector('.item-select');
            
            if (otherLocSelect && otherLocSelect.value === locId) {
                if (otherItemSelect.value && otherItemSelect.value !== itemId) {
                    conflictInForm = true;
                    // Get name
                    conflictItemName = otherItemSelect.selectedOptions[0]?.text.trim();
                }
            }
        });

        if (conflictInForm) {
            if (typeof Swal !== 'undefined') {
                Swal.fire('Xung đột vị trí', `Vị trí ${locSelect.selectedOptions[0].text} đang được dùng để xếp [${conflictItemName}] ở dòng khác trong phiếu này. Tránh xếp chung 2 vật tư vào 1 ô/bồn.`, 'warning');
            } else {
                enterpriseNotify({ title: 'Xung đột vị trí', text: `Vị trí ${locSelect.selectedOptions[0].text} đang được dùng để xếp [${conflictItemName}] ở dòng khác trong phiếu này.`, icon: 'warning' });
            }
            locSelect.value = ''; // Reset
            return;
        }

        // 2. Check DB conflicts
        try {
            const res = await fetchJsonOrThrow(`/Warehouses/CheckLocationConflict?locationId=${locId}&itemId=${itemId}`, 'Không kiểm tra được xung đột vị trí.');
            if (res.conflict) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire('Vị trí đã có hàng', `Vị trí ${locSelect.selectedOptions[0].text} đang chứa ${res.conflictItemName}. Không thể xếp [${itemText}] chung vào đây.`, 'error');
                } else {
                    enterpriseNotify({ title: 'Vị trí đã có hàng', text: `Vị trí ${locSelect.selectedOptions[0].text} đang chứa ${res.conflictItemName}.`, icon: 'error' });
                }
                locSelect.value = '';
            }
        } catch (err) {
            console.error(err);
            if (typeof Swal !== 'undefined') {
                Swal.fire('Không kiểm tra được vị trí', err?.message || 'Có lỗi xảy ra khi kiểm tra xung đột vị trí.', 'error');
            }
        }
    }

    // --- FORM SUBMIT ---
    document.getElementById('voucherForm').addEventListener('submit', function(e) {
        // Tự động dọn dẹp các dòng trống (nếu có) trước khi kiểm tra lỗi
        const tbody = document.getElementById('linesContainer');
        const rows = tbody.querySelectorAll('.line-row');
        if (rows.length > 1) {
            let removedAny = false;
            for (let i = rows.length - 1; i >= 0; i--) {
                const r = rows[i];
                const itemSelect = r.querySelector('.item-select');
                const qtyInput = r.querySelector('.qty-input');
                if (itemSelect && qtyInput && !itemSelect.value && (!qtyInput.value || qtyInput.value === "0")) {
                    // Nếu dòng hoàn toàn trống và không phải dòng duy nhất
                    if (tbody.querySelectorAll('.line-row').length > 1) {
                        $(r).find('.item-select, .source-uom-select').each(function() {
                            if ($(this).hasClass('select2-hidden-accessible')) {
                                $(this).select2('destroy');
                            }
                        });
                        r.remove();
                        removedAny = true;
                    }
                }
            }
            if (removedAny) {
                // Đánh lại số thứ tự index để MVC Binding không bị lỗi
                const remainingRows = tbody.querySelectorAll('.line-row');
                remainingRows.forEach((r, idx) => {
                    r.querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/\[\d+\]/, `[${idx}]`);
                    });
                });
                lineIdx = remainingRows.length;
            }
        }

        let isValid = true;
        
        // Thêm fallback an toàn trong trường hợp jQuery validation chưa load kịch bản 
        if (typeof $ !== 'undefined' && $.fn && $.fn.valid) {
            isValid = $(this).valid();
        }

        // Custom validation: PartnerId required only when partner field is visible
        const requiredPartner = this.querySelector('select[name="PartnerId"].partner-select-validate');
        const partnerDiv = document.getElementById('partnerFieldDiv');
        const partnerVisible = partnerDiv && partnerDiv.style.display !== 'none';
        if (requiredPartner && partnerVisible && (!requiredPartner.value || requiredPartner.value === "")) {
            e.preventDefault();
            if (typeof Swal !== 'undefined') {
                Swal.fire('Thiếu thông tin', 'Vui lòng chọn Đối Tác (NCC / Khách Hàng) trước khi lưu phiếu.', 'warning');
            } else {
                enterpriseNotify({ title: 'Thiếu thông tin', text: 'Vui lòng chọn Đối Tác (NCC / Khách Hàng) trước khi lưu phiếu.', icon: 'warning' });
            }
            requiredPartner.focus();
            return;
        }

        if (isValid) {
            document.getElementById('submitBtn').disabled = true;
            document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang Xử Lý...';
        } else {
            document.getElementById('validationSummary').style.display = 'block';
            e.preventDefault();
        }
    });

    // ============================================================
    // TÍCH HỢP THIẾT BỊ QUÉT MÃ VẠCH
    // Thiết bị quét USB/Bluetooth hoạt động giống bàn phím:
    //   1. Thiết bị nhập nhanh chuỗi mã vạch
    //   2. Sau đó gửi phím Enter
    //   3. Ô nhập cần được lấy tiêu điểm để nhận mã
    // ============================================================
    initializeExportTabs();
    document.querySelectorAll('.line-row .item-select').forEach(select => {
        if (select.value) {
            itemChanged(select);
        } else {
            const sourceUomSelect = select.closest('.line-row')?.querySelector('.source-uom-select');
            if (sourceUomSelect) {
                resetSourceUomOptions(sourceUomSelect);
            }
        }
    });
    const bInput = document.getElementById('barcodeInput');

    // Tự lấy tiêu điểm khi tải trang
    if (bInput) {
        bInput.focus({ preventScroll: true });

        // Lấy lại tiêu điểm khi bấm vào vùng trống trên trang
        document.addEventListener('click', function(e) {
            // Bỏ qua khi bấm vào ô tìm kiếm select2 hoặc thành phần select2
            if (e.target.closest('.select2-container')) return;

            if (e.target.tagName !== 'INPUT' && e.target.tagName !== 'SELECT' && e.target.tagName !== 'TEXTAREA' && e.target.tagName !== 'BUTTON') {
                bInput.focus({ preventScroll: true });
            }
        });

        // Xử lý mã vạch khi người dùng nhấn Enter từ thiết bị quét hoặc nhập tay
        bInput.addEventListener('keypress', async function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const barcode = this.value.trim();
                this.value = '';
                if (barcode) {
                    // Nháy đèn trạng thái
                    const led = document.getElementById('scannerLed');
                    if (led) {
                        led.style.background = '#fbbf24';
                        led.style.boxShadow = '0 0 8px #fbbf24';
                    }
                    
                    await processBarcode(barcode);
                    
                    // Đưa đèn trạng thái về bình thường
                    if (led) {
                        setTimeout(() => {
                            led.style.background = '#10b981';
                            led.style.boxShadow = '0 0 6px #10b981';
                        }, 500);
                    }
                }
                // Luôn lấy lại tiêu điểm cho lần quét tiếp theo
                this.focus();
            }
        });
    }

    // --- XỬ LÝ MÃ VẠCH CHÍNH ---
    async function processBarcode(barcode) {
        if (!barcode) return false;
        const busy = window.wmsLoading?.begin(
            document.querySelector('.barcode-input-wrap') || document.getElementById('barcodeInput'),
            { text: 'Đang tra mã vạch...', delay: 700, disable: false }
        );

        try {
            const res = await fetch(`/Items/GetItemByBarcode?barcode=${encodeURIComponent(barcode)}`);
            const raw = await res.text();
            let payload = null;
            if (raw) {
                try {
                    payload = JSON.parse(raw);
                } catch {
                    if (res.ok) throw new Error('Server trả về dữ liệu mã vạch không hợp lệ.');
                }
            }

            if (res.ok && payload) {
                const item = payload;
                // Check if already in list → increment quantity
                let foundRow = null;
                document.querySelectorAll('.line-row').forEach(row => {
                    const select = row.querySelector('.item-select');
                    if (select.value == item.itemId) foundRow = row;
                });

                if (foundRow) {
                    // DUPLICATE SCAN → increment qty
                    const qtyInput = foundRow.querySelector('input[name$=".TransactionQty"]');
                    const newQty = parseCommaNumber(qtyInput.value) + 1;
                    qtyInput.value = formatWithCommas(newQty.toString());
                    
                    foundRow.classList.remove('scan-row-highlight');
                    void foundRow.offsetWidth; // Force reflow
                    foundRow.classList.add('scan-row-highlight');

                    beepDuplicate();
                    updateScanCount();
                    showScanToast(`✓ ${item.itemCode} — SL tăng lên ${newQty}`, 'duplicate');
                    return true;
                }

                // NEW ITEM → add to table
                const tbody = document.getElementById('linesContainer');
                let firstRow = tbody.querySelector('.line-row');
                let isFirstBlank = firstRow && firstRow.querySelector('.item-select').value === "";
                
                let targetRow = isFirstBlank ? firstRow : null;
                if (!targetRow) {
                    addRow();
                    const rows = document.querySelectorAll('.line-row');
                    targetRow = rows[rows.length - 1];
                }

                const select = targetRow.querySelector('.item-select');
                select.value = item.itemId;
                itemChanged(select); 
                
                targetRow.querySelector('input[name$=".TransactionQty"]').value = 1;
                calculateRowPrice(targetRow);

                // Highlight the new row
                targetRow.classList.add('scan-row-highlight');

                beepSuccess();
                updateScanCount();
                showScanToast(`✓ Đã thêm: [${item.itemCode}] ${item.itemName}`, 'success');
                return true;

            } else {
                // NOT FOUND
                beepError();
                showScanToast(`✗ ${payload?.message || `Không tìm thấy vật tư với mã: ${barcode}`}`, 'error');
                return false;
            }
        } catch (err) {
            console.error('[Scanner] Lỗi kết nối:', err);
            beepError();
            showScanToast(`✗ ${err?.message || 'Lỗi kết nối — thử lại'}`, 'error');
            return false;
        } finally {
            window.wmsLoading?.end(busy);
        }
    }

