                    `;
                    modal.innerHTML = contentHtml;
                    window.enhanceDataWidths?.();
                }

                // Store reference to location select
                modal.dataset.locSelectName = locSelect.getAttribute('name');
            })
            .catch(err => {
                console.error('Error loading suggestions:', err);
                modal.innerHTML = `
                    <div class="loc-suggest-modal loc-suggest-error">
                        <i class="fas fa-circle-exclamation loc-suggest-error-icon"></i>
