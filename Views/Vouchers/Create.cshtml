@model WMS.ViewModels.VoucherCreateViewModel
@{
    string typeName = Model.VoucherType switch {
        WMS.Models.VoucherTypeEnum.NhapKho => "Nhập kho",
        WMS.Models.VoucherTypeEnum.XuatKho => "Xuất kho",
        WMS.Models.VoucherTypeEnum.TraNCC => "Trả nhà cung cấp",
        WMS.Models.VoucherTypeEnum.KhachTra => "Khách trả",
        WMS.Models.VoucherTypeEnum.DieuChinh => "Điều chỉnh",
        WMS.Models.VoucherTypeEnum.ChuyenKho => "Chuyển kho",
        WMS.Models.VoucherTypeEnum.NhapThanhPham => "Nhập thành phẩm",
        WMS.Models.VoucherTypeEnum.XuatSanXuat => "Xuất sản xuất",
        _ => ""
    };
    ViewData["Title"] = $"Tạo phiếu {typeName}";
    var canSeeFinancial = (bool)(ViewBag.CanSeeFinancial ?? false);
    var isInbound = Model.VoucherType is WMS.Models.VoucherTypeEnum.NhapKho or WMS.Models.VoucherTypeEnum.KhachTra or WMS.Models.VoucherTypeEnum.NhapThanhPham;
    var itemAllowedSourceUomsJson = (string?)(ViewBag.ItemAllowedSourceUomsJson ?? "{}") ?? "{}";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Tạo phiếu @typeName</h1>
        <p class="page-subtitle">Khai báo đầy đủ thông tin để hệ thống ghi nhận chính xác và dễ đối soát sau này.</p>
    </div>
    <a asp-controller="Vouchers" asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
</div>

<div class="user-guide">
    <div class="user-guide-title"><i class="fas fa-circle-info"></i> Hướng dẫn nhanh trước khi tạo phiếu</div>
    <div class="step-list">
        <span class="step-chip"><i class="fas fa-building"></i> 1) Chọn đúng kho và đối tác liên quan</span>
        <span class="step-chip"><i class="fas fa-box"></i> 2) Chọn vật tư, nhập số lượng và đơn vị phù hợp với vật tư đó</span>
        @if (isInbound)
        {
            <span class="step-chip"><i class="fas fa-truck"></i> 3) Khai báo lịch xe đến và khung giờ nhận hàng nếu có</span>
            <span class="step-chip"><i class="fas fa-save"></i> 4) Chọn "Lưu tạm" để bổ sung sau hoặc "Lưu và gửi duyệt" để gửi quản lý</span>
        }
        else
        {
            <span class="step-chip"><i class="fas fa-save"></i> 3) Kiểm tra lại dữ liệu rồi bấm "Hoàn tất và lưu phiếu"</span>
        }
    </div>
</div>
@if (Model.VoucherType == WMS.Models.VoucherTypeEnum.ChuyenKho)
{
    <div class="user-guide transfer-guide">
        <div class="user-guide-title"><i class="fas fa-lightbulb"></i> Cách hiểu nhanh phiếu chuyển kho</div>
        <div class="transfer-guide-text">
            <b>Số lượng thực chuyển</b> = <b>Số lượng xuất</b> x <b>Quy đổi ra đơn vị tồn kho</b>.
            Ví dụ: xuất 2 Bộ, quy đổi 10 Cái/Bộ thì hệ thống sẽ chuyển tồn 20 Cái.
        </div>
    </div>
}

<form asp-controller="Vouchers" asp-action="Create" method="post" id="voucherForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="VoucherType" value="@Model.VoucherType" />
    <input type="hidden" name="ParentVoucherId" value="@Model.ParentVoucherId" />
    <div asp-validation-summary="All" class="alert alert-danger validation-summary-enterprise" id="validationSummary"></div>

    @if (Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatKho)
    {
        <input type="hidden" name="ExportMode" id="ExportMode" value="1" />
    }

    <div class="card mb-3">
        <div class="card-header"><span class="card-title">Thông tin chung</span></div>
        <div class="card-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Ngày Chứng Từ</label>
                    <input type="text" class="form-control" value="@WMS.Common.VietnamTime.Today.ToString("dd/MM/yyyy")" disabled />
                </div>
                @if(Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatKho)
                {
                    <div class="form-group">
                        <label class="form-label">Loại xuất</label>
                        <select id="exportModeSelect" class="form-control" data-wms-change-call="setExportMode" data-wms-change-value="true">
                            <option value="1" selected>Xuất nội bộ</option>
                            <option value="2">Xuất bán / ra ngoài</option>
                        </select>
                    </div>
                }
                <input type="hidden" name="WarehouseId" value="@(Model.WarehouseId > 0 ? Model.WarehouseId : Model.Warehouses.FirstOrDefault()?.WarehouseId)" />
                @if(Model.VoucherType == WMS.Models.VoucherTypeEnum.ChuyenKho)
                {
                    <div class="form-group">
                        <label class="form-label">Kho Đích *</label>
                        <select name="DestWarehouseId" class="form-control" required
                                data-wms-invalid-message="Vui lòng chọn kho đích."
                                data-wms-clear-validity="true">
                            <option value="">-- Chọn kho đích --</option>
                            @foreach (var w in Model.Warehouses.Where(x => x.IsActive))
                            {
                                <option value="@w.WarehouseId" selected="@(w.WarehouseId == Model.DestWarehouseId ? "selected" : null)">
                                    [@w.WarehouseCode] @w.WarehouseName
                                </option>
                            }
                        </select>
                    </div>
                }
                
                @if(Model.VoucherType is WMS.Models.VoucherTypeEnum.NhapKho or WMS.Models.VoucherTypeEnum.XuatKho or WMS.Models.VoucherTypeEnum.TraNCC or WMS.Models.VoucherTypeEnum.KhachTra)
                {
                    <div class="form-group" id="partnerFieldDiv">
                        <label class="form-label" asp-for="PartnerId">Đối Tác (NCC / Khách Hàng) *</label>
                        <select name="PartnerId" class="form-control partner-select-validate">
                            <option value="">-- Trống / Chọn Đối Tác --</option>
                            @foreach(var p in Model.Partners) { 
                                <option value="@p.PartnerId" selected="@(p.PartnerId == Model.PartnerId ? "selected" : null)">
                                    [@p.PartnerCode] @p.PartnerName
                                </option> 
                            }
                        </select>
                    </div>
                }
                @if (Model.OwnerPartners.Any())
                {
                    <div class="form-group">
                        <label class="form-label">Chủ hàng kho dịch vụ</label>
                        <select name="OwnerPartnerId" class="form-control">
                            <option value="">-- Internal / unowned --</option>
                            @foreach (var owner in Model.OwnerPartners)
                            {
                                <option value="@owner.PartnerId" selected="@(owner.PartnerId == Model.OwnerPartnerId ? "selected" : null)">
                                    [@owner.PartnerCode] @owner.PartnerName
                                </option>
                            }
                        </select>
                    </div>
                }
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Số Chứng Từ Gốc</label>
                    <input type="text" name="ReferenceNo" class="form-control" placeholder="VD: INVOICE-123" value="@Model.ReferenceNo" />
                </div>
                <div class="form-group form-span-2">
                    <label class="form-label">Diễn giải / Ghi chú</label>
                    <input type="text" name="Description" class="form-control" placeholder="Mục đích nhập/xuất" value="@Model.Description" />
                </div>
                @if (Model.VoucherType is WMS.Models.VoucherTypeEnum.XuatKho or WMS.Models.VoucherTypeEnum.TraNCC or WMS.Models.VoucherTypeEnum.ChuyenKho or WMS.Models.VoucherTypeEnum.XuatSanXuat)
                {
                    <div class="form-group">
                        <label class="form-label">Ngày cần hàng theo cam kết</label>
                        <input type="date" name="RequestedDeliveryDate" class="form-control" 
                               value="@(Model.RequestedDeliveryDate?.ToString("yyyy-MM-dd"))" 
                               title="Ngày KH / bộ phận cần nhận hàng — hệ thống sẽ cảnh báo nếu trễ hạn" />
                    </div>
                }
            </div>
            @if (isInbound)
            {
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Giờ xe đến dự kiến *</label>
                        <input type="datetime-local" name="ExpectedArrivalAt" class="form-control"
                               value="@(Model.ExpectedArrivalAt?.ToString("yyyy-MM-ddTHH:mm"))"
                               title="Thời điểm xe hoặc nhà cung cấp dự kiến đến kho" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Giờ bắt đầu khung nhận hàng</label>
                        <input type="datetime-local" name="DockAppointmentStart" class="form-control"
                               value="@(Model.DockAppointmentStart?.ToString("yyyy-MM-ddTHH:mm"))"
                               title="Khung giờ bắt đầu tiếp nhận và bốc dỡ hàng tại cửa kho" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Giờ kết thúc khung nhận hàng</label>
                        <input type="datetime-local" name="DockAppointmentEnd" class="form-control"
                               value="@(Model.DockAppointmentEnd?.ToString("yyyy-MM-ddTHH:mm"))"
                               title="Khung giờ dự kiến hoàn tất bốc dỡ tại cửa kho" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cửa nhận hàng ưu tiên</label>
                        <input type="text" name="DockDoor" class="form-control" maxlength="20"
                               placeholder="VD: Cửa 1, Cửa A — để trống nếu chưa biết"
                               value="@Model.DockDoor" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Đơn vị vận chuyển</label>
                        <input type="text" name="CarrierName" class="form-control" maxlength="100"
                               placeholder="VD: Xe nội bộ / NCC / đơn vị vận tải"
                               value="@Model.CarrierName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Biển số xe</label>
                        <input type="text" name="VehicleNumber" class="form-control" maxlength="30"
                               placeholder="VD: 51D-123.45"
                               value="@Model.VehicleNumber" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tài xế</label>
                        <input type="text" name="DriverName" class="form-control" maxlength="100"
                               placeholder="Tên người giao hàng / tài xế"
                               value="@Model.DriverName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">SĐT tài xế</label>
                        <input type="text" name="DriverPhone" class="form-control" maxlength="20"
                               placeholder="Số điện thoại liên hệ nhanh"
                               value="@Model.DriverPhone" />
                    </div>
                </div>
                <div class="form-help inbound-tip">
                    <strong>💡 Mẹo:</strong> Khai báo đủ giờ xe đến và khung nhận hàng ngay từ đầu để trưởng kho duyệt nhanh. Nếu chưa biết cửa nào trống, để trống ô "Cửa nhận hàng ưu tiên" — hệ thống sẽ tự gợi ý.
                </div>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header line-items-toolbar">
            <div class="line-items-toolbar-left">
                <span class="card-title line-items-title">Danh sách vật tư</span>
                <div class="barcode-input-wrap">
                    <i class="fas fa-barcode barcode-input-icon"></i>
                    <input type="text" id="barcodeInput" class="form-control barcode-input-field" autocomplete="off" 
                           placeholder="Quét mã vạch hoặc nhập mã vật tư rồi nhấn Enter" 
                           />
                    <span id="scannerLed" class="scanner-led"></span>
                </div>
                <span id="scanCount" class="badge scan-count-badge">0 lượt quét</span>
                <button type="button" class="btn btn-sm btn-secondary" data-wms-call="toggleWebcamScanner"><i class="fas fa-camera"></i> Quét bằng camera</button>
            </div>
            <div class="line-items-toolbar-actions">
                @if (isInbound)
                {
                    <button type="button" class="btn btn-sm btn-putaway" data-wms-call="autoPutaway" title="Tự động gợi ý vị trí cất hàng phù hợp dựa trên vật tư, sức chứa và quy tắc vận hành.">
                        <i class="fas fa-robot"></i> Gợi ý vị trí cất hàng
                    </button>
                }
                <label class="btn btn-sm btn-info btn-inline-label" id="uploadDocumentBtn" for="documentFileInput">
                    <span id="uploadDocumentBtnText"><i class="fas fa-magic"></i> Đọc chứng từ bằng AI</span>
                </label>
                <input type="file" id="documentFileInput" accept=".pdf,.jpg,.jpeg,.png,.webp,.docx,.pptx,.xlsx" multiple class="d-none" />
                <label class="btn btn-sm btn-secondary btn-inline-label" id="importExcelBtn">
                    <i class="fas fa-file-import"></i> Tải danh sách từ Excel
                    <input type="file" id="excelFileInput" accept=".xlsx" class="d-none" />
                </label>
                <a class="btn btn-sm btn-ghost" asp-controller="Vouchers" asp-action="DownloadImportTemplate" title="Tải file mẫu Excel đúng cấu trúc để nhập dữ liệu nhanh và hạn chế lỗi.">
                    <i class="fas fa-download"></i> Tải file mẫu
                </a>
                <button type="button" class="btn btn-sm btn-primary" data-wms-call="addRow"><i class="fas fa-plus"></i> Thêm dòng vật tư</button>
            </div>
        </div>
        <!-- Scan toast notification -->
        <div id="scanToast" class="scan-toast-enterprise"></div>
        <div class="table-container flat voucher-mobile-line-editor">
            <table id="linesTable" class="voucher-lines-table">
                <thead>
                    <tr>
                        <th class="col-line-no">#</th>
                        <th class="col-item">Vật Tư / Hàng Hóa *</th>
                        <th class="col-uom">@(isInbound ? "Đơn vị nhập" : "Đơn vị xuất")</th>
                        <th class="col-qty">@(isInbound ? "Số lượng nhập *" : "Số lượng xuất *")</th>
                        @if (Model.VoucherType is WMS.Models.VoucherTypeEnum.NhapKho or WMS.Models.VoucherTypeEnum.KhachTra or WMS.Models.VoucherTypeEnum.NhapThanhPham or WMS.Models.VoucherTypeEnum.ChuyenKho)
                        {
                            <th class="col-lot">Số lô</th>
                        }
                        @if (Model.VoucherType == WMS.Models.VoucherTypeEnum.ChuyenKho)
                        {
                            <th class="col-location">Lấy từ vị trí *</th>
                            <th class="col-location">Chuyển đến vị trí *</th>
                        }
                        @if (Model.VoucherType == WMS.Models.VoucherTypeEnum.DieuChinh)
                        {
                            <th class="col-adjust">Điều chỉnh</th>
                        }
                        @* Removed SL lỗi/thiếu column for simpler UX *@
                        @if (!isInbound)
                        {
                            <th class="col-base-uom" title="Đơn vị tồn kho (base unit) được hệ thống tự xác định dựa trên vật tư đã chọn.">Đơn vị tồn kho <i class="fas fa-info-circle info-inline-icon"></i></th>
                            <th class="col-conversion" title="Hệ số quy đổi: SL xuất × hệ số = SL trừ tồn kho. VD: xuất 2 Thùng × 10 Cái/Thùng = trừ 20 Cái.">Quy đổi ra đơn vị tồn <i class="fas fa-info-circle info-inline-icon"></i></th>
                        }
                        @if (isInbound)
                        {
                            <th class="col-putaway">Vị trí cất hàng</th>
                            <th class="col-date">Ngày SX</th>
                            <th class="col-date">Hạn SD</th>
                        }
                        <th class="price-col col-price">Đơn Giá (VNĐ)</th>
                        <th class="col-remove"></th>
                    </tr>
                </thead>
                <tbody id="linesContainer">
                    @{
                        if (Model.Lines == null || !Model.Lines.Any())
                        {
                            Model.Lines = new List<WMS.ViewModels.VoucherDetailLine> { new WMS.ViewModels.VoucherDetailLine { DefectQty = 0, TransactionQty = 0, UnitPrice = 0 } };
                        }
                    }
                    @for (int i = 0; i < Model.Lines.Count; i++)
                    {
                        var line = Model.Lines[i];
                        <tr class="line-row">
                            <td class="line-no text-center text-muted fw-700">@(i + 1)</td>
                            <td>
                                <select name="Lines[@i].ItemId" class="form-control item-select" required data-wms-change-call="itemChanged" data-wms-change-self="true">
                                    <option value="">-- Chọn vật tư --</option>
                                    @foreach(var item in Model.Items) { 
                                        <option value="@item.ItemId" 
                                                data-uom="@item.BaseUomId" 
                                                data-group="@item.BaseUom?.UomGroup"
                                                data-cost="@(canSeeFinancial ? item.UnitCost.ToString(System.Globalization.CultureInfo.InvariantCulture) : 0)" 
                                                data-default-loc="@item.DefaultLocationId"
                                                data-item-type="@item.ItemType"
                                                data-image-url="@(item.ImageUrl ?? "")"
                                                disabled="@(item.BaseUomId <= 0 ? "disabled" : null)"
                                                selected="@(item.ItemId == line.ItemId ? "selected" : null)">
                                            [@item.ItemCode] @item.ItemName
                                        </option> 
                                    }
                                </select>
                            </td>
                            <td>
                                <select name="Lines[@i].TransactionUomId" class="form-control source-uom-select" data-placeholder-text="-- Chọn đơn vị @(isInbound ? "nhập" : "xuất") --" data-wms-change-call="sourceUomChanged" data-wms-change-self="true">
                                    <option value="">-- Chọn đơn vị @(isInbound ? "nhập" : "xuất") --</option>
                                    @foreach(var u in Model.Uoms) { 
                                        <option value="@u.UomId" data-group="@u.UomGroup"
                                                selected="@(u.UomId == line.TransactionUomId ? "selected" : null)">
                                            @u.UomCode - @u.UomName
                                        </option> 
                                    }
                                </select>
                            </td>
                            <td>
                                <input type="text" name="Lines[@i].TransactionQty" class="form-control text-right qty-input" required value="@(line.TransactionQty > 0 ? line.TransactionQty.ToString("N0") : "")" data-wms-input-call="formatAndCalc" data-wms-input-self="true" />
                            </td>
                            @if (Model.VoucherType is WMS.Models.VoucherTypeEnum.NhapKho or WMS.Models.VoucherTypeEnum.KhachTra or WMS.Models.VoucherTypeEnum.NhapThanhPham or WMS.Models.VoucherTypeEnum.ChuyenKho)
                            {
                                <td>
                                    <input type="text" name="Lines[@i].LotNumber" class="form-control lot-input" value="@line.LotNumber" placeholder="Nhập số lô từ NCC" />
                                </td>
                            }
                            @if (Model.VoucherType == WMS.Models.VoucherTypeEnum.ChuyenKho)
                            {
                                <td>
                                    <select name="Lines[@i].LocationId" class="form-control loc-select" required>
                                        <option value="">-- Chọn vị trí lấy hàng --</option>
                                        @foreach (var loc in Model.Locations.Where(l => l.IsActive))
                                        {
                                            <option value="@loc.LocationId" selected="@(loc.LocationId == line.LocationId ? "selected" : null)">
                                                @loc.LocationCode
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="Lines[@i].DestLocationId" class="form-control dest-loc-select" required>
                                        <option value="">-- Chọn vị trí nhận hàng --</option>
                                        @foreach (var loc in Model.Locations.Where(l => l.IsActive))
                                        {
                                            <option value="@loc.LocationId" selected="@(loc.LocationId == line.DestLocationId ? "selected" : null)">
                                                @loc.LocationCode
                                            </option>
                                        }
                                    </select>
                                </td>
                            }
                            @if (Model.VoucherType == WMS.Models.VoucherTypeEnum.DieuChinh)
                            {
                                <td>
                                    <select name="Lines[@i].AdjustSign" class="form-control select-strong">
                                        <option value="1" selected="@(line.AdjustSign == 1 ? "selected" : null)">Tăng</option>
                                        <option value="-1" selected="@(line.AdjustSign == -1 ? "selected" : null)">Giảm</option>
                                    </select>
                                </td>
                            }
                            @* Removed SL lỗi/thiếu input *@
                            @if (!isInbound)
                            {
                                <td>
                                    <select class="form-control dest-uom-select" disabled>
                                        <option value="">-- Đơn vị tồn kho --</option>
                                        @foreach(var u in Model.Uoms) { 
                                            <option value="@u.UomId">@u.UomCode - @u.UomName</option> 
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input type="text" name="Lines[@i].DestQty" class="form-control text-right dest-qty-input input-strong-accent" readonly title="Hệ số quy đổi được tính tự động theo bảng quy đổi hệ thống." />
                                    @* For non-transfer vouchers, LocationId is handled via hidden field *@
                                    @if (Model.VoucherType != WMS.Models.VoucherTypeEnum.ChuyenKho)
                                    {
                                        <input type="hidden" name="Lines[@i].LocationId" class="loc-input" value="@line.LocationId" />
                                    }
                                </td>
                            }
                            else
                            {
                                @* Inbound: hide conversion, auto-set DestQty=0 (ConversionRate=1) *@
                                <input type="hidden" name="Lines[@i].DestQty" value="0" />
                            }
                            @if (isInbound)
                            {
                                <td>
                                    <select name="Lines[@i].LocationId" class="form-control putaway-loc-select">
                                        <option value="">-- Chờ hệ thống gợi ý vị trí --</option>
                                        @foreach (var loc in Model.Locations.Where(l => l.IsActive))
                                        {
                                            <option value="@loc.LocationId" selected="@(loc.LocationId == line.LocationId ? "selected" : null)">@loc.LocationCode</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input type="date" name="Lines[@i].ManufacturingDate" class="form-control mfg-date-input" value="@(line.ManufacturingDate?.ToString("yyyy-MM-dd"))" />
                                </td>
                                <td>
                                    <input type="date" name="Lines[@i].ExpiryDate" class="form-control exp-date-input" value="@(line.ExpiryDate?.ToString("yyyy-MM-dd"))" />
                                </td>
                            }
                            <input type="hidden" name="Lines[@i].DefectQty" value="0" />
                            <td class="price-col">
                                <input type="text" name="Lines[@i].UnitPrice" class="form-control text-right cost-input" value="@(Model.VoucherType == WMS.Models.VoucherTypeEnum.NhapKho || Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatSanXuat || !canSeeFinancial ? "0" : line.UnitPrice.ToString("N0"))" @(Model.VoucherType == WMS.Models.VoucherTypeEnum.NhapKho || Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatSanXuat || !canSeeFinancial ? "readonly" : "") data-wms-input-call="formatAndPrice" data-wms-input-self="true" />
                            </td>
                            <td class="line-row-actions">
                                <button type="button" class="btn-delete-row" data-wms-call-self="deleteRow" title="Xóa dòng">
                                    <i class="fas fa-times"></i>
                                </button>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

    <div class="action-bar voucher-submit-actions">
        @if (Model.VoucherType is WMS.Models.VoucherTypeEnum.NhapKho or WMS.Models.VoucherTypeEnum.KhachTra or WMS.Models.VoucherTypeEnum.NhapThanhPham)
        {
            <button type="submit" class="btn btn-secondary btn-lg" name="submit" value="false" id="saveDraftBtn"><i class="fas fa-save"></i> Lưu tạm</button>
            <button type="submit" class="btn btn-success btn-lg" name="submit" value="true" id="submitBtn"><i class="fas fa-paper-plane"></i> Lưu và gửi duyệt</button>
        }
        else
        {
            <button type="submit" class="btn btn-success btn-lg" id="submitBtn"><i class="fas fa-check"></i> Hoàn tất và lưu phiếu</button>
        }
    </div>
</form>


@section Scripts {
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    function getSafeItemImageUrl(optionElement) {
        const raw = (optionElement?.dataset?.imageUrl || '').trim();
        if (!raw) return '';

        if (raw.startsWith('/uploads/items/') || raw.startsWith('https://') || raw.startsWith('http://')) {
            return raw;
        }

        return '';
    }

    function createItemThumbNode(imageUrl, altText) {
        if (imageUrl) {
            const img = document.createElement('img');
            img.className = 'item-thumb';
            img.src = imageUrl;
            img.alt = altText || 'Ảnh vật tư';
            img.loading = 'lazy';
            img.decoding = 'async';
            img.onerror = function() {
                this.replaceWith(createItemThumbNode('', altText));
            };
            return img;
        }

        const fallback = document.createElement('span');
        fallback.className = 'item-thumb item-thumb-empty';
        fallback.setAttribute('aria-hidden', 'true');
        const icon = document.createElement('i');
        icon.className = 'fas fa-box';
        fallback.appendChild(icon);
        return fallback;
    }

    function renderItemSelectOption(option) {
        if (!option.id || !option.element) {
            return option.text;
        }

        const imageUrl = getSafeItemImageUrl(option.element);
        const wrapper = document.createElement('div');
        wrapper.className = 'item-select-option';
        wrapper.appendChild(createItemThumbNode(imageUrl, option.text));

        const copy = document.createElement('div');
        copy.className = 'item-select-option-copy';

        const title = document.createElement('span');
        title.className = 'item-select-option-title';
        title.textContent = option.text || '';
        copy.appendChild(title);

        const meta = document.createElement('span');
        meta.className = 'item-select-option-meta';
        meta.textContent = imageUrl ? 'Có ảnh nhận diện' : 'Chưa có ảnh nhận diện';
        copy.appendChild(meta);

        wrapper.appendChild(copy);
        return $(wrapper);
    }

    function initSelect2() {
        $('.item-select').select2({
            width: '100%',
            dropdownAutoWidth: true,
            templateResult: renderItemSelectOption
        });

        $('.source-uom-select, select[name="PartnerId"]').select2({
            width: '100%',
            dropdownAutoWidth: true
        });
        
        // Fix for Select2 search input focus inside modals or elements
        $(document).on('select2:open', () => {
            document.querySelector('.select2-search__field').focus();
        });
    }

    $(document).ready(function() {
        initSelect2();
    });
    // === COMMA FORMATTING UTILITIES ===
    function parseCommaNumber(str) {
        if (!str) return 0;
        return parseFloat(str.toString().replace(/,/g, '')) || 0;
    }
    function formatWithCommas(num) {
        if (num === '' || num === null || num === undefined) return '';
        var n = parseFloat(num.toString().replace(/,/g, ''));
        if (isNaN(n)) return '';
        // Preserve decimals if present
        var parts = num.toString().replace(/,/g, '').split('.');
        var intPart = parseInt(parts[0]) || 0;
        var formatted = intPart.toLocaleString('en-US');
        if (parts.length > 1) formatted += '.' + parts[1];
        return formatted;
    }
    function formatCommaInput(input) {
        var cursorPos = input.selectionStart;
        var oldLen = input.value.length;
        var raw = input.value.replace(/[^0-9.\-]/g, '');
        input.value = formatWithCommas(raw);
        var newLen = input.value.length;
        input.selectionStart = input.selectionEnd = cursorPos + (newLen - oldLen);
    }
    function formatAndCalc(input) {
        formatCommaInput(input);
        sourceQtyChanged(input);
    }
    function formatAndPrice(input) {
        formatCommaInput(input);
        priceChanged(input);
    }
    // Strip commas before form submission so server gets clean numbers
    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('voucherForm');
        if (form) {
            // Normalize quantity inputs to avoid culture traps.
            // Quy ước nhập liệu:
            // - Nếu có 3 chữ số sau một dấu phân cách duy nhất thì xem là phân tách hàng nghìn (1,000 => 1000)
            // - Nếu có 1-2 chữ số sau một dấu phân cách duy nhất thì xem là phần thập phân (10.50 => 10.5)
            function normalizeQtyForPost(val) {
                if (!val) return '';
                let s = val.toString().trim();
                if (!s) return '';
                // keep digits, dot, comma, minus
                s = s.replace(/[^0-9.,\-]/g, '');
                if (!s) return '';

                const hasDot = s.indexOf('.') >= 0;
                const hasComma = s.indexOf(',') >= 0;
                let normalized = s;

                if (hasDot && hasComma) {
                    // If both exist, assume the last one is decimal separator
                    const lastDot = s.lastIndexOf('.');
                    const lastComma = s.lastIndexOf(',');
                    const decIsDot = lastDot > lastComma;
                    if (decIsDot) normalized = s.replace(/,/g, '');
                    else normalized = s.replace(/\./g, '').replace(',', '.');
                } else if (hasDot || hasComma) {
                    const sep = hasDot ? '.' : ',';
                    const parts = s.split(sep);
                    if (parts.length > 2) {
                        // multiple separators => thousands
                        normalized = s.replace(/[.,]/g, '');
                    } else {
                        const frac = parts[1] ?? '';
                        if (frac.length === 3) {
                            // 1,000 or 1.000 => thousands
                            normalized = s.replace(/[.,]/g, '');
                        } else if (frac.length === 0) {
                            normalized = parts[0];
                        } else if (frac.length <= 2) {
                            // decimal
                            normalized = parts[0] + '.' + frac;
                        } else {
                            // ambiguous long fraction -> treat as thousands to be safe
                            normalized = s.replace(/[.,]/g, '');
                        }
                    }
                }

                normalized = normalized.replace(/(?!^)-/g, '');
                const n = parseFloat(normalized);
                if (isNaN(n)) return '';
                return n.toString();
            }
            form.addEventListener('submit', function() {
                // Quantities: normalize aggressively
                form.querySelectorAll('.qty-input, .dest-qty-input, .defect-input').forEach(function(inp) {
                    inp.value = normalizeQtyForPost(inp.value);
                });
                // Prices: keep old behavior (commas only) to preserve meaning of "10.000" = 10k if user ever types dots
                form.querySelectorAll('.cost-input').forEach(function(inp) {
                    inp.value = inp.value.replace(/,/g, '');
                });
            });
        }
    });
    // ============================================================
    // HỆ THỐNG QUÉT MÃ VẠCH CẤP DOANH NGHIỆP
    // Hỗ trợ: thiết bị quét USB/Bluetooth, camera điện thoại, nhập tay
    // ============================================================

    let lineIdx = @(Model.Lines?.Count ?? 1);
    let totalScanned = 0;

    // --- WEB AUDIO BEEP (instant, no external dependency) ---
    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    let _audioCtx = null;

    function playBeep(frequency = 1200, duration = 150, type = 'square') {
        try {
            if (!_audioCtx) _audioCtx = new AudioCtx();
            const osc = _audioCtx.createOscillator();
            const gain = _audioCtx.createGain();
            osc.type = type;
            osc.frequency.value = frequency;
            gain.gain.value = 0.3;
            osc.connect(gain);
            gain.connect(_audioCtx.destination);
            osc.start();
            gain.gain.exponentialRampToValueAtTime(0.001, _audioCtx.currentTime + duration / 1000);
            osc.stop(_audioCtx.currentTime + duration / 1000);
        } catch (e) { /* Audio not supported */ }
    }

    function beepSuccess() {
        playBeep(1200, 100, 'square');
        setTimeout(() => playBeep(1600, 100, 'square'), 120);
    }

    function beepError() {
        playBeep(300, 300, 'sawtooth');
    }

    function beepDuplicate() {
        playBeep(800, 80, 'square');
    }

    // --- TOAST NOTIFICATION ---
    function showScanToast(message, type = 'success') {
        const toast = document.getElementById('scanToast');
        if (!toast) return;
        toast.textContent = message;
        toast.classList.remove('scan-toast-success', 'scan-toast-duplicate', 'scan-toast-error');
        toast.classList.add('is-visible', type === 'success' ? 'scan-toast-success' : (type === 'duplicate' ? 'scan-toast-duplicate' : 'scan-toast-error'));
        clearTimeout(toast._hideTimer);
        toast._hideTimer = setTimeout(() => {
            toast.classList.remove('is-visible', 'scan-toast-success', 'scan-toast-duplicate', 'scan-toast-error');
        }, 3000);
    }

    // --- SCAN COUNTER ---
    function updateScanCount() {
        totalScanned++;
        const badge = document.getElementById('scanCount');
        if (badge) {
            badge.textContent = totalScanned + ' đã quét';
            badge.style.display = 'inline-block';
        }
    }

    // --- ROW MANAGEMENT ---
    function refreshLineNumbers() {
        const rows = document.querySelectorAll('#linesContainer .line-row');
        rows.forEach((r, idx) => {
            const cell = r.querySelector('.line-no');
            if (cell) cell.textContent = (idx + 1).toString();
        });
    }

    // Gắn sự kiện cho các dòng có sẵn
    document.querySelectorAll('.line-row').forEach(row => {
        const qtyInput = row.querySelector('.qty-input');
        if (qtyInput) qtyInput.addEventListener('input', function() { formatAndCalc(this); });
    });
    refreshLineNumbers();

    // Override addRow để gắn sự kiện cho dòng mới thêm
    window.addRow = function() {
        // Hủy select2 trước khi clone để tránh lỗi giao diện
        $('.item-select, .source-uom-select, select[name="PartnerId"]').each(function() {
            if ($(this).hasClass("select2-hidden-accessible")) {
                $(this).select2('destroy');
            }
        });

        const tbody = document.getElementById('linesContainer');
        const newRow = document.querySelector('.line-row').cloneNode(true);
        newRow.querySelectorAll('[name]').forEach(el => {
            el.name = el.name.replace(/\[\d+\]/, `[${lineIdx}]`);
            if (el.tagName === 'INPUT') {
                if(el.className.includes('loc-input')) el.value = '';
                else if(el.type === 'hidden') { /* keep hidden defaults */ }
                else el.value = '';
            } else if (el.tagName === 'SELECT') {
                if(el.className.includes('item-select')) el.value = '';
                if(el.className.includes('source-uom-select')) el.value = '';
            }
        });
        // Reset dest-uom-select (no name attribute)
        const destUom = newRow.querySelector('.dest-uom-select');
        if (destUom) destUom.value = '';
        const destQty = newRow.querySelector('.dest-qty-input');
        if (destQty) destQty.value = '';
        
        // Gắn sự kiện cho dòng mới (with comma formatting)
        const sourceUomSelect = newRow.querySelector('.source-uom-select');
        if (sourceUomSelect) {
            resetSourceUomOptions(sourceUomSelect);
        }

        tbody.appendChild(newRow);
        lineIdx++;

        // Khởi tạo lại select2 cho tất cả
        initSelect2();
        refreshLineNumbers();
    };

    // === DELETE ROW ===
    window.deleteRow = function(btn) {
        const row = btn.closest('tr');
        const tbody = document.getElementById('linesContainer');
        const rows = tbody.querySelectorAll('.line-row');
        if (rows.length <= 1) {
            Swal.fire('Cảnh Báo', 'Phải có ít nhất 1 dòng chi tiết!', 'warning');
            return;
        }
        // Destroy select2 before removing
        $('.item-select, .source-uom-select').each(function() {
            if ($(this).hasClass('select2-hidden-accessible')) {
                $(this).select2('destroy');
            }
        });
        row.remove();
        // Re-index remaining rows
        const remainingRows = tbody.querySelectorAll('.line-row');
        remainingRows.forEach((r, idx) => {
            r.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/\[\d+\]/, `[${idx}]`);
            });
        });
        lineIdx = remainingRows.length;
        // Reinit select2
        initSelect2();
        refreshLineNumbers();
    };

    const itemAllowedSourceUoms = @Html.Raw(itemAllowedSourceUomsJson);
    const allSourceUomOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Uoms.Select(u => new
        {
            id = u.UomId,
            text = $"{u.UomCode} - {u.UomName}",
            group = u.UomGroup
        }).ToList()
    ));
    const isInboundVoucherJs = @(isInbound ? "true" : "false");
    const isExportVoucherJs = @(Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatKho ? "true" : "false");

    function getCurrentWarehouseId() {
        return parseInt(document.querySelector('input[name="WarehouseId"]')?.value || '0');
    }

    function buildWarehouseQuery() {
        const warehouseId = getCurrentWarehouseId();
        return warehouseId > 0 ? `&warehouseId=${warehouseId}` : '';
    }

    async function fetchJsonOrThrow(url, defaultMessage) {
        const response = await fetch(url);
        const raw = await response.text();
        let data = null;

        if (raw) {
            try {
                data = JSON.parse(raw);
            } catch {
                if (response.ok) {
                    throw new Error(defaultMessage || 'Server trả về dữ liệu không hợp lệ.');
                }
            }
        }

        if (!response.ok) {
            const message = (data && (data.message || data.error)) || raw || defaultMessage || 'Không thể tải dữ liệu.';
            throw new Error(message);
        }

        if (data === null) {
            throw new Error(defaultMessage || 'Server không trả về JSON hợp lệ.');
        }

        return data;
    }

    function getSourceUomPlaceholder(sourceUomSelect) {
        return sourceUomSelect?.dataset?.placeholderText || '-- Chọn đơn vị --';
    }

    function rebuildSourceUomOptions(sourceUomSelect, allowedUomIds, selectedValue) {
        if (!sourceUomSelect) return '';

        const allowedSet = new Set((allowedUomIds || []).map(x => x.toString()));
        const nextValue = selectedValue?.toString() || '';
        const hadSelect2 = $(sourceUomSelect).hasClass('select2-hidden-accessible');
        const resolvedValue = allowedSet.has(nextValue) ? nextValue : (allowedUomIds?.[0]?.toString() || '');

        if (hadSelect2) {
            $(sourceUomSelect).select2('destroy');
        }

        sourceUomSelect.innerHTML = '';
        sourceUomSelect.appendChild(new Option(getSourceUomPlaceholder(sourceUomSelect), ''));

        allSourceUomOptions
            .filter(uom => allowedSet.has(uom.id.toString()))
            .forEach(uom => {
                const option = new Option(uom.text, uom.id);
                option.dataset.group = uom.group || '';
                sourceUomSelect.appendChild(option);
            });

        sourceUomSelect.value = resolvedValue;

        if (hadSelect2) {
            $(sourceUomSelect).select2({ width: '100%', dropdownAutoWidth: true });
            $(sourceUomSelect).val(resolvedValue).trigger('change.select2');
        }

        return resolvedValue;
    }

    function resetSourceUomOptions(sourceUomSelect) {
        return rebuildSourceUomOptions(sourceUomSelect, [], '');
    }

    function filterSourceUomOptions(sourceUomSelect, itemId, baseUomId) {
        if (!sourceUomSelect) return '';

        const allowedUomIds = Array.from(new Set([
            ...((itemAllowedSourceUoms[itemId] || []).map(x => x.toString())),
            ...(baseUomId ? [baseUomId.toString()] : [])
        ]));

        const selectedValue = allowedUomIds.includes(sourceUomSelect.value)
            ? sourceUomSelect.value
            : (baseUomId ? baseUomId.toString() : (allowedUomIds[0] || ''));

        return rebuildSourceUomOptions(sourceUomSelect, allowedUomIds, selectedValue);
    }

    function itemChanged(select) {
        const opt = select.selectedOptions[0];
        const row = select.closest('tr');
        const locSelect = row.querySelector('.loc-select');
        if (opt.value) {
            // Set ĐV Đích = item's base UoM (auto-select, disabled)
            const destUomSelect = row.querySelector('.dest-uom-select');
            if (destUomSelect) {
                destUomSelect.value = opt.dataset.uom || '';
            }
            
            // Default source UoM cũng là base UoM
            const sourceUomSelect = row.querySelector('.source-uom-select');
            if (sourceUomSelect) {
                const selectedUom = filterSourceUomOptions(sourceUomSelect, opt.value, opt.dataset.uom || '');
                if (selectedUom) {
                    sourceUomSelect.value = selectedUom;
                } else if (typeof enterpriseNotify === 'function') {
                    enterpriseNotify({
                        title: 'Thiếu đơn vị nhập',
                        text: 'Vật tư này chưa có đơn vị cơ sở hoặc bảng quy đổi hợp lệ. Vui lòng kiểm tra danh mục vật tư trước khi lưu phiếu.',
                        icon: 'warning'
                    });
                }
            }

            // Auto-fill Putaway Location từ Master Data (Fixed Bin)
            const putawaySelect = row.querySelector('.putaway-loc-select');
            if (putawaySelect && opt.dataset.defaultLoc) {
                putawaySelect.value = opt.dataset.defaultLoc;
                putawaySelect.classList.add('putaway-highlight');
                setTimeout(() => {
                    putawaySelect.classList.remove('putaway-highlight');
                }, 2000);
            }
            
            // Lưu base cost vào row
            let baseCost = parseFloat(opt.dataset.cost || 0);
            row.dataset.baseCost = baseCost;
            
            // Set initial unit price
            let initialPrice = baseCost;
            if (@((int)Model.VoucherType) == 2) { // XuatKho
                const exportMode = document.getElementById('ExportMode')?.value || 1;
                if (exportMode == 2) initialPrice = baseCost * 1.2;
                else initialPrice = 0;
            } else if (@((int)Model.VoucherType) == 1 || @((int)Model.VoucherType) == 8) { // NhapKho || XuatSanXuat
                initialPrice = 0;
            }
            row.querySelector('.cost-input').value = formatWithCommas(initialPrice.toFixed(0));
            
            // Tính SL Đích
            calculateDestQty(row);
            
            const defaultLoc = opt.dataset.defaultLoc;
            if (defaultLoc && defaultLoc !== "" && defaultLoc !== "0") {
                const locInput = row.querySelector('.loc-input');
                if (locInput) {
                    locInput.value = defaultLoc;
                }
            }

            if (locSelect) {
                if (isExportVoucherJs) {
                    filterExportLocations(locSelect, opt.value);
                } else if (isInboundVoucherJs) {
                    limitImportLocations(locSelect, opt.value, defaultLoc);
                }
            }
        } else {
            const sourceUomSelect = row.querySelector('.source-uom-select');
            if (sourceUomSelect) {
                resetSourceUomOptions(sourceUomSelect);
            }
            if (locSelect) {
                locSelect.value = '';
                Array.from(locSelect.options).forEach(optEl => {
                    optEl.style.display = '';
                    optEl.disabled = false;
                });
            }
        }
    }
    
    // Khi user thay đổi ĐV Nguồn → tính lại SL Đích
    function sourceUomChanged(select) {
        const row = select.closest('tr');
        calculateDestQty(row);
    }
    
    // Khi user thay đổi SL Nguồn → tính lại SL Đích
    function sourceQtyChanged(input) {
        const row = input.closest('tr');
        calculateDestQty(row);
    }
    
    // Hệ số quy đổi được lấy từ bảng UnitConversion (item-specific ưu tiên hơn global).
    async function calculateDestQty(row) {
        const destQtyInput = row?.querySelector('.dest-qty-input');
        if (!destQtyInput) return;
        const itemSelect = row.querySelector('.item-select');
        const sourceUomSelect = row.querySelector('.source-uom-select');
        const selectedItem = itemSelect?.selectedOptions?.[0];
        const itemId = selectedItem?.value;
        const baseUomId = selectedItem?.dataset?.uom;
        const fromUomId = sourceUomSelect?.value || baseUomId;
        const toUomId = baseUomId;

        if (!itemId || !fromUomId || !toUomId) {
            destQtyInput.value = '';
            return;
        }

        if (fromUomId === toUomId) {
            destQtyInput.value = formatWithCommas('1');
            return;
        }

        try {
            const data = await fetchJsonOrThrow(`/Vouchers/GetConversionRate?fromUomId=${fromUomId}&toUomId=${toUomId}&itemId=${itemId}`, 'Không tải được hệ số quy đổi.');
            if (!data?.found) {
                destQtyInput.value = '';
                return;
            }
            const rate = Number(data.rate || 0);
            destQtyInput.value = rate > 0 ? formatWithCommas(rate.toString()) : '';
        } catch (err) {
            console.error('Lỗi tính quy đổi:', err);
            destQtyInput.value = '';
        }
    }

    function priceChanged(input) {
        const row = input.closest('tr');
        calculateRowPrice(row);
    }
    
    function calculateRowPrice(row) {
        const itemSelect = row.querySelector('.item-select');
        const itemOpt = itemSelect?.selectedOptions[0];
        if (!itemOpt || !itemOpt.value) return;
        
        if (@((int)Model.VoucherType) == 8) { // XuatSanXuat
            row.querySelector('.cost-input').value = '0';
        } else if (@((int)Model.VoucherType) == 2) { // XuatKho
            const exportMode = document.getElementById('ExportMode')?.value || 1;
            if (exportMode != 2) {
                row.querySelector('.cost-input').value = '0';
            }
        }
    }

    const canSeeFinancialJs = @(canSeeFinancial ? "true" : "false");
    
    function setExportMode(mode) {
        if (!document.getElementById('ExportMode')) return;
        document.getElementById('ExportMode').value = mode;

        // Sync combobox value
        const exportSelect = document.getElementById('exportModeSelect');
        if (exportSelect) exportSelect.value = mode;

        const showPrice = mode === 2 && canSeeFinancialJs;
        document.querySelectorAll('.price-col').forEach(el => el.style.display = showPrice ? 'table-cell' : 'none');

        // Recalculate prices for existing rows
        document.querySelectorAll('.line-row').forEach(row => {
            const costInput = row.querySelector('.cost-input');
            if (!costInput) return;
            if (showPrice) {
                costInput.removeAttribute('readonly');
                // Auto-fill from item UnitCost × 1.2 for external sales
                const itemSelect = row.querySelector('.item-select');
                const selectedOpt = itemSelect?.selectedOptions[0];
                if (selectedOpt && selectedOpt.value) {
                    const baseCost = parseFloat(selectedOpt.dataset.cost || 0);
                    if (!parseCommaNumber(costInput.value)) {
                        costInput.value = formatWithCommas((baseCost * 1.2).toFixed(0));
                    }
                }
            } else {
                costInput.setAttribute('readonly', 'readonly');
                costInput.value = '0';
            }
        });
        // Hiện/ẩn đối tác theo loại xuất
        const partnerDiv = document.getElementById('partnerFieldDiv');
        if (partnerDiv) partnerDiv.style.display = mode === 2 ? 'block' : 'none';
    }

    function initializeExportTabs() {
        if (@((int)Model.VoucherType) == 2) { // XuatKho
            const currentMode = parseInt(document.getElementById('ExportMode')?.value || '1');
            setExportMode(currentMode);
        } else if (@((int)Model.VoucherType) == 1 || @((int)Model.VoucherType) == 8) { // NhapKho || XuatSanXuat
             // Nhập kho (1) và Xuất SX (8): ẩn đơn giá
             document.querySelectorAll('.price-col').forEach(el => el.style.display = 'none');
        } else {
             document.querySelectorAll('.price-col').forEach(el => el.style.display = canSeeFinancialJs ? 'table-cell' : 'none');
        }
    }

    // --- LỌC VỊ TRÍ XUẤT KHO ---
    async function filterExportLocations(locSelect, itemId) {
        if (!locSelect || !itemId) return;
        // Reset trước
        Array.from(locSelect.options).forEach(opt => { opt.style.display = ''; opt.disabled = false; });
        try {
            const data = await fetchJsonOrThrow(`/Warehouses/GetItemLocations?itemId=${itemId}${buildWarehouseQuery()}`, 'Không tải được danh sách vị trí xuất.');
            const occupiedIds = Array.isArray(data) ? data.map(d => d.locationId.toString()) : [];
            Array.from(locSelect.options).forEach(opt => {
                if (!opt.value) return;
                if (occupiedIds.includes(opt.value)) {
                    opt.style.display = '';
                    opt.disabled = false;
                } else {
                    opt.style.display = 'none';
                    opt.disabled = true;
                }
            });
            if (occupiedIds.length === 1) {
                locSelect.value = occupiedIds[0];
            } else if (locSelect.value && !occupiedIds.includes(locSelect.value)) {
                locSelect.value = '';
            }
        } catch (err) {
            console.error('Lỗi tải vị trí vật tư:', err);
        }
    }

    // --- LỌC VỊ TRÍ NHẬP KHO (TỐI ĐA 2 VỊ TRÍ) ---
    async function limitImportLocations(locSelect, itemId, defaultLocId) {
        if (!locSelect || !itemId) return;
        // Ẩn tất cả option (trừ option mặc định rỗng)
        Array.from(locSelect.options).forEach(opt => { 
            if (opt.value !== "") {
                opt.style.display = 'none';
                opt.disabled = true;
            }
        });

        try {
            const data = await fetchJsonOrThrow(`/Warehouses/GetSuggestedLocations?itemId=${itemId}&qty=1${buildWarehouseQuery()}`, 'Không tải được vị trí nhập gợi ý.');
            const suggestions = Array.isArray(data) ? data : [];
            let allowedIds = [];
            if (defaultLocId && defaultLocId !== "0" && defaultLocId !== "") {
                allowedIds.push(defaultLocId.toString());
            }

            for (let i = 0; i < suggestions.length; i++) {
                if (allowedIds.length >= 2) break;
                let locStr = suggestions[i].locationId?.toString();
                if (locStr && !allowedIds.includes(locStr) && !suggestions[i].hasOtherItem) {
                    allowedIds.push(locStr);
                }
            }

            Array.from(locSelect.options).forEach(opt => {
                if (opt.value && allowedIds.includes(opt.value)) {
                    opt.style.display = '';
                    opt.disabled = false;
                }
            });

            if (defaultLocId && allowedIds.includes(defaultLocId.toString()) && (locSelect.value === "" || locSelect.value !== defaultLocId.toString())) {
                locSelect.value = defaultLocId;
            } else if (allowedIds.length > 0 && locSelect.value === "") {
                locSelect.value = allowedIds[0];
            } else if (locSelect.value && !allowedIds.includes(locSelect.value)) {
                locSelect.value = '';
            }
        } catch (err) {
            console.error('Lỗi xử lý vị trí nhập:', err);
        }
    }

