                    <i class="fas fa-spinner fa-spin loc-suggest-loading-icon"></i>
                    <p class="loc-suggest-loading-text">Đang tải dữ liệu...</p>
                </div>
            </div>
        `;
        
        // Lấy dữ liệu thật từ bộ xử lý nội bộ: xuất kho dùng danh sách vị trí đang có hàng, nhập kho dùng gợi ý vị trí cất.
        const isExport = @(Model.VoucherType == WMS.Models.VoucherTypeEnum.XuatKho ? "true" : "false");
        const apiUrl = isExport
            ? `/Warehouses/GetItemLocations?itemId=${itemId}${buildWarehouseQuery()}`
            : `/Warehouses/GetSuggestedLocations?itemId=${itemId}&qty=${qty}${buildWarehouseQuery()}`;
        fetchJsonOrThrow(apiUrl, 'Không tải được dữ liệu gợi ý vị trí.')
            .then(data => {
                data = Array.isArray(data) ? data : [];
                let tableRows = '';

                if (isExport) {
                    // XUẤT KHO: chỉ hiện ô đang chứa vật tư
                    if (data && data.length > 0) {
                        data.forEach(loc => {
                            const locId = safeLocationId(loc.locationId);
                            const locCodeText = escapeDocumentText(loc.locationCode);
                            const locCodeArg = suggestionArg(loc.locationCode);
                            const zoneText = escapeDocumentText(loc.zoneName);
                            const quantityText = formatVnNumber(loc.quantity);
                            const isSelected = String(loc.locationId ?? '') === currentLocId;
                            // FEFO indicators
                            let expiryText = '---';
                            let expiryBadge = '';
                            if (loc.expiryDate) {
                                const dt = new Date(loc.expiryDate);
                                if (!isNaN(dt)) {
                                    const dd = String(dt.getDate()).padStart(2, '0');
                                    const mm = String(dt.getMonth() + 1).padStart(2, '0');
                                    const yyyy = dt.getFullYear();
                                    expiryText = `${dd}/${mm}/${yyyy}`;
                                    const today = new Date();
                                    const daysLeft = Math.ceil((dt - new Date(today.getFullYear(), today.getMonth(), today.getDate())) / (1000 * 60 * 60 * 24));
                                    if (daysLeft <= 0) {
                                        expiryBadge = `<span class="chip chip-danger loc-suggest-chip-offset">Hết hạn</span>`;
                                    } else if (daysLeft <= 30) {
