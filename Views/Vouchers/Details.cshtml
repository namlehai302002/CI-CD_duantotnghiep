@section Scripts {
<script>
    const modalFocusState = new Map();
    function getFocusableElements(container) {
        if (!container) return [];
        return Array.from(container.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
            .filter(el => !el.hasAttribute('disabled') && el.offsetParent !== null);
    }
    function openAppModal(modalId, initialFocusId) {
        const modal = document.getElementById(modalId);
        if (!modal) return;
        modalFocusState.set(modalId, document.activeElement);
        modal.style.display = 'flex';
        const focusTarget = initialFocusId ? document.getElementById(initialFocusId) : null;
        const focusables = getFocusableElements(modal);
        (focusTarget || focusables[0])?.focus();
    }
    function closeAppModal(modalId) {
        const modal = document.getElementById(modalId);
        if (!modal) return;
        modal.style.display = 'none';
        const previous = modalFocusState.get(modalId);
        if (previous && typeof previous.focus === 'function') previous.focus();
    }
    function trapModalFocus(modalId, e) {
        if (e.key !== 'Tab') return;
        const modal = document.getElementById(modalId);
        if (!modal || modal.style.display !== 'flex') return;
        const focusables = getFocusableElements(modal);
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
        }
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            ['dockModal', 'rejectModal', 'shippingModal', 'packingModal'].forEach((id) => {
                const modal = document.getElementById(id);
                if (modal?.style.display === 'flex') closeAppModal(id);
            });
            return;
        }
        ['dockModal', 'rejectModal', 'shippingModal', 'packingModal'].forEach((id) => trapModalFocus(id, e));
    });

    // Kiểm kho & tăng tồn
    document.getElementById('approveBtn')?.addEventListener('click', function() {
        const rows = Array.from(document.querySelectorAll('table tbody tr'));
        let totalTrans = 0;
        let totalDefectTrans = 0;
        let totalBase = 0;
        let totalDefectBase = 0;
        for (const r of rows) {
            const cells = r.querySelectorAll('td');
            if (!cells || cells.length === 0) continue;

            // Ưu tiên lấy từ data attribute để tránh lệch khi format số.
            const baseCell = r.querySelector('[data-base-qty]') || null;
            const defectCell = r.querySelector('[data-defect-qty]') || null;
            const transCell = r.querySelector('[data-trans-qty]') || null;
            const defectTransCell = r.querySelector('[data-defect-trans-qty]') || null;
            const parseNum = (t) => {
                if (!t) return 0;
                let s = ('' + t).trim();
                if (!s) return 0;
                // keep digits and common separators only
                s = s.replace(/[^0-9,.\-]/g, '');
                if (!s || s === '-' || s === ',' || s === '.') return 0;

                const hasDot = s.indexOf('.') >= 0;
                const hasComma = s.indexOf(',') >= 0;

                // Decide decimal separator:
                // - If both exist, the last one is assumed to be decimal
                // - If only one exists:
                //    - multiple occurrences => thousands separators
                //    - single occurrence:
                //        - 3 digits after => likely thousands
                //        - otherwise => decimal
                let normalized = s;
                if (hasDot && hasComma) {
                    const lastDot = s.lastIndexOf('.');
                    const lastComma = s.lastIndexOf(',');
                    const decIsDot = lastDot > lastComma;
                    if (decIsDot) {
                        normalized = s.replace(/,/g, '');
                    } else {
                        normalized = s.replace(/\./g, '').replace(',', '.');
                    }
                } else if (hasDot || hasComma) {
                    const sep = hasDot ? '.' : ',';
                    const parts = s.split(sep);
                    if (parts.length > 2) {
                        // many separators => thousands
                        normalized = s.replace(/[.,]/g, '');
                    } else {
                        const frac = parts[1] || '';
                        if (frac.length === 3 && parts[0].length >= 1) {
                            // 1.000 / 10,000 => thousands
                            normalized = s.replace(/[.,]/g, '');
                        } else {
                            // treat as decimal
                            normalized = parts[0] + '.' + frac;
                        }
                    }
                }

                // remove any stray minus signs except leading
                normalized = normalized.replace(/(?!^)-/g, '');
                const n = parseFloat(normalized);
                return isNaN(n) ? 0 : n;
            };

            const base = baseCell ? parseNum(baseCell.getAttribute('data-base-qty')) : 0;
            const defectBase = defectCell ? parseNum(defectCell.getAttribute('data-defect-qty')) : 0;
            const trans = transCell ? parseNum(transCell.getAttribute('data-trans-qty')) : 0;
            const defectTrans = defectTransCell ? parseNum(defectTransCell.getAttribute('data-defect-trans-qty')) : 0;

            totalBase += base;
            totalDefectBase += defectBase;
            totalTrans += trans;
            totalDefectTrans += defectTrans;
        }
        const totalGoodTrans = Math.max(0, totalTrans - totalDefectTrans);
        const totalGoodBase = Math.max(0, totalBase - totalDefectBase);
        const hasConversion = Math.abs(totalBase - totalTrans) > 0.000001 || Math.abs(totalDefectBase - totalDefectTrans) > 0.000001;

        Swal.fire({
            title: 'Xác nhận tăng tồn?',
            html: '<div class="voucher-review-confirm">' +
                  '<div class="voucher-review-summary"><i class="fas fa-check-circle success-icon"></i> Hệ thống sẽ <b>cộng tồn kho</b> theo số lượng thực nhận.</div>' +
                  '<div class="voucher-review-note">' +
                  '<div><b>Tổng SL chứng từ:</b> ' + (totalTrans || 0).toLocaleString('vi-VN') + '</div>' +
                  '<div><b>SL tăng tồn (ĐVT tồn):</b> <span class="voucher-review-good">' + (totalGoodBase || 0).toLocaleString('vi-VN') + '</span></div>' +
                  (hasConversion
                      ? ('<div class="voucher-review-muted">' +
                         '<i class="fas fa-exchange-alt"></i> SL tăng tồn (ĐVT giao dịch): ' +
                         (totalGoodTrans || 0).toLocaleString('vi-VN') +
                         '</div>')
                      : '') +
                  '</div>' +
                  '<div class="voucher-review-hint"><i class="fas fa-info-circle"></i> Sai lệch nếu có đã được nhập ở từng dòng bằng nút Lưu lệch.</div>' +
                  '<div class="voucher-review-hint"><i class="fas fa-user-check"></i> Người kiểm phải khác người lập phiếu.</div>' +
                  '</div>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '<i class="fas fa-check-double"></i> Xác nhận tăng tồn',
            cancelButtonText: '<i class="fas fa-times"></i> Hủy',
            confirmButtonColor: '#10b981',
            cancelButtonColor: '#6b7280'
        }).then((result) => {
            if (result.isConfirmed) {
                const hasDefect = totalDefectBase > 0.000001 || totalDefectTrans > 0.000001;
                const data = hasDefect
                    ? {
                        reviewResult: 3,
                        responsibilityScore: 1,
                        reviewNote: 'Đã có sai lệch và đã lưu chỉnh tại dòng chi tiết trước khi tăng tồn.'
                    }
                    : {
                        reviewResult: 2,
                        responsibilityScore: 0,
                        reviewNote: 'Đạt - không sai lệch.'
                    };
                const reviewResultInput = document.getElementById('reviewResultInput');
                const responsibilityScoreInput = document.getElementById('responsibilityScoreInput');
                const reviewNoteInput = document.getElementById('reviewNoteInput');
                if (reviewResultInput) reviewResultInput.value = String(data.reviewResult);
                if (responsibilityScoreInput) responsibilityScoreInput.value = String(data.responsibilityScore);
                if (reviewNoteInput) reviewNoteInput.value = data.reviewNote || '';
                document.getElementById('approveForm').submit();
            }
        });
    });

    // Toggle ô nhập lý do khi chọn "Lý do khác"
    function toggleCancelReasonInput() {
        const sel = document.getElementById('cancelReasonCodeSelect');
        const inp = document.getElementById('cancelReasonInput');
        if (sel && inp) {
            inp.classList.toggle('d-none', sel.value !== '99');
            if (sel.value !== '99') inp.value = '';
        }
    }
    toggleCancelReasonInput();

    // Hủy phiếu
    document.getElementById('cancelBtn')?.addEventListener('click', function() {
        const codeSelect = document.getElementById('cancelReasonCodeSelect');
        const reason = document.getElementById('cancelReasonInput').value.trim();
        // Chỉ bắt buộc nhập chi tiết khi chọn "Lý do khác"
        if (codeSelect.value === '99' && !reason) {
            Swal.fire({
                title: 'Thiếu lý do!',
                text: 'Bạn chọn "Lý do khác" — vui lòng nhập chi tiết lý do hủy.',
                icon: 'warning',
                confirmButtonText: 'Đã hiểu',
                confirmButtonColor: '#f59e0b'
            });
            return;
        }
        Swal.fire({
            title: 'Hủy phiếu này?',
            html: '<div class="voucher-cancel-confirm">' +
                  '<i class="fas fa-exclamation-triangle danger-icon"></i> Hủy phiếu sẽ <b>hoàn tác</b> toàn bộ tồn kho đã ghi nhận<br>' +
                  '<i class="fas fa-undo warning-icon"></i> Tất cả số lượng sẽ được trả về trạng thái trước phiếu</div>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<i class="fas fa-trash"></i> Xác nhận hủy',
            cancelButtonText: '<i class="fas fa-times"></i> Không hủy',
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('cancelForm').submit();
            }
        });
    });
    const voucherActionUrls = {
        rejectInbound: '@Url.Action("RejectInbound", "Vouchers")',
        assignDock: '@Url.Action("AssignDock", "Vouchers")',
        confirmPacking: '@Url.Action("ConfirmPacking", "Vouchers")',
        confirmShipping: '@Url.Action("ConfirmShipping", "Vouchers")'
    };

    // Từ chối phiếu nhập bằng hộp thoại chuẩn
    function openRejectDialog() {
        const input = document.getElementById('rejectReasonInput');
        const validation = document.getElementById('rejectValidation');
        if (validation) validation.textContent = '';
        if (input) input.value = '';
        openAppModal('rejectModal', 'rejectReasonInput');
    }
    function closeRejectDialog() {
        closeAppModal('rejectModal');
    }
    function appendHiddenInput(form, name, value) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = name;
        input.value = value ?? '';
        form.appendChild(input);
    }
    function submitRejectDialog() {
        const reason = document.getElementById('rejectReasonInput')?.value?.trim() || '';
        const validation = document.getElementById('rejectValidation');
        if (!reason) {
            if (validation) validation.textContent = 'Vui lòng nhập lý do từ chối.';
            return;
        }
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = voucherActionUrls.rejectInbound;
        const token = document.querySelector('input[name=__RequestVerificationToken]').value;
        appendHiddenInput(form, '__RequestVerificationToken', token);
        appendHiddenInput(form, 'id', '@Model.VoucherId');
        appendHiddenInput(form, 'rejectionReason', reason);
        document.body.appendChild(form);
        form.submit();
    }
    document.getElementById('rejectBtn')?.addEventListener('click', openRejectDialog);
    document.getElementById('rejectCancelBtn')?.addEventListener('click', closeRejectDialog);
    document.getElementById('rejectSubmitBtn')?.addEventListener('click', submitRejectDialog);
    document.getElementById('rejectModal')?.addEventListener('click', function(e) { if (e.target === this) closeRejectDialog(); });

    // Gán cửa nhận hàng bằng hộp thoại chuẩn
    const dockSeed = {
        expectedArrivalAt: '@((Model.ExpectedArrivalAt?.ToString("yyyy-MM-ddTHH:mm")) ?? "")',
        dockAppointmentStart: '@((Model.DockAppointmentStart?.ToString("yyyy-MM-ddTHH:mm")) ?? "")',
        dockAppointmentEnd: '@((Model.DockAppointmentEnd?.ToString("yyyy-MM-ddTHH:mm")) ?? "")',
        dockDoor: '@(Model.DockDoor ?? "")',
        carrierName: '@(Model.CarrierName ?? "")',
        vehicleNumber: '@(Model.VehicleNumber ?? "")',
        driverName: '@(Model.DriverName ?? "")',
        driverPhone: '@(Model.DriverPhone ?? "")'
    };
    function openDockDialog() {
        Object.keys(dockSeed).forEach((k) => {
            const input = document.getElementById(`dock-${k}`);
            if (input) input.value = dockSeed[k] || '';
        });
        document.getElementById('dockValidation').textContent = '';
        openAppModal('dockModal', 'dock-expectedArrivalAt');
    }
    function closeDockDialog() {
        closeAppModal('dockModal');
    }
    function submitDockDialog() {
        const expectedArrivalAt = document.getElementById('dock-expectedArrivalAt').value;
        const dockAppointmentStart = document.getElementById('dock-dockAppointmentStart').value;
        const dockAppointmentEnd = document.getElementById('dock-dockAppointmentEnd').value;
        const dockDoor = document.getElementById('dock-dockDoor').value;
        const carrierName = document.getElementById('dock-carrierName').value;
        const vehicleNumber = document.getElementById('dock-vehicleNumber').value;
        const driverName = document.getElementById('dock-driverName').value;
        const driverPhone = document.getElementById('dock-driverPhone').value;
        const validation = document.getElementById('dockValidation');
        validation.textContent = '';

        if (!expectedArrivalAt) {
            validation.textContent = 'Vui lòng nhập giờ xe đến dự kiến.';
            return;
        }
        if ((dockAppointmentStart && !dockAppointmentEnd) || (!dockAppointmentStart && dockAppointmentEnd)) {
            validation.textContent = 'Khung giờ nhận hàng phải có đủ giờ bắt đầu và giờ kết thúc.';
            return;
        }

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = voucherActionUrls.assignDock;
        const token = document.querySelector('input[name=__RequestVerificationToken]').value;
        appendHiddenInput(form, '__RequestVerificationToken', token);
        appendHiddenInput(form, 'id', '@Model.VoucherId');
        appendHiddenInput(form, 'expectedArrivalAt', expectedArrivalAt);
        appendHiddenInput(form, 'dockAppointmentStart', dockAppointmentStart);
        appendHiddenInput(form, 'dockAppointmentEnd', dockAppointmentEnd);
        appendHiddenInput(form, 'dockDoor', dockDoor);
        appendHiddenInput(form, 'carrierName', carrierName);
        appendHiddenInput(form, 'vehicleNumber', vehicleNumber);
        appendHiddenInput(form, 'driverName', driverName);
        appendHiddenInput(form, 'driverPhone', driverPhone);
        document.body.appendChild(form);
        form.submit();
    }
    document.getElementById('assignDockBtn')?.addEventListener('click', openDockDialog);
    document.getElementById('dockModal')?.addEventListener('click', function(e) { if (e.target === this) closeDockDialog(); });
    document.getElementById('dockCancelBtn')?.addEventListener('click', closeDockDialog);
    document.getElementById('dockSubmitBtn')?.addEventListener('click', submitDockDialog);

    // Đóng gói
    function openPackingDialog() {
        const validation = document.getElementById('packingValidation');
        if (validation) validation.textContent = '';
        openAppModal('packingModal', 'packingPackageType');
        updatePackingSummary();
        return false;
    }
    function closePackingDialog() {
        closeAppModal('packingModal');
    }
    function updatePackingSummary() {
        const packageType = document.getElementById('packingPackageType')?.value || 'Thùng carton';
        const manualCount = parseInt(document.getElementById('packingManualCount')?.value || '0', 10);
        const packageCodes = document.getElementById('packingPackageCodes')?.value || '';
        const lpnCodes = document.getElementById('packingLpnCodes')?.value || '';
        const countLines = (str) => str.trim() ? str.trim().split(/\r?\n/).filter(l => l.trim().length > 0).length : 0;
        const totalCodes = countLines(packageCodes) + countLines(lpnCodes);
        const summary = document.getElementById('packingSummary');
        if (summary) summary.textContent = `Loại kiện: ${packageType} · Số kiện tạo: ${Math.max(0, manualCount)} · Tổng mã quét: ${totalCodes}`;
    }
    function submitPackingDialog() {
        const manualPackageCount = parseInt(document.getElementById('packingManualCount')?.value || '0', 10);
        const packageCodes = document.getElementById('packingPackageCodes')?.value || '';
        const lpnCodes = document.getElementById('packingLpnCodes')?.value || '';
        const packageType = document.getElementById('packingPackageType')?.value || '';
        const packingNote = document.getElementById('packingNote')?.value || '';
        const actualCatchWeight = document.getElementById('packingCatchWeight')?.value || '';
        const requiresCatchWeight = @(requiresCatchWeight ? "true" : "false");
        const validation = document.getElementById('packingValidation');
        if (validation) validation.textContent = '';
        if (requiresCatchWeight && (!(parseFloat(actualCatchWeight) > 0))) {
            if (validation) validation.textContent = 'Phiếu có hàng cân trọng lượng thực tế, vui lòng nhập tổng cân thực tế.';
            return;
        }

        if (manualPackageCount < 0) {
            if (validation) validation.textContent = 'Số kiện thủ công không được âm.';
            return;
        }
        if (manualPackageCount === 0 && !lpnCodes.trim()) {
            if (validation) validation.textContent = 'Vui lòng nhập ít nhất 1 kiện thủ công hoặc 1 mã kiện (LPN).';
            return;
        }

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = voucherActionUrls.confirmPacking;
        const token = document.querySelector('input[name=__RequestVerificationToken]').value;
        appendHiddenInput(form, '__RequestVerificationToken', token);
        appendHiddenInput(form, 'id', '@Model.VoucherId');
        appendHiddenInput(form, 'manualPackageCount', manualPackageCount);
        appendHiddenInput(form, 'packageType', packageType);
        appendHiddenInput(form, 'packageCodes', packageCodes);
        appendHiddenInput(form, 'lpnCodes', lpnCodes);
        appendHiddenInput(form, 'packingNote', packingNote);
        appendHiddenInput(form, 'actualCatchWeight', actualCatchWeight);
        document.body.appendChild(form);
        form.submit();
    }
    document.getElementById('packingPackageType')?.addEventListener('change', updatePackingSummary);
    document.getElementById('packingManualCount')?.addEventListener('input', updatePackingSummary);
    document.getElementById('packingPackageCodes')?.addEventListener('input', updatePackingSummary);
    document.getElementById('packingLpnCodes')?.addEventListener('input', updatePackingSummary);
    document.getElementById('packingCancelBtn')?.addEventListener('click', closePackingDialog);
    document.getElementById('packingSubmitBtn')?.addEventListener('click', submitPackingDialog);
    document.getElementById('packingModal')?.addEventListener('click', function(e) { if (e.target === this) closePackingDialog(); });

    // Giao hàng bằng hộp thoại chuẩn
    function openShippingDialog() {
        openAppModal('shippingModal', 'shippingTrackingInput');
    }
    function closeShippingDialog() {
        closeAppModal('shippingModal');
    }
    function submitShippingDialog() {
        const tracking = document.getElementById('shippingTrackingInput')?.value || '';
        const manifest = document.getElementById('shippingManifestInput')?.value || '';
        const handoverNote = document.getElementById('shippingNoteInput')?.value || '';
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = voucherActionUrls.confirmShipping;
        const token = document.querySelector('input[name=__RequestVerificationToken]').value;
        appendHiddenInput(form, '__RequestVerificationToken', token);
        appendHiddenInput(form, 'id', '@Model.VoucherId');
        appendHiddenInput(form, 'trackingNumber', tracking);
        appendHiddenInput(form, 'manifestCode', manifest);
        appendHiddenInput(form, 'handoverNote', handoverNote);
        document.body.appendChild(form);
        form.submit();
    }
    document.getElementById('shipBtn')?.addEventListener('click', openShippingDialog);
    document.getElementById('shippingCancelBtn')?.addEventListener('click', closeShippingDialog);
    document.getElementById('shippingSubmitBtn')?.addEventListener('click', submitShippingDialog);
    document.getElementById('shippingModal')?.addEventListener('click', function(e) { if (e.target === this) closeShippingDialog(); });

</script>
}
