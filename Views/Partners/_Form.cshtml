@model WMS.Models.Partner

<form method="post">
    @Html.AntiForgeryToken()
    <div class="form-section-title">Thông tin định danh</div>
    <div class="form-grid">
        <div class="form-group">
            <label class="form-label" for="PartnerCode">Mã đối tác *</label>
            <input id="PartnerCode" type="text" name="PartnerCode" class="form-control" value="@Model.PartnerCode" required placeholder="VD: NCC-001" />
            <span asp-validation-for="PartnerCode" class="text-danger"></span>
        </div>
        <div class="form-group form-span-2">
            <label class="form-label" for="PartnerName">Tên đối tác *</label>
            <input id="PartnerName" type="text" name="PartnerName" class="form-control" value="@Model.PartnerName" required placeholder="VD: Công ty cổ phần vật liệu X" />
            <span asp-validation-for="PartnerName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label" for="PartnerType">Phân loại *</label>
            <select id="PartnerType" name="PartnerType" class="form-control" required>
                <option value="1" selected="@(Model.PartnerType == WMS.Models.PartnerTypeEnum.Supplier)">Nhà cung cấp</option>
                <option value="2" selected="@(Model.PartnerType == WMS.Models.PartnerTypeEnum.Customer)">Khách hàng</option>
                <option value="3" selected="@(Model.PartnerType == WMS.Models.PartnerTypeEnum.Both)">Vừa là nhà cung cấp vừa là khách hàng</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label" for="TaxCode">Mã số thuế</label>
            <input id="TaxCode" type="text" name="TaxCode" class="form-control" value="@Model.TaxCode" placeholder="Mã số thuế nếu có" />
        </div>
    </div>

    <div class="form-section-title">Thông tin giao dịch</div>
    <div class="form-grid">
        <div class="form-group form-span-2">
            <label class="form-label" for="Address">Địa chỉ đăng ký hoặc nhận hàng</label>
            <input id="Address" type="text" name="Address" class="form-control" value="@Model.Address" placeholder="Địa chỉ dùng trên chứng từ và bàn giao" />
        </div>
        <div class="form-group">
            <label class="form-label" for="ContactPerson">Người liên hệ</label>
            <input id="ContactPerson" type="text" name="ContactPerson" class="form-control" value="@Model.ContactPerson" placeholder="Tên người phụ trách" />
        </div>
        <div class="form-group">
            <label class="form-label" for="Phone">Điện thoại</label>
            <input id="Phone" type="text" name="Phone" class="form-control" value="@Model.Phone" placeholder="Số điện thoại liên hệ" />
        </div>
        <div class="form-group">
            <label class="form-label" for="Email">Thư điện tử</label>
            <input id="Email" type="email" name="Email" class="form-control" value="@Model.Email" placeholder="ten@congty.vn" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>

    <div class="form-section-title">Đánh giá nhà cung cấp</div>
    <div class="form-grid">
        <div class="form-group">
            <label class="form-label" for="VendorRating">Hạng nhà cung cấp</label>
            <select id="VendorRating" name="VendorRating" class="form-control">
                <option value="4" selected="@(Model.VendorRating == WMS.Models.VendorRatingEnum.New)">Mới - kiểm tra toàn bộ</option>
                <option value="1" selected="@(Model.VendorRating == WMS.Models.VendorRatingEnum.A)">Hạng A - tin cậy</option>
                <option value="2" selected="@(Model.VendorRating == WMS.Models.VendorRatingEnum.B)">Hạng B - bình thường</option>
                <option value="3" selected="@(Model.VendorRating == WMS.Models.VendorRatingEnum.C)">Hạng C - rủi ro</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label" for="LeadTimeDays">Thời gian giao hàng trung bình</label>
            <input id="LeadTimeDays" type="number" name="LeadTimeDays" class="form-control" value="@(Model.LeadTimeDays?.ToString() ?? "")" placeholder="VD: 7" min="0" />
            <span class="field-hint">Số ngày dự kiến từ khi đặt hàng đến khi nhận.</span>
        </div>
    </div>

    <div class="form-action-row">
        <a asp-controller="Partners" asp-action="Index" class="btn btn-secondary"><i class="fas fa-xmark"></i> Hủy</a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> @(Model.PartnerId == 0 ? "Thêm đối tác" : "Lưu thay đổi")
        </button>
    </div>
</form>
