@model WMS.Models.ItemCategory

<form method="post">
    @Html.AntiForgeryToken()
    <div class="form-section-title">Thông tin danh mục</div>
    <div class="form-grid">
        <div class="form-group">
            <label class="form-label" for="CategoryCode">Mã danh mục *</label>
            <input id="CategoryCode" type="text" name="CategoryCode" class="form-control" value="@Model.CategoryCode" required placeholder="VD: THEP-01" />
            <span asp-validation-for="CategoryCode" class="text-danger"></span>
        </div>
        <div class="form-group form-span-2">
            <label class="form-label" for="CategoryName">Tên danh mục *</label>
            <input id="CategoryName" type="text" name="CategoryName" class="form-control" value="@Model.CategoryName" required placeholder="VD: Thép xây dựng" />
            <span asp-validation-for="CategoryName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label" for="SortOrder">Thứ tự sắp xếp</label>
            <input id="SortOrder" type="number" name="SortOrder" class="form-control" value="@(Model.CategoryId == 0 ? 0 : Model.SortOrder)" />
            <span class="field-hint">Số nhỏ sẽ hiển thị trước trong danh sách chọn.</span>
        </div>
    </div>

    <div class="form-action-row">
        <a asp-controller="Categories" asp-action="Index" class="btn btn-secondary"><i class="fas fa-xmark"></i> Hủy</a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> @(Model.CategoryId == 0 ? "Thêm danh mục" : "Lưu thay đổi")
        </button>
    </div>
</form>
