    var isAdmin = User.IsInRole("Admin");
    var isManager = User.IsInRole("Manager");
    var isStaff = User.IsInRole("Staff");
    var currentRoleKey = isAdmin ? "admin" : isManager ? "manager" : isStaff ? "staff" : "viewer";
    var currentRoleName = isAdmin ? "Quản trị viên" : isManager ? "Quản lý kho" : isStaff ? "Nhân viên kho" : "Chỉ xem";
    var managerOnlyHelpSections = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "vai-tro-phan-quyen",
        "danh-muc",
        "nguoi-dung-thiet-bi"
    };
    var viewerHelpSections = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "bat-dau",
        "ton-kho",
        "ma-kien",
        "so-se-ri",
        "bao-cao",
        "kiem-tra-cuoi-ca"
    };

    bool CanSeeHelpSection(string key)
    {
        if (isAdmin || isManager) return true;
        if (isStaff) return !managerOnlyHelpSections.Contains(key);
        return viewerHelpSections.Contains(key);
    }

    string RoleScopeText(string key)
    {
        if (isAdmin)
            return "Bạn đang ở quyền quản trị: xem toàn bộ hướng dẫn, cấu hình người dùng, phân quyền, danh mục và các luồng vận hành trọng yếu.";
        if (isManager)
            return "Bạn đang ở quyền quản lý kho: xem và xử lý các luồng vận hành, duyệt nghiệp vụ, theo dõi báo cáo, ngoại lệ và cấu hình vận hành được phân quyền.";
        if (isStaff)
            return managerOnlyHelpSections.Contains(key)
                ? "Mục này không hiển thị cho nhân viên kho."
                : "Bạn đang ở quyền nhân viên kho: tập trung vào thao tác nhập, xuất, quét mã, di chuyển, kiểm tra và bàn giao ca theo kho được gán.";
        return "Bạn đang ở quyền chỉ xem: chỉ đọc các nội dung tra cứu và báo cáo được phân quyền, không thực hiện thao tác làm đổi tồn kho.";
    }

    var visibleSections = sections.Where(s => CanSeeHelpSection(s.Key)).ToArray();
}

<div class="page-header">
    <div class="header-content">
        <h1 class="page-title"><i class="fas fa-book-open"></i> Hướng dẫn sử dụng WMS Pro</h1>
        <div class="page-subtitle">Tài liệu vận hành chi tiết theo từng nghiệp vụ, viết để người mới có thể đọc, làm theo và tự kiểm tra kết quả.</div>
    </div>
</div>

<div class="help-workspace">
    <aside class="help-toc" aria-label="Mục lục hướng dẫn">
        <div class="help-toc-title"><i class="fas fa-list-check"></i> Mục lục</div>
        <div class="help-search">
            <i class="fas fa-search"></i>
            <input id="helpSearchInput" type="search" placeholder="Tìm trong hướng dẫn..." autocomplete="off" />
        </div>
        <nav class="help-toc-links">
            @foreach (var helpSection in visibleSections)
            {
                <a href="#help-@helpSection.Key" data-help-link="@helpSection.Key">@helpSection.Title</a>
            }
        </nav>
        <div class="help-toc-note">
            Mỗi mục có thể mở hoặc đóng riêng. Hệ thống nhớ trạng thái trong trình duyệt hiện tại.
        </div>
    </aside>

    <main class="help-content">
        <div class="user-guide">
            <div class="user-guide-title"><i class="fas fa-route"></i> Lộ trình đọc nhanh cho người mới</div>
            <div class="step-list">
                <span class="step-chip">1) Đăng nhập và xác định vai trò</span>
                <span class="step-chip">2) Đọc nhập kho và xuất kho</span>
                <span class="step-chip">3) Thực hành quét mã bằng điện thoại</span>
                <span class="step-chip">4) Kiểm tra ngoại lệ và đối soát cuối ca</span>
            </div>
        </div>

        <div class="help-toolbar">
            <button type="button" class="btn btn-secondary" id="helpExpandAll"><i class="fas fa-plus-square"></i> Mở tất cả</button>
            <button type="button" class="btn btn-secondary" id="helpCollapseAll"><i class="fas fa-minus-square"></i> Đóng tất cả</button>
            <span class="help-toolbar-note"><i class="fas fa-user-shield"></i> Nội dung đang lọc theo quyền: @currentRoleName</span>
        </div>

        <section class="help-accordion" id="helpAccordion" data-help-role="@currentRoleKey">
            @for (var index = 0; index < visibleSections.Length; index++)
            {
                var helpSection = visibleSections[index];
                <details class="help-accordion-item" id="help-@helpSection.Key" data-help-key="@helpSection.Key" @(index == 0 ? "open" : null)>
                    <summary class="help-accordion-summary">
                        <span class="help-section-icon"><i class="fas @helpSection.Icon"></i></span>
                        <span>
                            <span class="help-section-kicker">Phần @(index + 1)</span>
                            <strong>@helpSection.Title</strong>
                        </span>
                        <i class="fas fa-chevron-down help-chevron"></i>
                    </summary>
                    <div class="help-accordion-body">
                        <div class="help-detail-grid">
                            <div class="help-detail-card">
                                <h3>Mục đích</h3>
                                <p>@helpSection.Purpose</p>
                            </div>
                            <div class="help-detail-card">
                                <h3>Bạn được thấy/làm gì</h3>
                                <p>@RoleScopeText(helpSection.Key)</p>
                            </div>
                            <div class="help-detail-card">
                                <h3>Vào màn nào</h3>
                                <p>@helpSection.Screen</p>
                            </div>
                        </div>

                        <div class="help-subsection">
                            <h3>Điều kiện cần có trước khi làm</h3>
                            <ul class="help-check-list">
                                @foreach (var item in helpSection.Prerequisites)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>

                        <div class="help-subsection">
                            <h3>Các bước thao tác chi tiết</h3>
                            <ol class="help-step-list">
                                @foreach (var step in helpSection.Steps)
                                {
                                    <li>@step</li>
                                }
                            </ol>
                        </div>

                        <div class="help-detail-grid">
                            <div class="help-detail-card warning">
                                <h3>Lỗi thường gặp</h3>
                                <ul>
                                    @foreach (var item in helpSection.CommonErrors)
                                    {
                                        <li>@item</li>
                                    }
                                </ul>
                            </div>
                            <div class="help-detail-card success">
                                <h3>Kết quả đúng sau khi hoàn tất</h3>
                                <p>@helpSection.ExpectedResult</p>
                                <h3>Ghi chú an toàn nghiệp vụ</h3>
                                <p>@helpSection.SafetyNote</p>
                            </div>
                        </div>
                    </div>
                </details>
            }
            @if (!visibleSections.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-lock"></i>
                    <h3>Chưa có mục hướng dẫn phù hợp</h3>
                    <p>Tài khoản hiện tại chưa được gán quyền xem hướng dẫn vận hành. Vui lòng liên hệ quản trị viên.</p>
                </div>
            }
        </section>
    </main>
</div>

@section Scripts {
    <script>
        (function () {
            const accordion = document.getElementById('helpAccordion');
            const storageKey = 'wms-help-open-sections-v2-' + (accordion?.dataset?.helpRole || 'viewer');
            const items = Array.from(document.querySelectorAll('.help-accordion-item'));
            const searchInput = document.getElementById('helpSearchInput');

            function readState() {
                try {
                    return JSON.parse(sessionStorage.getItem(storageKey) || '{}');
                } catch {
                    return {};
                }
            }

            function writeState() {
                const state = {};
                items.forEach(item => state[item.dataset.helpKey] = item.open);
                sessionStorage.setItem(storageKey, JSON.stringify(state));
            }

            const saved = readState();
            items.forEach((item, index) => {
                if (Object.prototype.hasOwnProperty.call(saved, item.dataset.helpKey)) {
                    item.open = !!saved[item.dataset.helpKey];
                } else {
                    item.open = index === 0;
                }
                item.addEventListener('toggle', writeState);
            });

            document.getElementById('helpExpandAll')?.addEventListener('click', () => {
                items.forEach(item => item.open = true);
                writeState();
            });

            document.getElementById('helpCollapseAll')?.addEventListener('click', () => {
                items.forEach(item => item.open = false);
                writeState();
            });

            searchInput?.addEventListener('input', () => {
                const keyword = searchInput.value.trim().toLowerCase();
                items.forEach(item => {
                    const matched = !keyword || item.textContent.toLowerCase().includes(keyword);
                    item.hidden = !matched;
                    if (keyword && matched) {
                        item.open = true;
                    }
                });
            });
        })();
    </script>
}
