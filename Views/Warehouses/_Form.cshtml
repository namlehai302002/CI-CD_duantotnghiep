@model WMS.Models.Warehouse
@{
    var managers = ViewBag.ManagerUsers as List<WMS.Models.AppUser> ?? new List<WMS.Models.AppUser>();
}

<form method="post">
    @Html.AntiForgeryToken()
    <div class="form-section-title">Thông tin nhận diện kho</div>
    <div class="form-grid">
        <div class="form-group">
            <label class="form-label" for="WarehouseCode">Mã kho *</label>
            <input id="WarehouseCode" type="text" name="WarehouseCode" class="form-control" value="@Model.WarehouseCode" required placeholder="VD: KHO-CHINH" />
            <span asp-validation-for="WarehouseCode" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label" for="WarehouseName">Tên kho *</label>
            <input id="WarehouseName" type="text" name="WarehouseName" class="form-control" value="@Model.WarehouseName" required placeholder="VD: Kho nguyên vật liệu tổng" />
            <span asp-validation-for="WarehouseName" class="text-danger"></span>
        </div>
    </div>

    <div class="form-section-title">Thông tin vận hành</div>
    <div class="form-grid">
        <div class="form-group form-span-2">
            <label class="form-label" for="Address">Địa chỉ *</label>
            <input id="Address" type="text" name="Address" class="form-control" value="@Model.Address" required placeholder="Số nhà, đường, phường/xã, tỉnh/thành" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label" for="ManagerUserId">Người quản lý kho</label>
            <select id="ManagerUserId" name="ManagerUserId" class="form-control">
                <option value="">Chưa phân công</option>
                @foreach (var u in managers)
                {
                    if (Model.ManagerUserId == u.UserId)
                    {
                        <option value="@u.UserId" selected>@u.FullName (@u.UserName)</option>
                    }
                    else
                    {
                        <option value="@u.UserId">@u.FullName (@u.UserName)</option>
                    }
                }
            </select>
            <span class="field-hint">Chọn quản lý chịu trách nhiệm điều phối và đối soát kho này.</span>
        </div>
        <div class="form-group">
            <label class="form-label" for="Phone">Số điện thoại</label>
            <input id="Phone" type="text" name="Phone" class="form-control" value="@Model.Phone" placeholder="09xxxx..." />
            <span class="field-hint">Dùng khi cần liên hệ nhanh với kho hoặc bảo vệ cổng.</span>
        </div>
    </div>

    <div class="form-action-row">
        <a asp-controller="Warehouses" asp-action="Index" class="btn btn-secondary"><i class="fas fa-xmark"></i> Hủy</a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> @(Model.WarehouseId == 0 ? "Thêm kho" : "Lưu thay đổi")
        </button>
    </div>
</form>
