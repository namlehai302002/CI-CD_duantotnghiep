@model WMS.ViewModels.StockCountPageViewModel
@{
    ViewData["Title"] = "Kiểm kê theo vị trí";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kiểm kê theo vị trí</h1>
        <p class="page-subtitle">Nhập số đếm thực tế theo vị trí và lô hàng, sau đó gửi quản lý duyệt để sinh phiếu điều chỉnh chênh lệch khi cần.</p>
    </div>
</div>

<div class="user-guide">
    <div class="user-guide-title"><i class="fas fa-circle-info"></i> Quy trình chuẩn</div>
    <div class="step-list">
        <span class="step-chip"><i class="fas fa-download"></i> 1) Chọn kho và tải dữ liệu tồn hiện tại.</span>
        <span class="step-chip"><i class="fas fa-keyboard"></i> 2) Nhập số lượng đếm thực tế cho từng dòng.</span>
        <span class="step-chip"><i class="fas fa-save"></i> 3) Lưu nháp phiếu kiểm kê.</span>
        <span class="step-chip"><i class="fas fa-user-check"></i> 4) Quản lý duyệt để tạo phiếu điều chỉnh nếu có chênh lệch.</span>
    </div>
</div>

<form method="get" class="filter-bar">
    <div class="form-group">
        <label class="form-label">Kho *</label>
        <select name="warehouseId" class="form-control" required>
            <option value="">-- Chọn kho --</option>
            @foreach (var w in Model.Warehouses)
            {
                <option value="@w.WarehouseId" selected="@(Model.WarehouseId == w.WarehouseId)">@w.WarehouseCode - @w.WarehouseName</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Ngày kiểm kê</label>
        <input type="date" name="countDate" class="form-control" value="@Model.CountDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="form-group">
        <label class="form-label">&nbsp;</label>
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tải dữ liệu kiểm kê</button>
    </div>
</form>

@if (Model.WarehouseId.HasValue)
{
    <form method="post" asp-controller="Reports" asp-action="StockCountSaveDraft">
        @Html.AntiForgeryToken()
        <input type="hidden" name="WarehouseId" value="@Model.WarehouseId" />
        <input type="hidden" name="CountDate" value="@Model.CountDate.ToString("yyyy-MM-dd")" />

        <div class="card mb-3">
            <div class="card-body">
                <label class="form-label">Ghi chú phiếu kiểm kê</label>
                <input type="text" name="Notes" class="form-control" value="@Model.Notes" placeholder="Ví dụ: Kiểm kê cuối tháng, kiểm kê đột xuất khu A..." />
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Mã vật tư</th>
                        <th>Tên vật tư</th>
                        <th>Vị trí</th>
                        <th>Số lô</th>
                        <th>Hạn dùng</th>
                        <th class="cell-right">@(Model.IsBlindCount ? "SL hệ thống (ẩn)" : "SL hệ thống")</th>
                        <th class="cell-right">SL thực tế</th>
                        <th class="cell-right">@(Model.IsBlindCount ? "---" : "Chênh lệch")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Lines.Any())
                    {
                        <tr><td colspan="8" class="cell-empty cell-empty-md">Không có dữ liệu tồn để kiểm kê cho kho đã chọn.</td></tr>
                    }
                    else
                    {
                        for (var i = 0; i < Model.Lines.Count; i++)
                        {
                            var line = Model.Lines[i];
                            <tr>
                                <td class="td-code">@line.ItemCode<input type="hidden" name="Lines[@i].ItemId" value="@line.ItemId" /></td>
                                <td class="td-name">@line.ItemName</td>
                                <td>@line.LocationCode<input type="hidden" name="Lines[@i].LocationId" value="@line.LocationId" /></td>
                                <td>@(line.LotNumber ?? "-")<input type="hidden" name="Lines[@i].LotNumber" value="@line.LotNumber" /></td>
                                <td>@(line.ExpiryDate?.ToString("dd/MM/yyyy") ?? "-")<input type="hidden" name="Lines[@i].ExpiryDate" value="@line.ExpiryDate?.ToString("yyyy-MM-dd")" /></td>
                                <td class="td-number">@(Model.IsBlindCount ? "***" : line.SystemQty.ToString("#,##0.##"))<input type="hidden" name="Lines[@i].SystemQty" value="@line.SystemQty" /></td>
                                <td class="w-180">
                                    <input type="number" min="0" step="0.0001" class="form-control counted-input" name="Lines[@i].CountedQty" value="@line.CountedQty.ToString("0.####")" />
                                </td>
                                <td class="td-number diff-cell">@(Model.IsBlindCount ? "---" : (line.CountedQty - line.SystemQty).ToString("#,##0.##"))</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Lines.Any())
        {
            <div class="mt-3">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-save"></i> Lưu nháp phiếu kiểm kê
                </button>
            </div>
        }
    </form>

    <div class="card mt-3">
        <div class="card-header">
            <strong>Phiếu kiểm kê trong ngày</strong>
        </div>
        <div class="card-body">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Mã phiếu</th>
                            <th>Người tạo</th>
                            <th>Thời điểm tạo</th>
                            <th>Dòng kiểm / dòng lệch</th>
                            <th>Trạng thái</th>
                            <th>Phiếu điều chỉnh</th>
                            <th class="w-180">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ExistingSheets.Any())
                        {
                            <tr><td colspan="7" class="cell-empty cell-empty-sm">Chưa có phiếu kiểm kê nào trong ngày đã chọn.</td></tr>
                        }
                        else
                        {
                            foreach (var s in Model.ExistingSheets)
                            {
                                var canApprove = s.Status == WMS.Models.StockCountStatusEnum.Draft && (User.IsInRole("Admin") || User.IsInRole("Manager"));
                                var canUnlock = s.Status == WMS.Models.StockCountStatusEnum.Approved && User.IsInRole("Admin");
                                var isApproved = s.Status == WMS.Models.StockCountStatusEnum.Approved;
                                <tr>
                                    <td class="fw-700">#@s.StockCountSheetId</td>
                                    <td>@s.CreatedBy</td>
                                    <td>@s.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@s.TotalLines / <span class="@(s.DiffLines > 0 ? "text-warning fw-700" : "")">@s.DiffLines</span></td>
                                    <td>
                                        @if (isApproved)
                                        {
                                            <span class="chip chip-success"><i class="fas fa-check"></i> Đã duyệt</span>
                                        }
                                        else
                                        {
                                            <span class="chip chip-warning"><i class="fas fa-clock"></i> Chờ duyệt</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(s.VoucherCode))
                                        {
                                            <span class="td-code text-accent fw-600">@s.VoucherCode</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="td-actions">
                                        @if (canApprove)
                                        {
                                            <form id="approveForm-@s.StockCountSheetId" method="post" asp-controller="Reports" asp-action="StockCountApproveDraft" class="d-none">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.StockCountSheetId" />
                                                <input type="hidden" name="approvalReason" id="approveReason-@s.StockCountSheetId" value="" />
                                            </form>
                                            <button type="button" class="btn btn-primary approve-btn" data-id="@s.StockCountSheetId" data-lines="@s.TotalLines" data-diff="@s.DiffLines">
                                                <i class="fas fa-check"></i> Duyệt
                                            </button>
                                        }
                                        @if (canUnlock)
                                        {
                                            <form id="unlockForm-@s.StockCountSheetId" method="post" asp-controller="Reports" asp-action="StockCountUnlockApproved" class="d-none">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.StockCountSheetId" />
                                                <input type="hidden" name="unlockReason" id="unlockReason-@s.StockCountSheetId" value="" />
                                            </form>
                                            <button type="button" class="btn btn-danger unlock-btn" data-id="@s.StockCountSheetId" data-voucher="@(s.VoucherCode ?? "")">
                                                <i class="fas fa-lock-open"></i> Mở khóa
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
document.addEventListener('input', function(e) {
    if (!e.target.classList.contains('counted-input')) return;
    const row = e.target.closest('tr');
    if (!row) return;
    const sysInput = row.querySelector('input[name$=".SystemQty"]');
    const sys = parseFloat(sysInput?.value || '0') || 0;
    const counted = parseFloat(e.target.value || '0') || 0;
    const diff = counted - sys;
    const cell = row.querySelector('.diff-cell');
    if (cell) cell.innerText = diff.toLocaleString('vi-VN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
});

document.querySelectorAll('.approve-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const lines = this.dataset.lines;
        const diff = this.dataset.diff;
        if (typeof Swal === 'undefined') {
            enterprisePrompt({
                title: 'Duyệt phiếu kiểm kê',
                text: 'Nhập lý do duyệt phiếu kiểm kê.',
                inputPlaceholder: 'Lý do duyệt',
                confirmButtonText: 'Duyệt phiếu'
            }).then(reason => {
                if (!reason) return;
                document.getElementById('approveReason-' + id).value = reason;
                document.getElementById('approveForm-' + id).submit();
            });
            return;
        }
        Swal.fire({
            title: 'Duyệt phiếu kiểm kê?',
            html: `<div class="swal-enterprise-body">
                <div><b>Mã phiếu:</b> #${id}</div>
                <div><b>Tổng số dòng:</b> ${lines}</div>
                <div><b>Số dòng chênh lệch:</b> <span class="stockcount-diff-highlight">${diff}</span></div>
                <hr class="swal-enterprise-divider">
                <label class="swal-enterprise-label">Lý do duyệt *</label>
                <input id="swalApproveReason" class="swal2-input swal-enterprise-input" placeholder="Ví dụ: Đã đối chiếu xong, cho phép tạo phiếu điều chỉnh" required>
            </div>`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Duyệt phiếu',
            cancelButtonText: 'Hủy',
            confirmButtonColor: '#3b82f6',
            preConfirm: () => {
                const reason = document.getElementById('swalApproveReason')?.value?.trim();
                if (!reason) {
                    Swal.showValidationMessage('Vui lòng nhập lý do duyệt');
                    return false;
                }
                return reason;
            }
        }).then(r => {
            if (r.isConfirmed && r.value) {
                document.getElementById('approveReason-' + id).value = r.value;
                document.getElementById('approveForm-' + id).submit();
            }
        });
    });
});

document.querySelectorAll('.unlock-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const voucher = this.dataset.voucher;
        if (typeof Swal === 'undefined') {
            enterprisePrompt({
                title: 'Mở khóa phiếu kiểm kê',
                text: 'Nhập lý do mở khóa phiếu kiểm kê.',
                inputPlaceholder: 'Lý do mở khóa',
                confirmButtonText: 'Mở khóa'
            }).then(reason => {
                if (!reason) return;
                document.getElementById('unlockReason-' + id).value = reason;
                document.getElementById('unlockForm-' + id).submit();
            });
            return;
        }
        Swal.fire({
            title: 'Mở khóa phiếu đã duyệt?',
            html: `<div class="swal-enterprise-body">
                <div><b>Mã phiếu kiểm kê:</b> #${id}</div>
                ${voucher ? `<div><b>Phiếu điều chỉnh liên quan:</b> ${voucher}</div>` : ''}
                <div class="swal-enterprise-warning-box">
                    Sau khi mở khóa, phiếu sẽ quay lại trạng thái nháp để kiểm tra lại số liệu.
                </div>
                <label class="swal-enterprise-label mt-2">Lý do mở khóa *</label>
                <input id="swalUnlockReason" class="swal2-input swal-enterprise-input" placeholder="Ví dụ: Phát hiện đếm sai, cần kiểm tra lại" required>
            </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Xác nhận mở khóa',
            cancelButtonText: 'Hủy',
            confirmButtonColor: '#ef4444',
            preConfirm: () => {
                const reason = document.getElementById('swalUnlockReason')?.value?.trim();
                if (!reason) {
                    Swal.showValidationMessage('Vui lòng nhập lý do mở khóa');
                    return false;
                }
                return reason;
            }
        }).then(r => {
            if (r.isConfirmed && r.value) {
                document.getElementById('unlockReason-' + id).value = r.value;
                document.getElementById('unlockForm-' + id).submit();
            }
        });
    });
});
</script>
}
