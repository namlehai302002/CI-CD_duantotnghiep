@{
    ViewData["Title"] = "Báo cáo hàng chậm luân chuyển";
    var data = (IEnumerable<dynamic>)ViewBag.Data;
    var days = (int)ViewBag.Days;
    var canSeeFinancial = (bool)ViewBag.CanSeeFinancial;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">SKU không phát sinh giao dịch trong @days ngày qua.</p>
    </div>
</div>

<div class="filter-bar mb-3">
    <form method="get" class="enterprise-inline-controls">
        <div class="form-group min-w-200">
            <label class="form-label">Kho</label>
            <select name="warehouseId" class="form-control">
                <option value="">-- Tất cả kho --</option>
                @foreach (var wh in (IEnumerable<WMS.Models.Warehouse>)ViewBag.Warehouses)
                {
                    <option value="@wh.WarehouseId" selected="@(ViewBag.WarehouseId != null && (int)ViewBag.WarehouseId == wh.WarehouseId)">@wh.WarehouseCode - @wh.WarehouseName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Không giao dịch trong</label>
            <select name="days" class="form-control">
                <option value="60" selected="@(days == 60)">60 ngày</option>
                <option value="90" selected="@(days == 90)">90 ngày</option>
                <option value="180" selected="@(days == 180)">180 ngày</option>
                <option value="365" selected="@(days == 365)">365 ngày</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Lọc</button>
    </form>
</div>

@if (data.Any())
{
    <div class="stats-grid mb-3">
        <div class="stat-card">
            <div class="stat-value">@data.Count()</div>
            <div class="stat-label">Tổng SKU chậm luân chuyển</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@data.Sum(d => (decimal)d.CurrentStock).ToString("N0")</div>
            <div class="stat-label">Tổng SL tồn</div>
        </div>
        @if (canSeeFinancial)
        {
            <div class="stat-card danger">
                <div class="stat-value text-danger">@data.Sum(d => (decimal)d.StockValue).ToString("N0") VNĐ</div>
                <div class="stat-label">Giá trị vốn bị kẹt</div>
            </div>
        }
    </div>

    <div class="card">
        <div class="card-body table-card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Mã VT</th>
                        <th>Tên vật tư</th>
                        <th>Danh mục</th>
                        <th>ĐVT</th>
                        <th class="cell-right">Tồn kho</th>
                        @if (canSeeFinancial) { <th class="cell-right">Giá trị</th> }
                        <th>Giao dịch cuối</th>
                        <th class="cell-right">Ngày không GD</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in data)
                    {
                        var severityClass = d.DaysSinceLastTx > 365 ? "text-danger fw-700" :
                            d.DaysSinceLastTx > 180 ? "text-warning fw-600" : "";
                        <tr>
                            <td><strong>@d.ItemCode</strong></td>
                            <td>@d.ItemName</td>
                            <td>@d.CategoryName</td>
                            <td>@d.UomCode</td>
                            <td class="cell-right">@d.CurrentStock.ToString("N2")</td>
                            @if (canSeeFinancial) { <td class="cell-right">@d.StockValue.ToString("N0")</td> }
                            <td>@(d.LastTransactionDate?.ToString("dd/MM/yyyy") ?? "Chưa từng")</td>
                            <td class="cell-right @severityClass">
                                @(d.DaysSinceLastTx >= 9999 ? "∞" : d.DaysSinceLastTx.ToString("N0"))
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card"><div class="card-body empty-state">
        <i class="fas fa-check-circle empty-success-icon"></i>
        <p class="mt-3">Không có mặt hàng nào chậm luân chuyển trong @days ngày qua.</p>
    </div></div>
}
