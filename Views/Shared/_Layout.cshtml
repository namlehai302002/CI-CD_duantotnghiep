<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WMS Pro</title>
    <meta name="description" content="Hệ thống quản lý kho nguyên vật liệu và thành phẩm" />
    <meta name="theme-color" content="#C74634" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="WMS Pro" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="~/images/logo.svg" asp-append-version="true" />
    <link rel="alternate icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/pwa-icon-192.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            function asOptions(messageOrOptions, fallbackIcon) {
                if (messageOrOptions && typeof messageOrOptions === 'object') return messageOrOptions;
                return { text: String(messageOrOptions || ''), icon: fallbackIcon || 'info' };
            }

            function fallbackDialog(options, mode) {
                return new Promise(function (resolve) {
                    var overlay = document.createElement('div');
                    overlay.className = 'enterprise-dialog-overlay';
                    var box = document.createElement('div');
                    box.className = 'enterprise-dialog-box';
                    var inputHtml = mode === 'prompt'
                        ? '<input id="enterpriseDialogInput" class="enterprise-dialog-input" type="text" placeholder="' + escapeHtml(options.inputPlaceholder || '') + '" />'
                        : '';
                    box.innerHTML =
                        '<div class="enterprise-dialog-title">' + escapeHtml(options.title || 'Thông báo hệ thống') + '</div>' +
                        '<div class="enterprise-dialog-text">' + escapeHtml(options.text || '') + '</div>' +
                        inputHtml +
                        '<div class="enterprise-dialog-actions">' +
                        (mode !== 'notify' ? '<button type="button" id="enterpriseDialogCancel" class="enterprise-dialog-cancel">' + escapeHtml(options.cancelButtonText || 'Hủy') + '</button>' : '') +
                        '<button type="button" id="enterpriseDialogOk" class="enterprise-dialog-confirm">' + escapeHtml(options.confirmButtonText || 'Đồng ý') + '</button>' +
                        '</div>';
                    overlay.appendChild(box);
                    document.body.appendChild(overlay);

                    function close(value) {
                        overlay.remove();
                        resolve(value);
                    }

                    overlay.querySelector('#enterpriseDialogOk').addEventListener('click', function () {
                        if (mode === 'prompt') {
                            close(overlay.querySelector('#enterpriseDialogInput').value || null);
                            return;
                        }
                        close(true);
                    });
                    overlay.querySelector('#enterpriseDialogCancel')?.addEventListener('click', function () {
                        close(mode === 'prompt' ? null : false);
                    });
                    overlay.addEventListener('click', function (event) {
                        if (event.target === overlay) close(mode === 'prompt' ? null : false);
                    });
                    overlay.querySelector('#enterpriseDialogInput')?.focus();
                });
            }

            function escapeHtml(value) {
                var div = document.createElement('div');
                div.textContent = value == null ? '' : String(value);
                return div.innerHTML;
            }

            window.enterpriseNotify = function (messageOrOptions, icon) {
                var options = asOptions(messageOrOptions, icon || 'info');
                if (window.Swal) {
                    return Swal.fire({
                        toast: options.toast !== false,
                        position: options.position || 'top-end',
                        icon: options.icon || 'info',
                        title: options.title || options.text || 'Thông báo hệ thống',
                        text: options.title ? options.text : undefined,
                        customClass: {
                            popup: 'enterprise-toast-popup',
                            title: 'enterprise-toast-title'
                        },
                        showConfirmButton: options.showConfirmButton === true,
                        timer: options.timer || 3600,
                        timerProgressBar: true
                    });
                }
                return fallbackDialog(options, 'notify');
            };

            window.enterpriseConfirm = function (messageOrOptions) {
                var options = asOptions(messageOrOptions, 'question');
                if (window.Swal) {
                    return Swal.fire({
                        title: options.title || 'Xác nhận thao tác',
                        html: options.html,
                        text: options.html ? undefined : (options.text || ''),
                        icon: options.icon || 'question',
                        showCancelButton: true,
                        confirmButtonText: options.confirmButtonText || 'Xác nhận',
                        cancelButtonText: options.cancelButtonText || 'Hủy',
                        confirmButtonColor: options.confirmButtonColor || '#2563eb',
                        focusCancel: options.focusCancel !== false
                    }).then(function (result) { return !!result.isConfirmed; });
                }
                return fallbackDialog(options, 'confirm');
            };

            window.enterprisePrompt = function (messageOrOptions) {
                var options = asOptions(messageOrOptions, 'question');
                if (window.Swal) {
                    return Swal.fire({
                        title: options.title || 'Nhập thông tin',
                        text: options.text || '',
                        input: options.input || 'text',
                        inputPlaceholder: options.inputPlaceholder || '',
                        inputValue: options.inputValue || '',
                        icon: options.icon || 'question',
                        showCancelButton: true,
                        confirmButtonText: options.confirmButtonText || 'Tiếp tục',
                        cancelButtonText: options.cancelButtonText || 'Hủy',
                        inputValidator: options.inputValidator
                    }).then(function (result) { return result.isConfirmed ? (result.value || '') : null; });
                }
                return fallbackDialog(options, 'prompt');
            };

            window.alert = function (message) {
                window.enterpriseNotify({ title: 'Thông báo hệ thống', text: String(message || ''), icon: 'info' });
            };
            window.confirm = function (message) {
                window.enterpriseNotify({ title: 'Cần xác nhận chuẩn enterprise', text: String(message || ''), icon: 'warning' });
                return false;
            };
            window.prompt = function (message) {
                window.enterpriseNotify({ title: 'Cần biểu mẫu nhập liệu chuẩn enterprise', text: String(message || ''), icon: 'warning' });
                return null;
            };

            document.addEventListener('submit', function (event) {
                var form = event.target.closest('form[data-enterprise-confirm]');
                if (!form || form.dataset.enterpriseConfirmed === 'true') return;
                event.preventDefault();
                window.enterpriseConfirm({
                    title: form.dataset.enterpriseConfirmTitle || 'Xác nhận thao tác',
                    text: form.dataset.enterpriseConfirm,
                    icon: form.dataset.enterpriseConfirmIcon || 'question',
                    confirmButtonText: form.dataset.enterpriseConfirmOk || 'Xác nhận',
                    cancelButtonText: form.dataset.enterpriseConfirmCancel || 'Hủy'
                }).then(function (ok) {
                    if (!ok) return;
                    form.dataset.enterpriseConfirmed = 'true';
                    form.requestSubmit();
                    setTimeout(function () { delete form.dataset.enterpriseConfirmed; }, 0);
                });
            }, true);
        })();
    </script>
</head>
@{
    var layoutControllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var layoutIsAccountPage = layoutControllerName == "Account";
    var layoutCanOperate = !layoutIsAccountPage && (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Staff"));
}
<body class="app-shell @(layoutIsAccountPage ? "account-shell" : "")" data-wms-operational="@(layoutCanOperate ? "true" : "false")">
    @if (!layoutIsAccountPage)
    {
        var isAdmin = User.IsInRole("Admin");
        var isManager = User.IsInRole("Manager");
        var isStaff = User.IsInRole("Staff");
        var isViewer = !isAdmin && !isManager && !isStaff;
        var isAdminOrManager = isAdmin || isManager;
        var canOperate = isAdmin || isManager || isStaff;
        var canSeeFinancialReports = isAdmin || User.Claims.Any(c => c.Type == "perm" && c.Value == "report.view.financial");
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var act = ViewContext.RouteData.Values["action"]?.ToString();
        var mobileQuickDockActions = new[] { "NextTask", "RfReceiving", "RfPicking", "RfMovement", "LpnLookup", "SerialLookup", "PackageLookup" };
        var showMobileQuickDock = canOperate && ctrl == "Operations" && mobileQuickDockActions.Contains(act);
        var voucherTypeQuery = Context.Request.Query["type"].FirstOrDefault();
        var isCreateInbound = ctrl == "Vouchers" && act == "Create" && voucherTypeQuery == "1";
        var isCreateOutbound = ctrl == "Vouchers" && act == "Create" && voucherTypeQuery == "2";
        var layoutTitle = !string.IsNullOrWhiteSpace(ViewData["Title"]?.ToString()) ? ViewData["Title"]?.ToString() : "WMS Pro";
        var userInitial = User.Identity?.Name?.Length >= 1 ? User.Identity.Name.Substring(0, 1).ToUpper() : "?";
        var userFullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Người dùng";
        var roleClaimTopbar = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
        var roleDisplayTopbar = roleClaimTopbar switch {
            "Admin" => "Quản trị viên",
            "Manager" => "Quản lý kho",
            "Staff" => "Nhân viên kho",
            "Viewer" => "Chỉ xem",
            _ => roleClaimTopbar
        };
        var layoutScopedWarehouseId = (int?)null;
        if (!isAdmin && int.TryParse(User.FindFirst("WarehouseId")?.Value, out var layoutWarehouseClaim))
        {
            layoutScopedWarehouseId = layoutWarehouseClaim;
        }
        var layoutPendingInboundApprovals = 0;
        if (isAdminOrManager)
        {
            var layoutDb = (WMS.Data.AppDbContext)Context.RequestServices.GetService(typeof(WMS.Data.AppDbContext))!;
            var pendingInboundQuery = layoutDb.Vouchers.Where(v => !v.IsCancelled
                && (v.VoucherType == WMS.Models.VoucherTypeEnum.NhapKho || v.VoucherType == WMS.Models.VoucherTypeEnum.KhachTra || v.VoucherType == WMS.Models.VoucherTypeEnum.NhapThanhPham)
                && v.InboundStatus == WMS.Models.InboundStatusEnum.PendingApproval);
            if (layoutScopedWarehouseId.HasValue)
            {
                pendingInboundQuery = pendingInboundQuery.Where(v => v.WarehouseId == layoutScopedWarehouseId.Value);
            }
            layoutPendingInboundApprovals = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.CountAsync(pendingInboundQuery);
        }

        <header class="app-topbar" id="appTopbar">
            <div class="topbar-left">
                <button id="sidebarToggle" class="topbar-icon-btn" type="button" aria-label="Mở hoặc thu gọn menu">
                    <i class="fas fa-bars"></i>
                </button>
                <a class="topbar-brand" asp-controller="Home" asp-action="Index" aria-label="WMS Pro">
                    <img src="~/images/logo.svg" asp-append-version="true" alt="WMS Pro" class="topbar-brand-mark" />
                </a>
                <div class="topbar-screen-title">@layoutTitle</div>
            </div>
            <div class="topbar-search">
                <button class="topbar-search-trigger" type="button" data-wms-call="openQuickSearch" title="Tìm kiếm nhanh (Ctrl+K)">
                    <i class="fas fa-search"></i>
                    <span>Tìm mã phiếu, vật tư, mã vạch...</span>
                    <kbd>Ctrl+K</kbd>
                </button>
            </div>
            <div class="topbar-right">
                <button class="topbar-icon-btn" type="button" title="Màn hình yêu thích" data-wms-notify-title="Màn hình yêu thích" data-wms-notify-text="Các lối vào thường dùng đã được gom tại trang chính." data-wms-notify-icon="info">
                    <i class="fas fa-star"></i>
                </button>
                <a class="topbar-icon-btn" asp-controller="Reports" asp-action="Alerts" title="Cảnh báo vận hành">
                    <i class="fas fa-bell"></i>
                </a>
                <a class="topbar-icon-btn" asp-controller="Help" asp-action="Index" title="Trợ giúp">
                    <i class="fas fa-circle-question"></i>
                </a>
                <div class="warehouse-context" title="Kho đang thao tác">
                    <i class="fas fa-warehouse"></i>
                    <span>Kho vận hành</span>
                </div>
                <details class="topbar-user">
                    <summary>
                        <span class="topbar-avatar">@userInitial</span>
                        <span class="topbar-user-text">
                            <strong>@userFullName</strong>
                            <small>@roleDisplayTopbar</small>
                        </span>
                        <i class="fas fa-chevron-down"></i>
                    </summary>
                    <div class="topbar-user-menu">
                        <a asp-controller="Account" asp-action="TrustedDevices"><i class="fas fa-shield-halved"></i> Thiết bị tin cậy</a>
                        <a asp-controller="Help" asp-action="Index"><i class="fas fa-book-open"></i> Hướng dẫn sử dụng</a>
                        <form method="post" asp-controller="Account" asp-action="Logout">
                            @Html.AntiForgeryToken()
                            <button type="submit"><i class="fas fa-sign-out-alt"></i> Đăng xuất</button>
                        </form>
                    </div>
                </details>
            </div>
        </header>

        <aside class="sidebar app-sidebar" id="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><img src="~/images/logo.svg" asp-append-version="true" alt="Biểu trưng" /></div>
                <div class="brand-text">
                    <span class="brand-name">WMS Pro</span>
                    <span class="brand-sub">Nội bộ nhân viên kho</span>
                </div>
            </a>
            <div class="sidebar-tools">
                <button type="button" class="sidebar-pin-btn" id="sidebarPinToggle" title="Ghim hoặc thu gọn menu">
                    <i class="fas fa-thumbtack"></i>
                    <span>Ghim menu</span>
                </button>
                <label class="sidebar-search" for="sidebarSearchInput">
                    <i class="fas fa-search"></i>
                    <input id="sidebarSearchInput" type="search" autocomplete="off" placeholder="Tìm chức năng..." />
                </label>
            </div>
            <nav class="sidebar-nav">
                @* ═══ TRANG CHÍNH ═══ *@
                <div class="nav-section nav-rail-link" data-nav-kind="link" data-nav-label="Trang chính">
                    <a class="nav-link @(ctrl == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index" aria-label="Trang chính">
                        <span class="nav-icon"><i class="fas fa-chart-pie"></i></span> Trang chính
                    </a>
                </div>

                @if (canOperate)
                {
                    @* ═══ NHẬP KHO ═══ *@
                    <div class="nav-section nav-rail-group" data-section="inbound" data-nav-kind="group" data-nav-label="Nhập kho">
                        <button class="nav-section-title nav-section-inbound" type="button" data-section="inbound" aria-expanded="true" aria-label="Nhập kho">
                            <span class="nav-section-icon"><i class="fas fa-arrow-down"></i></span>
                            <span class="nav-section-label">NHẬP KHO</span>
                            @if (layoutPendingInboundApprovals > 0)
                            {
                                <span class="nav-section-badge">@layoutPendingInboundApprovals</span>
                            }
                            <i class="fas fa-chevron-down section-chevron"></i>
                        </button>
                        <div class="nav-section-body">
                            <a class="nav-link @(isCreateInbound ? "active" : "")" asp-controller="Vouchers" asp-action="Create" asp-route-type="1">
                                <span class="nav-icon"><i class="fas fa-plus"></i></span> Tạo phiếu nhập
                            </a>
                            @if (isAdminOrManager)
                            {
                                <a class="nav-link @(ctrl == "Operations" && act == "InboundApprovals" ? "active" : "")" asp-controller="Operations" asp-action="InboundApprovals">
                                    <span class="nav-icon"><i class="fas fa-clipboard-check"></i></span> Duyệt phiếu nhập
                                    @if (layoutPendingInboundApprovals > 0)
                                    {
                                        <span class="nav-badge">@layoutPendingInboundApprovals</span>
                                    }
                                </a>
                            }
                            <a class="nav-link @(ctrl == "Operations" && act == "Receiving" ? "active" : "")" asp-controller="Operations" asp-action="Receiving">
                                <span class="nav-icon"><i class="fas fa-truck-loading"></i></span> Tiếp nhận hàng
                            </a>
                            <a class="nav-link @(ctrl == "Operations" && act == "DockBoard" ? "active" : "")" asp-controller="Operations" asp-action="DockBoard">
                                <span class="nav-icon"><i class="fas fa-display"></i></span> Bảng điều phối cửa bến
                            </a>
                            <a class="nav-link @(ctrl == "Operations" && act == "YardManagement" ? "active" : "")" asp-controller="Operations" asp-action="YardManagement">
                                <span class="nav-icon"><i class="fas fa-truck-ramp-box"></i></span> Quản lý bãi đỗ
                            </a>
                            @if (isAdminOrManager)
                            {
                                <a class="nav-link @(ctrl == "Operations" && act == "YardBillingCharges" ? "active" : "")" asp-controller="Operations" asp-action="YardBillingCharges">
                                    <span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span> Đối soát phí bãi
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "YardBillingRates" ? "active" : "")" asp-controller="Operations" asp-action="YardBillingRates">
                                    <span class="nav-icon"><i class="fas fa-money-bill-trend-up"></i></span> Bảng giá phí bãi
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && (act == "ThreePlBillingRuns" || act == "ThreePlBillingRunDetails") ? "active" : "")" asp-controller="Operations" asp-action="ThreePlBillingRuns">
                                    <span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span> Tính phí kho nhiều chủ hàng
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "ThreePlBillingRates" ? "active" : "")" asp-controller="Operations" asp-action="ThreePlBillingRates">
                                    <span class="nav-icon"><i class="fas fa-coins"></i></span> Bảng giá kho nhiều chủ hàng
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && (act == "ThreePlContracts" || act == "ThreePlInvoiceDetails") ? "active" : "")" asp-controller="Operations" asp-action="ThreePlContracts">
                                    <span class="nav-icon"><i class="fas fa-file-contract"></i></span> Hợp đồng kho nhiều chủ hàng
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "ThreePlClientPortal" ? "active" : "")" asp-controller="Operations" asp-action="ThreePlClientPortal">
                                    <span class="nav-icon"><i class="fas fa-user-shield"></i></span> Khu vực chủ hàng
                                </a>
                            }
                            <a class="nav-link @(ctrl == "Operations" && act == "RfReceiving" ? "active" : "")" asp-controller="Operations" asp-action="RfReceiving">
                                <span class="nav-icon"><i class="fas fa-mobile-screen"></i></span> Quét nhận hàng bằng điện thoại
                            </a>
                            <a class="nav-link @(ctrl == "Operations" && act == "QualityInspection" ? "active" : "")" asp-controller="Operations" asp-action="QualityInspection">
                                <span class="nav-icon"><i class="fas fa-microscope"></i></span> Kiểm tra chất lượng
                            </a>
                        </div>
                    </div>

                    @* ═══ XUẤT KHO ═══ *@
                    <div class="nav-section nav-rail-group" data-section="outbound" data-nav-kind="group" data-nav-label="Xuất kho">
                        <button class="nav-section-title nav-section-outbound" type="button" data-section="outbound" aria-expanded="true" aria-label="Xuất kho">
                            <span class="nav-section-icon"><i class="fas fa-arrow-up"></i></span>
                            <span class="nav-section-label">XUẤT KHO</span>
                            <i class="fas fa-chevron-down section-chevron"></i>
                        </button>
                        <div class="nav-section-body">
                            <a class="nav-link @(isCreateOutbound ? "active" : "")" asp-controller="Vouchers" asp-action="Create" asp-route-type="2">
                                <span class="nav-icon"><i class="fas fa-plus"></i></span> Tạo phiếu xuất
                            </a>

                            @if (isAdminOrManager)
                            {
                                <a class="nav-link @(ctrl == "Operations" && act == "Waves" ? "active" : "")" asp-controller="Operations" asp-action="Waves">
                                    <span class="nav-icon"><i class="fas fa-layer-group"></i></span> Đợt gom đơn
                                </a>
                            }
                            <a class="nav-link @(ctrl == "Operations" && act == "PickTasks" ? "active" : "")" asp-controller="Operations" asp-action="PickTasks">
                                <span class="nav-icon"><i class="fas fa-list-check"></i></span> Nhiệm vụ lấy hàng
                            </a>
                            <a class="nav-link @(ctrl == "Operations" && act == "RfPicking" ? "active" : "")" asp-controller="Operations" asp-action="RfPicking">
                                <span class="nav-icon"><i class="fas fa-mobile-alt"></i></span> Quét lấy hàng bằng điện thoại
                            </a>
                            <a class="nav-link @(ctrl == "Operations" && act == "NextTask" ? "active" : "")" asp-controller="Operations" asp-action="NextTask">
                                <span class="nav-icon"><i class="fas fa-forward"></i></span> Nhiệm vụ tiếp theo
                            </a>
                            @if (isAdminOrManager)
                            {
                                <a class="nav-link @(ctrl == "Operations" && act == "Shipping" ? "active" : "")" asp-controller="Operations" asp-action="Shipping">
                                    <span class="nav-icon"><i class="fas fa-truck-fast"></i></span> Đóng gói & giao
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "ShippingDispatch" ? "active" : "")" asp-controller="Operations" asp-action="ShippingDispatch">
                                    <span class="nav-icon"><i class="fas fa-route"></i></span> Điều phối vận chuyển
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "DeliveryReconciliation" ? "active" : "")" asp-controller="Operations" asp-action="DeliveryReconciliation">
                                    <span class="nav-icon"><i class="fas fa-clipboard-check"></i></span> Đối soát giao hàng
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "CarrierConnectors" ? "active" : "")" asp-controller="Operations" asp-action="CarrierConnectors">
                                    <span class="nav-icon"><i class="fas fa-plug-circle-bolt"></i></span> Bộ kết nối vận tải
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && (act == "ShipmentLoads" || act == "ShipmentLoadDetails") ? "active" : "")" asp-controller="Operations" asp-action="ShipmentLoads">
                                    <span class="nav-icon"><i class="fas fa-truck-ramp-box"></i></span> Bảng chuyến xe
                                </a>
                                <a class="nav-link @(ctrl == "Labels" ? "active" : "")" asp-controller="Labels" asp-action="PrintJobs">
                                    <span class="nav-icon"><i class="fas fa-tags"></i></span> Nhãn & chứng từ
                                </a>
                                <a class="nav-link @(ctrl == "Operations" && act == "CrossDockOpportunities" ? "active" : "")" asp-controller="Operations" asp-action="CrossDockOpportunities">
                                    <span class="nav-icon"><i class="fas fa-shuffle"></i></span> Chuyển thẳng
                                </a>
                            }
                            @if (isStaff)
                            {
                                <a class="nav-link @(ctrl == "Labels" ? "active" : "")" asp-controller="Labels" asp-action="PrintJobs">
                                    <span class="nav-icon"><i class="fas fa-tags"></i></span> Nhãn & chứng từ
                                </a>
                            }
                        </div>
                    </div>
                }

                @* ═══ TỒN KHO ═══ *@
                <div class="nav-section nav-rail-group" data-section="inventory" data-nav-kind="group" data-nav-label="Tồn kho">
