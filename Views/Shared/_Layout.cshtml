    <script>
        /* ── Collapsible sidebar sections (Enterprise UX) ── */
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const toggle = document.getElementById('sidebarToggle');
            const overlay = document.getElementById('sidebarOverlay');
            const pinToggle = document.getElementById('sidebarPinToggle');
            const sidebarSearch = document.getElementById('sidebarSearchInput');
            const desktopQuery = window.matchMedia('(min-width: 1025px)');

            function readCollapsedState() {
                try {
                    return JSON.parse(localStorage.getItem('wms_nav_collapsed') || '{}');
                } catch {
                    return {};
                }
            }

            function writeCollapsedState(collapsed) {
                localStorage.setItem('wms_nav_collapsed', JSON.stringify(collapsed));
            }

            function isDesktopCollapsed() {
                return desktopQuery.matches && document.body.classList.contains('sidebar-collapsed');
            }

            function setSectionExpanded(section, expanded, persist) {
                section.classList.toggle('collapsed', !expanded);
                var button = section.querySelector('.nav-section-title');
                if (button) button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                if (persist && section.dataset.section) {
                    var collapsed = readCollapsedState();
                    collapsed[section.dataset.section] = !expanded;
                    writeCollapsedState(collapsed);
                }
            }

            function closeSidebarFlyout() {
                document.querySelectorAll('.sidebar .nav-section.flyout-open').forEach(function(section) {
                    section.classList.remove('flyout-open');
                    if (isDesktopCollapsed()) {
                        var button = section.querySelector('.nav-section-title');
                        if (button) button.setAttribute('aria-expanded', 'false');
                    }
                });
            }

            function syncSidebarAria() {
                document.querySelectorAll('.sidebar .nav-section[data-section]').forEach(function(section) {
                    var button = section.querySelector('.nav-section-title');
                    if (!button) return;
                    if (isDesktopCollapsed()) {
                        button.setAttribute('aria-expanded', section.classList.contains('flyout-open') ? 'true' : 'false');
                    } else {
                        button.setAttribute('aria-expanded', section.classList.contains('collapsed') ? 'false' : 'true');
                    }
                });
            }

            function openSidebarFlyout(section) {
                if (!section || !isDesktopCollapsed()) return;
                var body = section.querySelector('.nav-section-body');
                if (!body) return;

                document.querySelectorAll('.sidebar .nav-section.flyout-open').forEach(function(openSection) {
                    if (openSection !== section) {
                        openSection.classList.remove('flyout-open');
                        var openButton = openSection.querySelector('.nav-section-title');
                        if (openButton) openButton.setAttribute('aria-expanded', 'false');
                    }
                });

                var headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height'), 10) || 56;
                var rect = section.getBoundingClientRect();
                var maxPanelHeight = Math.min(560, Math.max(260, window.innerHeight - headerHeight - 20));
                var top = Math.max(headerHeight + 8, Math.min(rect.top, window.innerHeight - maxPanelHeight - 12));
                section.style.setProperty('--flyout-top', top + 'px');
                section.classList.add('flyout-open');
                var button = section.querySelector('.nav-section-title');
                if (button) button.setAttribute('aria-expanded', 'true');
            }

            function handleSectionToggle(button) {
                var section = button.closest('.nav-section');
                if (!section) return;
                if (isDesktopCollapsed()) {
                    if (section.classList.contains('flyout-open')) {
                        closeSidebarFlyout();
                    } else {
                        openSidebarFlyout(section);
                    }
                    return;
                }

                var expanded = section.classList.contains('collapsed');
                setSectionExpanded(section, expanded, true);
            }

            /* restore collapsed state from localStorage */
            var collapsed = readCollapsedState();
            document.querySelectorAll('.nav-section[data-section]').forEach(function(sec) {
                var key = sec.dataset.section;
                /* auto-expand if section contains active link */
                var hasActive = sec.querySelector('.nav-link.active');
                if (hasActive) {
                    sec.classList.add('has-active');
                    sec.classList.remove('collapsed');
                    collapsed[key] = false;
                } else if (collapsed[key]) {
                    sec.classList.add('collapsed');
                }
                var button = sec.querySelector('.nav-section-title');
                if (button) button.setAttribute('aria-expanded', sec.classList.contains('collapsed') ? 'false' : 'true');
            });
            writeCollapsedState(collapsed);

            /* điều hướng trái: mở trên điện thoại, thu gọn trên máy tính */
            function toggleSidebar() {
                if (!sidebar || !overlay) return;
                if (desktopQuery.matches) {
                    document.body.classList.toggle('sidebar-collapsed');
                    closeSidebarFlyout();
                    syncSidebarAria();
                    localStorage.setItem('wms_sidebar_collapsed', document.body.classList.contains('sidebar-collapsed') ? 'true' : 'false');
                    return;
                }

                sidebar.classList.toggle('open');
                overlay.classList.toggle('active');
                document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
            }

            function closeMobileSidebar() {
                if (!sidebar || !overlay) return;
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            if(toggle) toggle.addEventListener('click', toggleSidebar);
            if(pinToggle) pinToggle.addEventListener('click', toggleSidebar);
            if(overlay) overlay.addEventListener('click', closeMobileSidebar);
            if (localStorage.getItem('wms_sidebar_collapsed') === 'true' && desktopQuery.matches) {
                document.body.classList.add('sidebar-collapsed');
                syncSidebarAria();
            }
            desktopQuery.addEventListener?.('change', function(event) {
                closeSidebarFlyout();
                if (!event.matches) document.body.classList.remove('sidebar-collapsed');
                syncSidebarAria();
                closeMobileSidebar();
            });

            document.querySelectorAll('.sidebar .nav-section-title').forEach(function(button) {
                var section = button.closest('.nav-section');
                button.addEventListener('click', function(event) {
                    event.preventDefault();
                    handleSectionToggle(button);
                });
                button.addEventListener('mouseenter', function() {
                    if (isDesktopCollapsed()) openSidebarFlyout(section);
                });
                button.addEventListener('focus', function() {
                    if (isDesktopCollapsed()) openSidebarFlyout(section);
                });
            });

            document.querySelectorAll('.sidebar .nav-rail-group').forEach(function(section) {
                section.addEventListener('mouseleave', function() {
                    window.setTimeout(function() {
                        if (isDesktopCollapsed() && !section.matches(':hover') && !section.contains(document.activeElement)) {
                            section.classList.remove('flyout-open');
                            syncSidebarAria();
                        }
                    }, 120);
                });
            });

            document.addEventListener('click', function(event) {
                if (isDesktopCollapsed() && sidebar && !sidebar.contains(event.target)) {
                    closeSidebarFlyout();
                }
            });

            document.addEventListener('keydown', function(event) {
                if (event.key === 'Escape') {
                    closeSidebarFlyout();
                }
            });

            if (sidebarSearch) {
                sidebarSearch.addEventListener('input', function() {
                    var query = this.value.trim().toLocaleLowerCase('vi');
                    document.querySelectorAll('.sidebar .nav-link').forEach(function(link) {
                        var matched = !query || link.textContent.toLocaleLowerCase('vi').includes(query);
                        link.classList.toggle('nav-filter-hidden', !matched);
                    });
                    document.querySelectorAll('.sidebar .nav-section').forEach(function(section) {
                        var hasVisibleLink = !!section.querySelector('.nav-link:not(.nav-filter-hidden)');
                        section.classList.toggle('nav-filter-hidden', query && !hasVisibleLink);
                    });
                });
            }

            /* prevent same-page reload */
            document.querySelectorAll('.sidebar .nav-link').forEach(function(link) {
                link.addEventListener('click', function(e) {
                    const currentUrl = new URL(window.location.href);
                    const targetUrl = new URL(link.href, window.location.origin);
                    const isSamePath = currentUrl.pathname.replace(/\/+$/, '') === targetUrl.pathname.replace(/\/+$/, '');
                    const isSameQuery = currentUrl.search === targetUrl.search;
                    if (isSamePath && isSameQuery) {
                        e.preventDefault();
                    }
                    if (!desktopQuery.matches) closeMobileSidebar();
                });
            });

            /* scroll active link into view */
            var activeLink = document.querySelector('.sidebar .nav-link.active');
            if (activeLink) {
                activeLink.scrollIntoView({ block: 'center', behavior: 'instant' });
            }
        });

        /* ── Tìm kiếm nhanh (Ctrl+K) ── */
        var qsTimer = null;
        var quickSearchUrls = {
            createInbound: '@Url.Action("Create", "Vouchers", new { type = 1 })',
            itemByBarcode: '@Url.Action("GetItemByBarcode", "Items")',
            itemDetails: '@Url.Action("Details", "Items")',
            vouchers: '@Url.Action("Index", "Vouchers")',
            items: '@Url.Action("Index", "Items")',
            inventory: '@Url.Action("Inventory", "Reports")'
        };
        function openQuickSearch() {
            var ov = document.getElementById('qsOverlay');
            ov.classList.add('active');
            document.getElementById('qsInput').value = '';
            document.getElementById('qsResults').innerHTML = '<div class="qs-empty"><i class="fas fa-lightbulb"></i> Gõ mã phiếu, vật tư hoặc mã vạch để tìm.</div>';
            setTimeout(function(){ document.getElementById('qsInput').focus(); }, 100);
        }
        function closeQuickSearch() {
            document.getElementById('qsOverlay').classList.remove('active');
        }
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openQuickSearch(); }
            if (e.key === 'Escape') closeQuickSearch();
            /* Ctrl+N → create new voucher */
            if ((e.ctrlKey || e.metaKey) && e.key === 'n' && !e.shiftKey) {
                var activeEl = document.activeElement;
                if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.isContentEditable)) return;
                e.preventDefault();
                window.location.href = quickSearchUrls.createInbound;
            }
        });
        document.getElementById('qsOverlay')?.addEventListener('click', function(e) {
            if (e.target === this) closeQuickSearch();
        });
        document.getElementById('qsInput')?.addEventListener('input', function() {
            clearTimeout(qsTimer);
            var q = this.value.trim();
            if (q.length < 2) {
                document.getElementById('qsResults').innerHTML = '<div class="qs-empty"><i class="fas fa-lightbulb"></i> Gõ ít nhất 2 ký tự.</div>';
                return;
            }
            document.getElementById('qsResults').innerHTML = '<div class="qs-empty"><i class="fas fa-spinner fa-spin"></i> Đang tìm...</div>';
            qsTimer = setTimeout(function(){ doQuickSearch(q); }, 300);
        });
        function doQuickSearch(q) {
            var results = [];
            /* tìm vật tư */
            fetch(quickSearchUrls.itemByBarcode + '?barcode=' + encodeURIComponent(q))
                .then(function(r){ return r.ok ? r.json() : null; })
                .then(function(item){
                    if (item) results.push({type:'item', icon:'fa-box', label:item.itemCode + ' — ' + item.itemName, url: quickSearchUrls.itemDetails + '/' + item.itemId});
                })
                .catch(function(){})
                .finally(function(){
                    renderQsResults(results, q);
                });
        }
        function renderQsResults(results, q) {
            var html = '';
            /* always add shortcut links */
            html += '<div class="qs-group-title">Đi nhanh</div>';
            html += '<a class="qs-item" href="' + quickSearchUrls.vouchers + '?search=' + encodeURIComponent(q) + '"><i class="fas fa-file-invoice"></i> Tìm phiếu "' + escHtml(q) + '"</a>';
            html += '<a class="qs-item" href="' + quickSearchUrls.items + '?search=' + encodeURIComponent(q) + '"><i class="fas fa-boxes-stacked"></i> Tìm vật tư "' + escHtml(q) + '"</a>';
            html += '<a class="qs-item" href="' + quickSearchUrls.inventory + '?search=' + encodeURIComponent(q) + '"><i class="fas fa-clipboard-list"></i> Tìm tồn kho "' + escHtml(q) + '"</a>';
            if (results.length > 0) {
                html += '<div class="qs-group-title">Kết quả khớp</div>';
                results.forEach(function(r){
                    html += '<a class="qs-item qs-match" href="' + r.url + '"><i class="fas ' + r.icon + '"></i> ' + escHtml(r.label) + '</a>';
                });
            }
            document.getElementById('qsResults').innerHTML = html;
        }
        function escHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        /* ── Sortable Tables (Enterprise) ── */
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('thead th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var table = th.closest('table');
                    var tbody = table.querySelector('tbody');
                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    var colIndex = Array.from(th.parentElement.children).indexOf(th);
                    var isAsc = th.classList.contains('sort-asc');

                    /* reset all headers in this table */
                    th.parentElement.querySelectorAll('th.sortable').forEach(function(h) {
                        h.classList.remove('sort-asc', 'sort-desc');
                    });

                    var direction = isAsc ? 'desc' : 'asc';
                    th.classList.add('sort-' + direction);

                    rows.sort(function(a, b) {
                        var aText = (a.children[colIndex]?.textContent || '').trim();
                        var bText = (b.children[colIndex]?.textContent || '').trim();
                        var aNum = parseFloat(aText.replace(/[^0-9.,-]/g, '').replace(',', '.'));
                        var bNum = parseFloat(bText.replace(/[^0-9.,-]/g, '').replace(',', '.'));
                        if (!isNaN(aNum) && !isNaN(bNum)) {
                            return direction === 'asc' ? aNum - bNum : bNum - aNum;
                        }
                        return direction === 'asc' ? aText.localeCompare(bText, 'vi') : bText.localeCompare(aText, 'vi');
                    });

                    rows.forEach(function(row) { tbody.appendChild(row); });
                });
            });
        });

        /* ── Xuất Excel phục vụ vận hành doanh nghiệp ── */
        function getVietnamDateStamp() {
            return new Intl.DateTimeFormat('en-CA', {
                timeZone: 'Asia/Ho_Chi_Minh',
                year: 'numeric',
                month: '2-digit',
                day: '2-digit'
            }).format(new Date());
        }

        function exportTableToExcel(tableSelector, filename) {
            var table = document.querySelector(tableSelector);
            if (!table) { window.enterpriseNotify({ title:'Không tìm thấy bảng dữ liệu', icon:'warning', timer:3000 }); return; }
            var clone = table.cloneNode(true);
            clone.querySelectorAll('script, style, button, .td-actions, .no-export').forEach(function(node) { node.remove(); });
            clone.querySelectorAll('a').forEach(function(link) { link.replaceWith(document.createTextNode(link.textContent.trim())); });
            var html = '<html><head><meta charset="utf-8" /></head><body>' + clone.outerHTML + '</body></html>';
            var blob = new Blob(['\uFEFF' + html], { type: 'application/vnd.ms-excel;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = (filename || 'xuat_du_lieu') + '_' + getVietnamDateStamp() + '.xls';
            a.click();
            URL.revokeObjectURL(url);
            var rows = table.querySelectorAll('tbody tr').length || Math.max(0, table.querySelectorAll('tr').length - 1);
            window.enterpriseNotify({ title:'Đã xuất Excel ' + rows + ' dòng', icon:'success', timer:3000 });
        }

        function exportTableToCsv(tableSelector, filename) {
            exportTableToExcel(tableSelector, filename);
        }
    </script>
